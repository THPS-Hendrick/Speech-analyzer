    <script>
        (function() {
            // New GitHub Dictionary URLs!
            const DICT_URLS = {
                simple: "https://raw.githubusercontent.com/THPS-Hendrick/Speech-analyzer/main/simple.json",
                visual: "https://raw.githubusercontent.com/THPS-Hendrick/Speech-analyzer/main/visualdict.json"
            };

            let personalPronouns = new Set(["i", "i'd", "i'll", "i'm", "i've", "he", "he'd", "he'll", "he's", "she", "she'd", "she'll", "she's"]);
            
            let visualDictPronouns = new Set();
            let visualDictWords = new Set();
            
            let simpleMap = new Map();
            let google10kSet = new Set();
            let dictsLoaded = false;

            // Load logic
            async function loadDictionaries() {
                let loadErrorType = null;
                let errorDictName = "";

                try {
                    const fetchDict = async (url, dictName) => {
                        if (!url) return {};
                        try {
                            const res = await fetch(url + "?v=" + Date.now(), { cache: "no-store" });
                            if (!res.ok) throw new Error("Fetch failed: " + res.status);
                            
                            const textData = await res.text();
                            try {
                                return JSON.parse(textData);
                            } catch (jsonErr) {
                                console.error(`JSON Syntax Error in ${dictName}:`, jsonErr);
                                throw new Error(`JSON_SYNTAX_${dictName}`);
                            }
                        } catch(e) {
                            console.warn(`Failed to load dictionary: ${dictName}`, e);
                            if (e.message.startsWith("JSON_SYNTAX_")) {
                                loadErrorType = "JSON";
                                errorDictName = dictName;
                            } else if (!loadErrorType) {
                                loadErrorType = "NETWORK";
                            }
                            return {}; 
                        }
                    };

                    const [simpleData, visualData] = await Promise.all([
                        fetchDict(DICT_URLS.simple, "simple.json"),
                        fetchDict(DICT_URLS.visual, "visualdict.json")
                    ]);

                    for (const [tier, words] of Object.entries(simpleData)) {
                        let t = tier.toLowerCase();
                        let finalTier = 'outside';
                        if (t.includes('5yr') || t.includes('5 yr')) finalTier = '5yr Old 1000';
                        else if (t.includes('esl')) finalTier = 'ESL 2000';
                        else if (t.includes('kitchen') || t.includes('kit')) finalTier = 'Kitchen 1000';
                        
                        if (finalTier !== 'outside') {
                            words.forEach(w => simpleMap.set(w.toLowerCase(), finalTier));
                        }
                    }

                    const getFuzzyKey = (obj, keyword) => {
                        const key = Object.keys(obj).find(k => k.toLowerCase().includes(keyword));
                        return key ? obj[key] : null;
                    };
                    
                    let vPronouns = getFuzzyKey(visualData, "pronoun");
                    let vWords = getFuzzyKey(visualData, "visual");

                    if (vPronouns) visualDictPronouns = new Set(vPronouns.map(w => w.toLowerCase()));
                    if (vWords) visualDictWords = new Set(vWords.map(w => w.toLowerCase()));
                    
                    try {
                        const gRes = await fetch('https://cdn.jsdelivr.net/gh/first20hours/google-10000-english@master/google-10000-english-no-swears.txt');
                        if(gRes.ok) {
                            const gText = await gRes.text();
                            const gWords = gText.split('\n').map(w => w.trim().toLowerCase()).filter(w => w.length > 0);
                            google10kSet = new Set(gWords);
                        } else {
                            if (!loadErrorType) loadErrorType = "NETWORK";
                        }
                    } catch(e) { 
                        console.warn("Google 10k text fetch failed", e);
                        if (!loadErrorType) loadErrorType = "NETWORK";
                    }

                    dictsLoaded = true;
                    
                    const btnText = document.getElementById('cba-btnText');
                    const analyzeBtn = document.getElementById('cba-analyzeBtn');
                    const dictDot = document.getElementById('cba-dictDot');
                    const dictText = document.getElementById('cba-dictText');
                    
                    if (btnText && analyzeBtn) {
                        analyzeBtn.disabled = false;
                        if (dictDot) dictDot.classList.remove('animate-pulse');
                        
                        if (loadErrorType === "JSON") {
                            btnText.textContent = "Refresh Analysis";
                            if(dictDot) dictDot.classList.replace('bg-amber-500', 'bg-red-500');
                            if(dictText) dictText.textContent = "Dictionaries Offline";
                            showError(`Syntax error inside your GitHub file: ${errorDictName}. Check for missing quotes or an extra comma at the very end of a list!`);
                        } else if (loadErrorType === "NETWORK") {
                            btnText.textContent = "Refresh Analysis";
                            if(dictDot) dictDot.classList.replace('bg-amber-500', 'bg-red-500');
                            if(dictText) dictText.textContent = "Dictionaries Offline";
                            showError("Could not connect to GitHub. Make sure your repository is set to Public.");
                        } else {
                            btnText.textContent = "Refresh Analysis";
                            if(dictDot) dictDot.classList.replace('bg-amber-500', 'bg-green-500');
                            if(dictText) dictText.textContent = "Dictionaries Active";
                        }
                    }

                } catch (e) {
                    console.error("Dictionary Load Error", e);
                }
            }

            // UI Element References
            const inputEl = document.getElementById('cba-inputText');
            const analyzeBtn = document.getElementById('cba-analyzeBtn');
            const clearBtn = document.getElementById('cba-clearBtn');
            const copyBtn = document.getElementById('cba-copyBtn');
            const resultsContainer = document.getElementById('cba-resultsContainer');
            const highlightContainer = document.getElementById('cba-highlightContainer');
            const highlightedText = document.getElementById('cba-highlightedText');
            const errorMsgEl = document.getElementById('cba-errorMsg');
            const wpmCard = document.getElementById('cba-wpmCard');
            const timerDisplay = document.getElementById('cba-timerDisplay');
            
            // Text Tracking & WPM State
            let wpmData = [];
            let wpmIntervalObj = null;
            let currentWordCount = 0;
            let recordStartTime = 0;
            let wpmChartInstance = null;
            let reportMarkdownText = "";
            let uiTimerInterval = null;
            
            // Audio Native API State
            let recordedAudio = false;
            let activeSpeakingMs = 0;
            let totalRecordElapsedMs = 0;
            let speechBurstStart = 0;
            let lastResultTime = 0;
            let activeTimeInterval = null;

            const showError = (msg) => {
                if (errorMsgEl) {
                    errorMsgEl.textContent = msg;
                    errorMsgEl.classList.remove('hidden');
                    setTimeout(() => errorMsgEl.classList.add('hidden'), 8000);
                }
            };

            const toggleAccordion = (btnId, contentId, arrowId = null) => {
                const btn = document.getElementById(btnId);
                if (btn) {
                    btn.addEventListener('click', () => {
                        document.getElementById(contentId).classList.toggle('cba-accordion-open');
                        if (arrowId) document.getElementById(arrowId).classList.toggle('rotate-180');
                    });
                }
            };
            
            toggleAccordion('cba-readabilityToggleBtn', 'cba-readabilityAccordion');
            toggleAccordion('cba-wpmToggleBtn', 'cba-wpmAccordion', 'cba-wpmArrow');
            toggleAccordion('cba-snToggleBtn', 'cba-snAccordion'); 
            toggleAccordion('cba-simpleToggleBtn', 'cba-simpleAccordion'); 

            const formatSpeechChunk = (chunk) => {
                chunk = chunk.trim();
                if (chunk.length === 0) return "";
                chunk = chunk.charAt(0).toUpperCase() + chunk.slice(1);
                chunk = chunk.replace(/\b[i]\b/g, "I").replace(/\b[i]'m\b/g, "I'm").replace(/\b[i]'d\b/g, "I'd").replace(/\b[i]'ve\b/g, "I've").replace(/\b[i]'ll\b/g, "I'll");
                if (!/[.!?]$/.test(chunk)) chunk += ".";
                return chunk + " ";
            };

            const mergeAndPunctuateChunks = (chunks) => {
                if (chunks.length === 0) return "";
                let distinctSentences = [ chunks[0].trim() ];
                
                for (let i = 1; i < chunks.length; i++) {
                    let nextChunk = chunks[i].trim();
                    if (!nextChunk) continue;

                    let currentSentence = distinctSentences[distinctSentences.length - 1];
                    let resClean = currentSentence.toLowerCase().replace(/[^a-z0-9]/g, '');
                    let nextClean = nextChunk.toLowerCase().replace(/[^a-z0-9]/g, '');

                    if (resClean.endsWith(nextClean) || resClean === nextClean) continue;
                    if (nextClean.startsWith(resClean)) {
                        distinctSentences[distinctSentences.length - 1] = nextChunk;
                        continue;
                    }

                    let resWords = currentSentence.split(/\s+/);
                    let nextWords = nextChunk.split(/\s+/);
                    let overlapFound = false;

                    let minLen = Math.min(resWords.length, nextWords.length);
                    for (let w = minLen; w > 0; w--) {
                        let endOfRes = resWords.slice(-w).join('').toLowerCase().replace(/[^a-z0-9]/g, '');
                        let startOfNext = nextWords.slice(0, w).join('').toLowerCase().replace(/[^a-z0-9]/g, '');
                        if (endOfRes === startOfNext) {
                            distinctSentences[distinctSentences.length - 1] = resWords.slice(0, resWords.length - w).join(' ') + ' ' + nextChunk;
                            overlapFound = true;
                            break;
                        }
                    }

                    if (!overlapFound) {
                        distinctSentences.push(nextChunk);
                    }
                }
                return distinctSentences.map(s => formatSpeechChunk(s)).join('');
            };

            // --- SPEECH RECOGNITION ---
            let recognition = null;
            let isRecording = false;
            
            let savedTranscript = "";   
            let sessionTranscript = ""; 
            let tempTranscript = "";    
            
            let restartTimer = null; 
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

            if (SpeechRecognition) {
                const stopRecordingUI = () => {
                    isRecording = false;
                    clearInterval(wpmIntervalObj);
                    clearInterval(activeTimeInterval);
                    clearInterval(uiTimerInterval);
                    clearTimeout(restartTimer);
                    document.getElementById('cba-recordBtn').classList.remove('hidden');
                    document.getElementById('cba-transcribeBtn').classList.add('hidden');
                    document.getElementById('cba-recordingIndicator').classList.add('hidden');
                    if (timerDisplay) {
                        timerDisplay.classList.remove('text-rose-600');
                        timerDisplay.classList.add('text-slate-600');
                    }
                    inputEl.placeholder = "Start typing, paste text, or record your voice...\n\nTip: if you finish recording while a pop up is active, it may not transcribe.";
                };

                document.getElementById('cba-recordBtn').addEventListener('click', () => {
                    if (isRecording) return;
                    
                    isRecording = true;
                    recordedAudio = true; 
                    
                    savedTranscript = "";
                    sessionTranscript = "";
                    tempTranscript = ""; 
                    wpmData = [];
                    currentWordCount = 0;
                    
                    activeSpeakingMs = 0;
                    speechBurstStart = 0;
                    lastResultTime = 0;
                    
                    recordStartTime = Date.now();

                    if (timerDisplay) {
                        timerDisplay.textContent = "00:00";
                        timerDisplay.classList.remove('text-slate-600');
                        timerDisplay.classList.add('text-rose-600');
                        uiTimerInterval = setInterval(() => {
                            const elapsed = Math.floor((Date.now() - recordStartTime) / 1000);
                            const mins = String(Math.floor(elapsed / 60)).padStart(2, '0');
                            const secs = String(elapsed % 60).padStart(2, '0');
                            timerDisplay.textContent = `${mins}:${secs}`;
                        }, 1000);
                    }
                    
                    wpmIntervalObj = setInterval(() => {
                        let fullTextSoFar = tempTranscript;
                        let wordsNow = fullTextSoFar.trim().split(/\s+/).filter(w => w.length > 0).length;
                        let wordsIn20s = wordsNow - currentWordCount;
                        if (wordsIn20s < 0) wordsIn20s = 0;
                        wpmData.push(wordsIn20s * 3); 
                        currentWordCount = wordsNow;
                    }, 20000); 

                    activeTimeInterval = setInterval(() => {
                        if (speechBurstStart > 0 && (Date.now() - lastResultTime > 500)) {
                            let burstDuration = lastResultTime - speechBurstStart;
                            if (burstDuration < 300) burstDuration = 300; 
                            activeSpeakingMs += burstDuration;
                            speechBurstStart = 0; 
                        }
                    }, 100);

                    recognition = new SpeechRecognition();
                    recognition.continuous = true; 
                    recognition.interimResults = true; 

                    recognition.onresult = (event) => {
                        let now = Date.now();
                        if (speechBurstStart === 0) speechBurstStart = now;
                        lastResultTime = now;

                        let chunks = [];
                        for (let i = 0; i < event.results.length; ++i) {
                            chunks.push(event.results[i][0].transcript);
                        }
                        
                        sessionTranscript = mergeAndPunctuateChunks(chunks);
                        tempTranscript = savedTranscript + sessionTranscript;
                    };

                    recognition.onerror = (event) => {
                        if(event.error !== "no-speech") showError("Speech API Error: " + event.error);
                    };

                    recognition.onend = () => {
                        savedTranscript += sessionTranscript;
                        sessionTranscript = "";
                        
                        if (isRecording && recognition) {
                            const tryRestart = () => {
                                if (!isRecording || !recognition) return;
                                try { recognition.start(); } catch(e) { restartTimer = setTimeout(tryRestart, 500); }
                            };
                            restartTimer = setTimeout(tryRestart, 250);
                        }
                    };

                    try { 
                        recognition.start(); 
                        document.getElementById('cba-recordBtn').classList.add('hidden');
                        document.getElementById('cba-transcribeBtn').classList.remove('hidden');
                        document.getElementById('cba-recordingIndicator').classList.remove('hidden');
                        inputEl.placeholder = "Recording... Keep window active.";
                    } catch(e) { stopRecordingUI(); }
                });

                document.getElementById('cba-transcribeBtn').addEventListener('click', () => {
                    totalRecordElapsedMs = Date.now() - recordStartTime;
                    
                    if (speechBurstStart > 0) {
                        let burstDuration = lastResultTime - speechBurstStart;
                        if (burstDuration < 300) burstDuration = 300;
                        activeSpeakingMs += burstDuration;
                        speechBurstStart = 0;
                    }

                    let elapsedSecs = totalRecordElapsedMs / 1000;
                    let fullTextSoFar = tempTranscript;
                    let wordsNow = fullTextSoFar.trim().split(/\s+/).filter(w => w.length > 0).length;
                    let remainingWords = wordsNow - currentWordCount;
                    let remainingSecs = elapsedSecs % 20; 
                    
                    if (wpmData.length === 0) {
                        if (elapsedSecs > 0) wpmData.push(Math.round((wordsNow / elapsedSecs) * 60));
                    } else if (remainingSecs > 2 && remainingWords > 0) {
                        wpmData.push(Math.round((remainingWords / remainingSecs) * 60));
                    }

                    if (recognition) recognition.stop();
                    stopRecordingUI();
                    
                    setTimeout(() => {
                        let finalText = tempTranscript;
                        if (finalText.trim().length > 0) {
                            inputEl.value = inputEl.value ? inputEl.value + "\n\n" + finalText.trim() : finalText.trim();
                            analyze();
                        }
                        savedTranscript = ""; sessionTranscript = ""; tempTranscript = ""; recognition = null; 
                    }, 600);
                });
            } else {
                const ac = document.getElementById('cba-audioControls');
                if (ac) ac.style.display = 'none';
            }

            function countSyllables(word) {
                word = word.toLowerCase().replace(/[^a-z]/g, '');
                if (word.length <= 3) return 1;
                word = word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
                word = word.replace(/^y/, '');
                const syllables = word.match(/[aeiouy]{1,2}/g);
                return syllables ? syllables.length : 1;
            }

            // Metrics Evaluators for the Dashboard
            const evalColor = (status) => {
                if(status === 'just right') return 'bg-green-100 text-green-700';
                if(status.includes('too') || status.includes('slow') || status.includes('strain')) return 'bg-red-100 text-red-700';
                return 'bg-amber-100 text-amber-700';
            };
            const setEval = (id, text, colorClass) => {
                const el = document.getElementById(id);
                if(el) { el.textContent = text; el.className = `text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wide ${colorClass}`; }
            };

            function analyze() {
                if (!dictsLoaded) return;
                const text = inputEl.value.trim();
                
                // Show the container immediately for the Summary Dashboard, even if empty
                resultsContainer.classList.remove('hidden');
                
                if (!text) {
                    highlightContainer.classList.add('hidden');
                    copyBtn.classList.add('hidden');
                    return;
                }

                try {
                    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
                    const words = text.split(/\s+/).filter(w => w.trim().length > 0);
                    const letterCount = text.replace(/[^a-zA-Z]/g, '').length;
                    
                    let totalSyllables = 0;
                    let complexWordCount = 0;
                    let personalCount = 0;
                    let visualCount = 0;
                    
                    let simpleCounts = { '5yr Old 1000': 0, 'ESL 2000': 0, 'Kitchen 1000': 0, 'outside': 0 };
                    let google10kCount = 0;

                    let highlightedHTML = "";
                    reportMarkdownText = ""; 
                    let inQuotes = false;
                    
                    let useFallback = true;
                    if (typeof window.nlp === 'function') {
                        try {
                            let doc = window.nlp(text);
                            try { doc.compute('root'); } catch(e) {} 
                            
                            const jsonDoc = doc.json({ terms: true }); 
                            
                            for (let sIdx = 0; sIdx < jsonDoc.length; sIdx++) {
                                const sentence = jsonDoc[sIdx];
                                if (!sentence.terms) continue; 

                                let personalCountdown = 0; 
                                let visualCountdown = 0; 

                                for (let tIdx = 0; tIdx < sentence.terms.length; tIdx++) {
                                    const term = sentence.terms[tIdx];
                                    let rawText = term.text || "";
                                    let rawPre = term.pre || "";
                                    let rawPost = term.post || "";
                                    let rawRoot = term.root || term.normal || rawText;

                                    let root = String(rawRoot).toLowerCase().replace(/[^a-z]/g, '');
                                    let normal = String(term.normal || rawText).toLowerCase().replace(/[^a-z']/g, ''); 
                                    
                                    if (rawPre.includes('"') || rawPre.includes('“') || rawText.includes('“') || rawText.startsWith('"')) inQuotes = true;

                                    if (personalPronouns.has(normal)) personalCountdown = 6;
                                    
                                    if (!personalPronouns.has(normal)) {
                                        if (visualDictPronouns.has(normal) || visualDictWords.has(normal) || visualDictWords.has(root)) {
                                            visualCountdown = Math.max(visualCountdown, 4);
                                        }
                                    }

                                    let isPersonal = false;
                                    let isVisual = false;

                                    if (inQuotes || personalCountdown > 0) isPersonal = true;
                                    if (visualCountdown > 0) isVisual = true; 

                                    if (personalCountdown > 0) personalCountdown--;
                                    if (visualCountdown > 0) visualCountdown--;

                                    if (/[.!?]/.test(rawText) || /[.!?]/.test(rawPost)) {
                                        visualCountdown = 0;
                                        personalCountdown = 0;
                                    }

                                    if (rawPost.includes('"') || rawPost.includes('”') || rawText.includes('”') || rawText.endsWith('"')) inQuotes = false;

                                    let safePre = rawPre.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                                    let safePost = rawPost.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                                    let safeText = rawText.replace(/</g, "&lt;").replace(/>/g, "&gt;");

                                    if (/[a-zA-Z]/.test(rawText)) {
                                        if (isPersonal && isVisual) {
                                            highlightedHTML += `${safePre}<span class="overlap-word">${safeText}</span>${safePost}`;
                                            reportMarkdownText += `${rawPre}_**${rawText}**_${rawPost}`;
                                            personalCount++; visualCount++;
                                        } else if (isPersonal) {
                                            highlightedHTML += `${safePre}<span class="personal-word">${safeText}</span>${safePost}`;
                                            reportMarkdownText += `${rawPre}**${rawText}**${rawPost}`;
                                            personalCount++;
                                        } else if (isVisual) {
                                            highlightedHTML += `${safePre}<span class="visual-word">${safeText}</span>${safePost}`;
                                            reportMarkdownText += `${rawPre}_${rawText}_${rawPost}`;
                                            visualCount++;
                                        } else {
                                            highlightedHTML += `${safePre}${safeText}${safePost}`;
                                            reportMarkdownText += `${rawPre}${rawText}${rawPost}`;
                                        }
                                    } else {
                                        highlightedHTML += `${safePre}${safeText}${safePost}`;
                                        reportMarkdownText += `${rawPre}${rawText}${rawPost}`;
                                    }
                                }
                            }
                            useFallback = false;
                        } catch(e) {
                            console.error("NLP failed, switching to manual fallback.", e);
                            useFallback = true;
                        }
                    }

                    if (useFallback) {
                        let tokens = text.split(/([a-zA-Z']+)/);
                        let personalCountdown = 0;
                        let visualCountdown = 0;

                        tokens.forEach(token => {
                            if (/[.!?]/.test(token)) {
                                visualCountdown = 0;
                                personalCountdown = 0;
                                inQuotes = false;
                            }

                            if (/[a-zA-Z]/.test(token)) {
                                let normal = token.toLowerCase().replace(/[^a-z']/g, '');
                                let root = normal.replace(/(?:s|es|ed|ing)$/, ''); 

                                if (personalPronouns.has(normal)) personalCountdown = 6;
                                
                                if (!personalPronouns.has(normal)) {
                                    if (visualDictPronouns.has(normal) || visualDictWords.has(normal) || visualDictWords.has(root)) {
                                        visualCountdown = Math.max(visualCountdown, 4);
                                    }
                                }

                                let isPersonal = false;
                                let isVisual = false;

                                if (inQuotes || personalCountdown > 0) isPersonal = true;
                                if (visualCountdown > 0) isVisual = true;

                                if (personalCountdown > 0) personalCountdown--;
                                if (visualCountdown > 0) visualCountdown--;

                                let safeText = token.replace(/</g, "&lt;").replace(/>/g, "&gt;");

                                if (isPersonal && isVisual) {
                                    highlightedHTML += `<span class="overlap-word">${safeText}</span>`;
                                    reportMarkdownText += `_**${token}**_`;
                                    personalCount++; visualCount++;
                                } else if (isPersonal) {
                                    highlightedHTML += `<span class="personal-word">${safeText}</span>`;
                                    reportMarkdownText += `**${token}**`;
                                    personalCount++;
                                } else if (isVisual) {
                                    highlightedHTML += `<span class="visual-word">${safeText}</span>`;
                                    reportMarkdownText += `_${token}_`;
                                    visualCount++;
                                } else {
                                    highlightedHTML += safeText;
                                    reportMarkdownText += token;
                                }
                            } else {
                                let quoteMatches = (token.match(/["“”]/g) || []).length;
                                if (quoteMatches % 2 !== 0) inQuotes = !inQuotes;
                                highlightedHTML += token.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                                reportMarkdownText += token;
                            }
                        });
                    }

                    words.forEach(word => {
                        let cleanWord = word.toLowerCase().replace(/[^a-z']/g, '');
                        
                        let syl = countSyllables(cleanWord);
                        totalSyllables += syl;
                        if (syl >= 3) complexWordCount++;
                        
                        if (cleanWord.length > 0) {
                            if (google10kSet.has(cleanWord)) {
                                google10kCount++;
                            }

                            let sTier = simpleMap.get(cleanWord);
                            
                            if (!sTier && typeof window.nlp === 'function') {
                                try {
                                    let doc = window.nlp(cleanWord).compute('root').json();
                                    if (doc.length > 0 && doc[0].terms.length > 0) {
                                        let rootWord = doc[0].terms[0].root || doc[0].terms[0].normal;
                                        if (rootWord) {
                                            sTier = simpleMap.get(rootWord);
                                        }
                                    }
                                } catch(e) {}
                            }
                            
                            simpleCounts[sTier || 'outside']++;
                        }
                    });

                    const numSentences = Math.max(1, sentences.length);
                    const numWords = Math.max(1, words.length);

                    try {
                        highlightContainer.classList.remove('hidden'); 
                        copyBtn.classList.remove('hidden'); 
                        highlightedText.innerHTML = highlightedHTML.replace(/\n/g, '<br>');
                    } catch(e) {}

                    // ==========================================
                    // INDIVIDUAL CARD SCORES
                    // ==========================================
                    let gPct = 0;
                    try {
                        const gCard = document.getElementById('cba-googleCard');
                        if (google10kSet.size > 0 && numWords > 0) {
                            gCard.classList.remove('hidden');
                            gPct = Math.round((google10kCount / numWords) * 100);
                            
                            document.getElementById('cba-googleScore').textContent = `${gPct}%`;
                            document.getElementById('cba-googleProgress').style.width = `${Math.min(100, Math.max(0, gPct))}%`;
                            document.getElementById('cba-googleCount').textContent = `${google10kCount} out of ${numWords} words`;
                            
                            let gColor = gPct > 80 ? "#10b981" : gPct > 60 ? "#f59e0b" : "#ef4444";
                            document.getElementById('cba-googleInterpret').textContent = gPct > 80 ? "Highly Common" : gPct > 60 ? "Moderately Common" : "Highly Unique/Niche";
                            
                            gCard.style.borderLeftColor = gColor;
                            document.getElementById('cba-googleProgress').style.backgroundColor = gColor;
                            document.getElementById('cba-googleScore').style.color = gColor;
                        } else if (gCard) {
                            gCard.classList.add('hidden');
                        }
                    } catch(e) { console.error("Google Stats Error:", e); }

                    let coreSimpleScore = 0;
                    try {
                        let s5yrPct = Math.round((simpleCounts['5yr Old 1000'] / numWords) * 100) || 0;
                        let sEslPct = Math.round((simpleCounts['ESL 2000'] / numWords) * 100) || 0;
                        let sKitPct = Math.round((simpleCounts['Kitchen 1000'] / numWords) * 100) || 0;
                        let sOutPct = Math.round((simpleCounts['outside'] / numWords) * 100) || 0;
                        
                        coreSimpleScore = s5yrPct + sEslPct + sKitPct; 
                        document.getElementById('cba-simpleScore').textContent = `${coreSimpleScore}%`;
                        
                        document.getElementById('cba-simpleBar5yr').style.width = `${s5yrPct}%`;
                        document.getElementById('cba-simpleBarEsl').style.width = `${sEslPct}%`;
                        document.getElementById('cba-simpleBarKit').style.width = `${sKitPct}%`;
                        
                        document.getElementById('cba-s5yr').textContent = `${s5yrPct}%`;
                        document.getElementById('cba-sEsl').textContent = `${sEslPct}%`;
                        document.getElementById('cba-sKit').textContent = `${sKitPct}%`;
                        document.getElementById('cba-sOut').textContent = `${sOutPct}%`;
                        
                        let sText = coreSimpleScore > 85 ? "Extremely Accessible" : coreSimpleScore > 70 ? "Good Accessibility" : "Highly advanced vocabulary";
                        document.getElementById('cba-simpleInterpret').textContent = sText;
                    } catch(e) { console.error("Simple Vocab Error:", e); }

                    let mumbleScore = 0;
                    let activeSpeakingSecs = 0;
                    let totalSecs = 0;
                    let pausePercent = 0;
                    try {
                        const mmCard = document.getElementById('cba-mumbleCard');
                        if (recordedAudio && activeSpeakingMs > 0 && totalSyllables > 0) {
                            mmCard.classList.remove('hidden');
                            mmCard.classList.remove('opacity-50');
                            
                            activeSpeakingSecs = Math.max(1, activeSpeakingMs / 1000);
                            mumbleScore = totalSyllables / activeSpeakingSecs;
                            
                            totalSecs = totalRecordElapsedMs / 1000;
                            let pauseTime = totalSecs - activeSpeakingSecs;
                            pausePercent = (pauseTime / totalSecs) * 100;
                            
                            let mColor, mText;
                            if (mumbleScore < 2.5) { mColor = "#3b82f6"; mText = "No.... Mum...bling..."; } 
                            else if (mumbleScore < 4.0) { mColor = "#10b981"; mText = "Very clear, no mumble"; } 
                            else if (mumbleScore <= 5.5) { mColor = "#f97316"; mText = "Slight mumble"; } 
                            else { mColor = "#ef4444"; mText = "High Mumbling Risk"; } 

                            document.getElementById('cba-mumbleScore').textContent = mumbleScore.toFixed(1);
                            document.getElementById('cba-mumbleInterpret').textContent = mText;
                            document.getElementById('cba-mumbleInterpret').style.color = mColor;
                            document.getElementById('cba-mumbleScore').style.color = mColor;
                            mmCard.style.borderLeftColor = mColor;

                            let mPct = Math.min(100, Math.max(0, (mumbleScore / 8) * 100));
                            document.getElementById('cba-mumbleMarker').style.left = mPct + "%";

                            document.getElementById('cba-mumbleStats').textContent = `${activeSpeakingSecs.toFixed(1)}s active / ${pauseTime.toFixed(1)}s pause / ${totalSecs.toFixed(1)}s total`;
                        } else if (mmCard && !recordedAudio) {
                            mmCard.classList.remove('hidden');
                            mmCard.classList.add('opacity-50');
                            document.getElementById('cba-mumbleInterpret').textContent = "Waiting for Audio...";
                        }
                    } catch(e) { console.error("Mumble Meter Error:", e); }

                    let avgWpm = 0;
                    try {
                        const wCard = document.getElementById('cba-wpmCard');
                        if (wpmData.length > 0 && typeof window.Chart !== 'undefined') {
                            wCard.classList.remove('hidden');
                            wCard.classList.remove('opacity-50');
                            avgWpm = Math.round(wpmData.reduce((a, b) => a + b, 0) / wpmData.length);
                            document.getElementById('cba-wpmScore').textContent = avgWpm;
                            document.getElementById('cba-wpmScore').classList.replace('text-slate-400', 'text-amber-500');
                            
                            if (wpmChartInstance) wpmChartInstance.destroy();
                            wpmChartInstance = new window.Chart(document.getElementById('cba-wpmChart'), {
                                type: 'bar',
                                data: {
                                    labels: wpmData.map((_, i) => `${(i+1)*20}s`),
                                    datasets: [{
                                        label: 'WPM',
                                        data: wpmData,
                                        backgroundColor: 'rgba(245, 158, 11, 0.5)',
                                        borderColor: 'rgba(245, 158, 11, 1)',
                                        borderWidth: 1,
                                        borderRadius: 4
                                    }]
                                },
                                options: { responsive: true, scales: { y: { beginAtZero: true, suggestedMax: 180 } }, plugins: { legend: { display: false } } }
                            });
                        } else if (wCard && !recordedAudio) {
                            wCard.classList.remove('hidden');
                            wCard.classList.add('opacity-50');
                            document.getElementById('cba-wpmScore').classList.replace('text-amber-500', 'text-slate-400');
                        }
                    } catch(e) { console.error("Chart Error:", e); }

                    let avgGrade = 0;
                    try {
                        const fleschGrade = (0.39 * (numWords / numSentences)) + (11.8 * (totalSyllables / numWords)) - 15.59;
                        const gunningFog = 0.4 * ((numWords / numSentences) + 100 * (complexWordCount / numWords));
                        const smog = 1.0430 * Math.sqrt(complexWordCount * (30 / numSentences)) + 3.1291;
                        const colemanLiau = 0.0588 * ((letterCount / numWords) * 100) - 0.296 * ((numSentences / numWords) * 100) - 15.8;

                        const cFlesch = Math.max(0, fleschGrade);
                        const cFog = Math.max(0, gunningFog);
                        const cSmog = Math.max(0, smog);
                        const cColeman = Math.max(0, colemanLiau);
                        
                        avgGrade = (cFlesch + cFog + cSmog + cColeman) / 4;

                        document.getElementById('cba-gradeLevel').textContent = avgGrade.toFixed(1);
                        document.getElementById('cba-fleschScore').textContent = cFlesch.toFixed(1);
                        document.getElementById('cba-fogScore').textContent = cFog.toFixed(1);
                        document.getElementById('cba-smogScore').textContent = cSmog.toFixed(1);
                        document.getElementById('cba-colemanScore').textContent = cColeman.toFixed(1);
                        document.getElementById('cba-avgScore').textContent = avgGrade.toFixed(1);

                        let gradeColor = avgGrade <= 4.4 ? "#f97316" : avgGrade <= 8.4 ? "#10b981" : avgGrade <= 9.5 ? "#00B700" : avgGrade <= 12.5 ? "#f59e0b" : "#ef4444";
                        document.getElementById('cba-gradeInterpret').textContent = avgGrade <= 4.4 ? "Pitched to 5-10 yr old" : avgGrade <= 8.4 ? "Short & Simple" : avgGrade <= 9.5 ? "Perfect Plain English" : avgGrade <= 12.5 ? "Audience Strain" : "Too Complex";
                        document.getElementById('cba-gradeInterpret').style.color = gradeColor;
                        document.getElementById('cba-simpleComplexCard').style.borderLeftColor = gradeColor;
                        document.getElementById('cba-gradeProgress').style.backgroundColor = gradeColor;
                        document.getElementById('cba-gradeProgress').style.width = `${Math.min(100, Math.max(0, (avgGrade / 18) * 100))}%`;
                        document.getElementById('cba-gradeLevel').classList.replace('text-slate-800', 'text-slate-400');
                    } catch(e) { console.error("Grade Error:", e); }

                    let personalPercent = 0;
                    try {
                        personalPercent = Math.round((personalCount / numWords) * 100);
                        document.getElementById('cba-personalScore').textContent = `${personalPercent}%`;
                        document.getElementById('cba-personalCount').textContent = `${personalCount} out of ${numWords} words`;
                        
                        let pColor = personalPercent <= 29 ? "#94a3b8" : personalPercent <= 44 ? "#10b981" : personalPercent <= 60 ? "#00B700" : "#a855f7";
                        document.getElementById('cba-personalInterpret').textContent = personalPercent <= 29 ? "Highly Detached" : personalPercent <= 44 ? "Good Balance" : personalPercent <= 60 ? "Highly Personal" : "Overly Conversational?";
                        document.getElementById('cba-personalCard').style.borderLeftColor = pColor;
                        document.getElementById('cba-personalProgress').style.backgroundColor = pColor;
                        document.getElementById('cba-personalScore').style.color = pColor;
                        document.getElementById('cba-personalProgress').style.width = `${Math.min(100, Math.max(0, personalPercent))}%`;
                    } catch(e) { console.error("Personal Error:", e); }

                    let visualPercent = 0;
                    try {
                        visualPercent = Math.round((visualCount / numWords) * 100);
                        document.getElementById('cba-visualScore').textContent = `${visualPercent}%`;
                        document.getElementById('cba-visualCount').textContent = `${visualCount} out of ${numWords} words`;
                        
                        let vColor = visualPercent <= 29 ? "#94a3b8" : visualPercent <= 44 ? "#10b981" : visualPercent <= 60 ? "#00B700" : "#a855f7";
                        document.getElementById('cba-visualInterpret').textContent = visualPercent <= 29 ? "Very Intangible" : visualPercent <= 44 ? "Good" : visualPercent <= 60 ? "Very Vivid" : "Reaching poetic levels";
                        document.getElementById('cba-visualCard').style.borderLeftColor = vColor;
                        document.getElementById('cba-visualProgress').style.backgroundColor = vColor;
                        document.getElementById('cba-visualScore').style.color = vColor;
                        document.getElementById('cba-visualProgress').style.width = `${Math.min(100, Math.max(0, visualPercent))}%`;
                    } catch(e) { console.error("Visual Error:", e); }

                    let avgWpsFloat = 0;
                    try {
                        document.getElementById('cba-statWords').textContent = words.length;
                        document.getElementById('cba-statSentences').textContent = sentences.length;
                        document.getElementById('cba-statSyllables').textContent = totalSyllables;

                        avgWpsFloat = numSentences > 0 ? (numWords / numSentences) : 0;
                        const avgWps = Math.round(avgWpsFloat);
                        document.getElementById('cba-snScore').textContent = avgWpsFloat.toFixed(1);

                        let snFeedback = ""; let snColor = "";
                        if (avgWps <= 9) { snFeedback = "Very high signal, low noise"; snColor = "#00B700"; } 
                        else if (avgWps <= 16) { snFeedback = "High signal; moderate noise"; snColor = "#6366f1"; } 
                        else if (avgWps <= 25) { snFeedback = "Moderate signal; high noise"; snColor = "#f59e0b"; } 
                        else { snFeedback = "Low signal; very high noise"; snColor = "#ef4444"; }

                        document.getElementById('cba-snInterpret').textContent = snFeedback;
                        document.getElementById('cba-snInterpret').style.color = snColor;
                        document.getElementById('cba-snCard').style.borderLeftColor = snColor;
                        document.getElementById('cba-snScore').style.color = snColor;
                        document.getElementById('cba-snProgress').style.backgroundColor = snColor;
                        document.getElementById('cba-snProgress').style.width = `${Math.min(100, Math.max(0, (avgWps / 40) * 100))}%`;

                        const snGrid = document.getElementById('cba-snGrid');
                        const spiralSeq = [12, 13, 18, 17, 16, 11, 6, 7, 8, 9, 14, 19, 24, 23, 22, 21, 20, 15, 10, 5, 0, 1, 2, 3, 4];
                        let maxFill = Math.min(25, avgWps);
                        
                        let clampedWpsForColor = Math.min(25, Math.max(1, avgWps));
                        let redVal = Math.round(255 - ((clampedWpsForColor - 1) * (255 / 24)));
                        let redHex = redVal.toString(16).padStart(2, '0').toUpperCase();
                        let centerColor = `#${redHex}0000`;
                        
                        let cellsHTML = new Array(25).fill('');
                        for (let i = 0; i < 25; i++) {
                            let cellIndex = spiralSeq[i];
                            if (i === 0) {
                                cellsHTML[cellIndex] = `<div class="w-3.5 h-3.5 sm:w-4 sm:h-4 rounded-sm transition-all duration-500 shadow-sm" style="background-color: ${centerColor}; border: 1px solid #450a0a;"></div>`;
                            } else if (i < maxFill) {
                                cellsHTML[cellIndex] = `<div class="w-3.5 h-3.5 sm:w-4 sm:h-4 rounded-sm transition-colors duration-500 bg-slate-800 border border-slate-900 shadow-sm"></div>`;
                            } else {
                                cellsHTML[cellIndex] = `<div class="w-3.5 h-3.5 sm:w-4 sm:h-4 rounded-sm transition-colors duration-500 bg-slate-100 border border-slate-200"></div>`;
                            }
                        }
                        snGrid.innerHTML = cellsHTML.join('');
                        const legendRed = document.getElementById('cba-legendRed');
                        if (legendRed) legendRed.style.backgroundColor = centerColor;

                    } catch(e) { console.error("Stats Error:", e); }

                    // ==========================================
                    // SCORE SUMMARY DASHBOARD LOGIC
                    // ==========================================
                    try {
                        const setEval = (id, text, colorClass) => {
                            const el = document.getElementById(id);
                            if(el) { el.textContent = text; el.className = `text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wide ${colorClass}`; }
                        };

                        // 1. Content
                        document.getElementById('sum-personal').textContent = `${personalPercent}%`;
                        let pStatus = personalPercent < 30 ? 'not enough' : personalPercent > 60 ? 'too much' : 'just right';
                        setEval('sum-personal-eval', pStatus, evalColor(pStatus));

                        document.getElementById('sum-visual').textContent = `${visualPercent}%`;
                        let vStatus = visualPercent < 20 ? 'not enough' : visualPercent > 50 ? 'too much' : 'just right';
                        setEval('sum-visual-eval', vStatus, evalColor(vStatus));

                        let intangiblePercent = Math.max(0, 100 - personalPercent - visualPercent);
                        document.getElementById('sum-intangible').textContent = `${intangiblePercent}%`;
                        let iStatus = intangiblePercent < 10 ? 'not enough' : intangiblePercent > 30 ? 'too much' : 'just right';
                        setEval('sum-intangible-eval', iStatus, evalColor(iStatus));

                        // 2. Delivery
                        if (recordedAudio && totalSecs > 0) {
                            document.getElementById('sum-wpm').textContent = avgWpm;
                            let wpmStatus = avgWpm < 100 ? 'speed up' : avgWpm > 150 ? 'strain' : 'just right';
                            setEval('sum-wpm-eval', wpmStatus, evalColor(wpmStatus));

                            document.getElementById('sum-sps').textContent = mumbleScore.toFixed(1);
                            let spsStatus = mumbleScore < 3 ? 'speed up' : mumbleScore > 5 ? 'strain' : 'just right';
                            setEval('sum-sps-eval', spsStatus, evalColor(spsStatus));

                            document.getElementById('sum-pause').textContent = `${pausePercent.toFixed(0)}%`;
                            let pzStatus = pausePercent < 10 ? 'too little' : pausePercent > 30 ? 'too much' : 'just right';
                            setEval('sum-pause-eval', pzStatus, evalColor(pzStatus));
                        } else {
                            document.getElementById('sum-wpm').textContent = "-";
                            document.getElementById('sum-sps').textContent = "-";
                            document.getElementById('sum-pause').textContent = "-";
                            setEval('sum-wpm-eval', 'Text Only', 'bg-slate-100 text-slate-500');
                            setEval('sum-sps-eval', 'Text Only', 'bg-slate-100 text-slate-500');
                            setEval('sum-pause-eval', 'Text Only', 'bg-slate-100 text-slate-500');
                        }

                        // 3. Simplicity
                        document.getElementById('sum-wps').textContent = avgWpsFloat.toFixed(1);
                        let wpsStatus = avgWpsFloat < 5 ? 'too simple' : avgWpsFloat > 15 ? 'too complex' : 'just right';
                        setEval('sum-wps-eval', wpsStatus, evalColor(wpsStatus));

                        document.getElementById('sum-grade').textContent = avgGrade.toFixed(1);
                        let gradeStatus = avgGrade < 5 ? 'too simple' : avgGrade > 10 ? 'too complex' : 'just right';
                        setEval('sum-grade-eval', gradeStatus, evalColor(gradeStatus));

                        document.getElementById('sum-simple').textContent = `${coreSimpleScore}%`;
                        let simpleStatus = coreSimpleScore < 85 ? 'too complex' : coreSimpleScore > 95 ? 'too simple' : 'just right';
                        setEval('sum-simple-eval', simpleStatus, evalColor(simpleStatus));

                    } catch(e) { console.error("Summary Dashboard Error:", e); }

                } catch (error) { 
                    console.error("Main Analysis Pipeline failed:", error); 
                    showError("Analysis stopped due to a browser error: " + error.message);
                }
            }

            // Copy Report Feature
            copyBtn.addEventListener('click', () => {
                let audioReportText = "";
                const wpmCardEl = document.getElementById('cba-wpmCard');
                if (recordedAudio) {
                    audioReportText = `\n[Speaking Pace] ${document.getElementById('cba-wpmScore').textContent} WPM\n[Mumble Meter] ${document.getElementById('cba-mumbleScore').textContent} syllables/sec\n[Pause Ratio] ${document.getElementById('sum-pause').textContent}`;
                }

                let cleanMarkdown = reportMarkdownText.trim().replace(/\n/g, '\n\n').replace(/ +/g, ' ');

                const report = `CONTENT BALANCE ANALYZER - REPORT
=========================================

--- EXECUTIVE SUMMARY ---
[Content] Personal: ${document.getElementById('sum-personal').textContent} | Visual: ${document.getElementById('sum-visual').textContent} | Intangible: ${document.getElementById('sum-intangible').textContent}
[Delivery] WPM: ${document.getElementById('sum-wpm').textContent} | Syllables/sec: ${document.getElementById('sum-sps').textContent} | Pause Time: ${document.getElementById('sum-pause').textContent}
[Simplicity] Words/Sent: ${document.getElementById('sum-wps').textContent} | Grade: ${document.getElementById('sum-grade').textContent} | Simple %: ${document.getElementById('sum-simple').textContent}

--- DETAILED SCORES ---
Personal Balance: ${document.getElementById('cba-personalScore').textContent}
Visual Balance: ${document.getElementById('cba-visualScore').textContent}
Signal-Noise Ratio: ${document.getElementById('cba-snScore').textContent}
Sentence Complexity (Avg Grade): ${document.getElementById('cba-gradeLevel').textContent}
Simple Language: ${document.getElementById('cba-simpleScore').textContent}
Google 10K Benchmark: ${document.getElementById('cba-googleScore').textContent}${audioReportText}

--- TRANSCRIPT (Marked Up) ---
* Personal text is **bolded**
* Visual text is _underlined_
* Overlapping text is _**both**_

${cleanMarkdown}
`;
                const el = document.createElement('textarea');
                el.value = report;
                document.body.appendChild(el);
                el.select();
                document.execCommand('copy');
                document.body.removeChild(el);

                const btnText = document.getElementById('cba-copyBtnText');
                const originalText = btnText.textContent;
                btnText.textContent = "Copied to Clipboard!";
                copyBtn.classList.replace('bg-white', 'bg-green-600');
                copyBtn.classList.replace('text-slate-700', 'text-white');
                
                setTimeout(() => { 
                    btnText.textContent = originalText; 
                    copyBtn.classList.replace('bg-green-600', 'bg-white');
                    copyBtn.classList.replace('text-white', 'text-slate-700');
                }, 2500);
            });

            // Init trigger
            loadDictionaries();
            analyzeBtn.addEventListener('click', analyze);
            clearBtn.addEventListener('click', () => { 
                inputEl.value = ''; 
                highlightContainer.classList.add('hidden'); 
                copyBtn.classList.add('hidden'); 
                wpmData = []; 
                recordedAudio = false; 

                if (timerDisplay) {
                    timerDisplay.textContent = "00:00";
                    timerDisplay.classList.remove('text-rose-600');
                    timerDisplay.classList.add('text-slate-600');
                }
                
                // Clear Dashboard UI immediately
                const summaryIds = ['sum-personal', 'sum-visual', 'sum-intangible', 'sum-wpm', 'sum-sps', 'sum-pause', 'sum-wps', 'sum-grade', 'sum-simple'];
                summaryIds.forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.textContent = "0";
                    const evalEl = document.getElementById(id + '-eval');
                    if (evalEl) {
                        evalEl.textContent = "Waiting";
                        evalEl.className = "text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wide bg-slate-100 text-slate-500";
                    }
                });
                
                analyze(); 
            });
            inputEl.addEventListener('input', () => { 
                recordedAudio = false; 
                if (inputEl.value.length === 0) {
                    analyze();
                    copyBtn.classList.add('hidden'); 
                }
            });

        })(); 
    </script>
</body>
</html>
