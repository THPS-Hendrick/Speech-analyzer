<body class="w-full mx-auto min-h-screen p-4 md:p-8 flex flex-col items-center justify-start overflow-x-hidden relative bg-slate-50">

    <!-- HIDDEN PROXY TEXTAREA: Keeps audio-processor.js connected even if the Text Input Widget is not spawned! -->
    <textarea id="cba-inputText" class="hidden"></textarea>

    <!-- THE NEW WIDGET MANAGER MENU -->
