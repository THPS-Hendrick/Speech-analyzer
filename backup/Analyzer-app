            <div class="flex flex-col items-center">
                <span id="celeb-label-grade" class="font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-slate-400">Final Grade</span>
                <span id="celeb-grade" class="text-5xl md:text-7xl font-black drop-shadow-sm text-slate-300">- / 10</span>
            </div>
            <div id="celeb-divider" class="w-px h-20 bg-slate-300 opacity-50"></div>
            <div class="flex flex-col items-center">
                <span id="celeb-label-time" class="font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-slate-400">Time</span>
                <span id="celeb-time" class="text-5xl md:text-7xl font-black drop-shadow-sm text-slate-300">-</span>
            </div>
        </div>
    </div>

    <div id="cba-wrapper" class="w-full max-w-6xl mx-auto mb-16">
        <div class="flex flex-col space-y-6 sm:space-y-8">
            <div id="cba-resultsContainer" class="flex flex-col space-y-6 sm:space-y-8 mt-4">

                <!-- PROCESSING PANEL -->
                <div id="cba-processing-panel" class="hidden score-card glass-panel p-8 rounded-2xl border-t-4 border-blue-500 shadow-md bg-gradient-to-b from-blue-50 to-white flex flex-col items-center justify-center transition-all duration-300">
                    <div class="relative flex items-center justify-center mb-4 w-16 h-16 bg-blue-100 rounded-full shadow-inner">
                        <i data-lucide="refresh-cw" class="w-8 h-8 text-blue-600 animate-spin"></i>
                        <i data-lucide="mic" class="w-4 h-4 text-blue-800 absolute"></i>
                    </div>
                    <h2 class="text-xl md:text-2xl font-black uppercase tracking-widest text-slate-800 drop-shadow-sm text-center">Analyzing Audio...</h2>
                    <p class="text-sm text-slate-500 font-medium mt-2 text-center animate-pulse">Running advanced parallel transcription and analysis. Please hold tight!</p>
                </div>
                
                <!-- TRACKMAN DASHBOARD AREA -->
                <div class="w-full">
                    <!-- Dashboard Header & Add Widget Button -->
                    <div class="flex justify-between items-end mb-4 border-b border-slate-200 pb-3">
                        <div>
                            <h2 class="text-xl sm:text-2xl font-black text-slate-800 tracking-tight">Your Dashboard</h2>
                            <p class="text-xs text-slate-500 mt-1">Configure your metrics to match your speaking goals.</p>
                        </div>
                        <button onclick="window.toggleWidgetMenu()" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl font-bold text-sm transition-all shadow-md hover:shadow-lg active:scale-95 group">
                            <i data-lucide="layout-grid" class="w-4 h-4 group-hover:rotate-12 transition-transform"></i>
                            <span class="hidden sm:inline">Add Widget</span>
                        </button>
                    </div>

                    <!-- THE DROP ZONE (Grid Container) -->
                    <div id="thps-dashboard-grid" class="flex flex-wrap gap-4 sm:gap-6 w-full items-start min-h-[150px] p-2 rounded-xl">
                        
                        <!-- DEFAULT WIDGETS -->
                        <div class="w-full mt-2 cursor-move relative group">
                            <thps-whats-this></thps-whats-this>
                        </div>

                        <div class="w-full mt-2 cursor-move relative group">
                            <thps-live-mic-timer></thps-live-mic-timer>
                        </div>

                        <div class="w-full mt-2 cursor-move relative group">
                            <thps-score-summary></thps-score-summary>
                        </div>

                        <div class="w-full mt-2 cursor-move relative group">
                            <thps-voice-graph></thps-voice-graph>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- JAVASCRIPT LOGIC                           -->
    <!-- ========================================== -->
    <script>
        lucide.createIcons();
        
        let gameTimerInterval = null;
        let isActive = false;
        let reportMarkdownText = "";

        const EXPLANATIONS_URL = "https://raw.githubusercontent.com/THPS-Hendrick/Speech-analyzer/main/explanations.json"; 
        let explanationsData = null;
        const FALLBACK_EXPLANATIONS = {
            "Score Summary": "This panel breaks down your speech into 9 core metrics across Content, Delivery, and Simplicity. Every metric in the green ('just right') awards you 1 point toward your final Grade.",
            "Time": "Your total speaking time. Speaking for 60-90 seconds is 1p, 30-60 is 0.75p, and going under 30s or over 90s cancels your Grade entirely.",
            "Grade": "Your final score out of 10. Metrics in the green give 1 point, yellow gives 0.75, and red gives 0.25 points.",
            "Content": "Measures the substance of your speech. Aim for 30%+ Personal examples and 30%+ Visual descriptions.",
            "Delivery": "Measures how you sound. Aim for 100-150 Words Per Minute, 3 to 5 Syllables/sec (to avoid mumbling), and pause for at least 400 milliseconds often.",
            "Simplicity": "Measures how easy your speech is to understand. Keep your average sentence between 5 to 15 words.",
            "Personal": "Measures storytelling and personal examples. Best speakers talk about a specific person doing specific things about 30-60% of the time.",
            "Visual": "Measures words that paint a picture (objects, colors, sizes). Aim for 20-50%.",
            "Intangible": "Content that is not Personal or Visual (abstract concepts and filler). Aim for under 30%.",
            "Words/min": "Your speaking pace. 100-150 words per minute is 'just right'.",
            "Syllable/sec": "Our 'Mumble Meter'. It measures how densely packed your syllables are during active speech. 3 to 5 syllables per second is ideal.",
            "Pause %": "The percentage of time you spend silent. Aim for 10-30%.",
            "Words/Sent": "The average length of your sentences. Aim for 5-15 words.",
            "Comp. Grade": "The reading grade level of your speech. A grade of 5-10 is 'just right' and plain english.",
            "Simple %": "The percentage of your words within the 10,000 words used by people learning english. 85-95% is ideal."
        };

        window.toggleWidgetMenu = function() {
            const drawer = document.getElementById('widget-menu-drawer');
            const overlay = document.getElementById('widget-menu-overlay');

            if (drawer.classList.contains('translate-x-full')) {
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    drawer.classList.remove('translate-x-full');
                }, 10);
            } else {
                overlay.classList.add('opacity-0');
                drawer.classList.add('translate-x-full');
                setTimeout(() => overlay.classList.add('hidden'), 300); 
            }
        };

        window.switchWidgetTab = function(size) {
            ['small', 'medium', 'large'].forEach(s => {
                const btn = document.getElementById(`tab-btn-${s}`);
                const content = document.getElementById(`tab-content-${s}`);
                btn.className = "flex-1 py-3.5 text-xs font-bold uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-slate-700 hover:bg-slate-50 transition-colors";
                content.classList.add('hidden');
                content.classList.remove('block');
            });
            const activeBtn = document.getElementById(`tab-btn-${size}`);
            const activeContent = document.getElementById(`tab-content-${size}`);
            activeBtn.className = "flex-1 py-3.5 text-xs font-bold uppercase tracking-wider border-b-2 border-blue-600 text-blue-600 transition-colors";
            activeContent.classList.remove('hidden');
            activeContent.classList.add('block');
        };

        window.toggleRecording = function() {
            const btnText = document.getElementById('toggle-text');
            const btnIcon = document.getElementById('toggle-icon');
            const actionBar = document.getElementById('action-bar');
            const timerProgress = document.getElementById('timer-progress');
            
            if (isActive) {
                clearInterval(gameTimerInterval);
                isActive = false;
                if(btnText) btnText.innerText = 'TAP TO START RECORDING';
                if(btnIcon) btnIcon.setAttribute('data-lucide', 'play');
                if(actionBar) {
                    actionBar.classList.replace('bg-rose-600', 'bg-slate-800');
                    actionBar.classList.replace('hover:bg-rose-500', 'hover:bg-slate-700');
                }
                if (window.THPS && window.THPS.Audio && typeof window.THPS.Audio.stopRecordingProcess === 'function') {
                    window.THPS.Audio.stopRecordingProcess();
                }
            } else {
                isActive = true;
                if(btnText) btnText.innerText = 'TAP TO STOP';
                if(btnIcon) btnIcon.setAttribute('data-lucide', 'square');
                if(actionBar) {
                    actionBar.classList.replace('bg-slate-800', 'bg-rose-600');
                    actionBar.classList.replace('hover:bg-slate-700', 'hover:bg-rose-500');
                }
                if(timerProgress) timerProgress.style.width = '0%';
                
                if (window.clearAnalyzer) window.clearAnalyzer();
                
                if (window.THPS && window.THPS.Audio && typeof window.THPS.Audio.startRecordingProcess === 'function') {
                    window.THPS.Audio.startRecordingProcess();
                }
                
                if (gameTimerInterval) clearInterval(gameTimerInterval);
                gameTimerInterval = setInterval(() => {
                    const elapsedSecs = (Date.now() - window.THPS.Audio.recordStartTime) / 1000;
                    if (elapsedSecs >= 240) {
                        clearInterval(gameTimerInterval);
                        isActive = false;
                        if(btnText) btnText.innerText = 'TAP TO START RECORDING';
                        if(btnIcon) btnIcon.setAttribute('data-lucide', 'play');
                        if(actionBar) {
                            actionBar.classList.replace('bg-rose-600', 'bg-slate-800');
                            actionBar.classList.replace('hover:bg-rose-500', 'hover:bg-slate-700');
                        }
                        if (window.THPS && window.THPS.Audio && typeof window.THPS.Audio.stopRecordingProcess === 'function') {
                            window.THPS.Audio.stopRecordingProcess();
                        }
                        if (window.lucide) window.lucide.createIcons();
                    } else {
                        if(timerProgress) timerProgress.style.width = `${(elapsedSecs / 240) * 100}%`;
                    }
                }, 50);
            }
            if (window.lucide) window.lucide.createIcons();
        };

        function updateCelebrationPanel(totalPoints, totalSecs, overrideGrade, recordedAudio, textLength) {
            const panel = document.getElementById('celebration-panel');
            const comment = document.getElementById('celeb-comment');
            const gradeEl = document.getElementById('celeb-grade');
            const timeEl = document.getElementById('celeb-time');

            if (!recordedAudio && totalSecs === 0 && textLength === 0) {
                // Return to Blank State
                panel.className = "hidden w-full max-w-4xl mx-auto mt-2 mb-10 rounded-3xl shadow-sm p-8 text-center border border-slate-200 bg-slate-50 transition-all duration-500";
                comment.textContent = "Waiting for Audio...";
                comment.className = "text-xl md:text-3xl font-black uppercase tracking-widest mb-6 drop-shadow-sm text-slate-400";
                gradeEl.className = "text-5xl md:text-7xl font-black drop-shadow-sm text-slate-300";
                timeEl.className = "text-5xl md:text-7xl font-black drop-shadow-sm text-slate-300";
                document.getElementById('celeb-label-grade').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-slate-400";
                document.getElementById('celeb-label-time').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-slate-400";
                document.getElementById('celeb-divider').className = "w-px h-20 bg-slate-300 opacity-50";
                return;
            }

            // Set Data
            let finalScore = totalPoints % 1 === 0 ? totalPoints : totalPoints.toFixed(2);
            gradeEl.textContent = overrideGrade ? "- / 10" : `${finalScore} / 10`;
            
            if (totalSecs > 0) {
                let m = Math.floor(totalSecs / 60);
                let s = Math.floor(totalSecs % 60).toString().padStart(2, '0');
                timeEl.textContent = `${m}:${s}`;
            } else {
                timeEl.textContent = "-";
            }

            // Apply success styling
            panel.className = "w-full max-w-4xl mx-auto mt-2 mb-10 rounded-3xl shadow-xl p-8 text-center transition-all duration-500 text-white";
            gradeEl.className = "text-5xl md:text-7xl font-black drop-shadow-sm";
            timeEl.className = "text-5xl md:text-7xl font-black drop-shadow-sm";
            comment.className = "text-xl md:text-3xl font-black uppercase tracking-widest mb-6 drop-shadow-sm";
            document.getElementById('celeb-label-grade').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-white/90";
            document.getElementById('celeb-label-time').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-white/90";
            document.getElementById('celeb-divider').className = "w-px h-20 bg-white/40";

            if (!overrideGrade) {
                if (totalPoints >= 8.5) {
                    comment.textContent = "Wow! Those are some nice scores!";
                    panel.classList.add('bg-gradient-to-br', 'from-emerald-600', 'to-teal-800');
                } else if (totalPoints >= 7) {
                    comment.textContent = "Well said! Check out those scores";
                    panel.classList.add('bg-gradient-to-br', 'from-blue-600', 'to-indigo-800');
                } else {
                    comment.textContent = "Check your scores and have another go!";
                    panel.classList.add('bg-gradient-to-br', 'from-amber-500', 'to-orange-700');
                }
            } else {
                comment.textContent = "Check your scores and have another go!";
                panel.classList.add('bg-gradient-to-br', 'from-slate-600', 'to-slate-800');
            }
        }

        window.analyze = function() {
            try {
                if (!window.THPS || !window.THPS.NLP || typeof window.THPS.NLP.loadDictionaries !== 'function') return;
            } catch(e) { return; }
            
            if (!window.THPS.NLP.dictsLoaded) return;
            
            let text = "";
            const widgetEl = document.getElementById('cba-inputText-widget');
            const hiddenEl = document.getElementById('cba-inputText');
            if (widgetEl && widgetEl.value.trim() !== '') text = widgetEl.value.trim();
            else if (hiddenEl) text = hiddenEl.value.trim();
            
            if (!text) {
                updateCelebrationPanel(0, 0, true, false, 0); 
                window.dispatchEvent(new CustomEvent('thps-dashboard-update', { detail: { text: "" } }));
                return;
            }

            let timestamps = [];
            if (window.THPS.Audio && window.THPS.Audio.recordedAudio && window.THPS.Audio.wordTimestamps) {
                timestamps = window.THPS.Audio.wordTimestamps;
            }
            
            const nlpData = window.THPS.NLP.analyzeTranscript(text, timestamps);

            const { 
                numWords, numSentences, totalSyllables, letterCount, complexWordCount, 
                personalCount, visualCount, simpleCounts, google10kCount, 
                highlightedHTML, reportMarkdownText: newReportMarkdown,
                wordTimestamps 
            } = nlpData;

            reportMarkdownText = newReportMarkdown; 

            let gPct = Math.round((google10kCount / numWords) * 100);

            let s5yrPct = Math.round((simpleCounts['5yr Old 1000'] / numWords) * 100) || 0;
            let sEslPct = Math.round((simpleCounts['ESL 2000'] / numWords) * 100) || 0;
            let sKitPct = Math.round((simpleCounts['Kitchen 1000'] / numWords) * 100) || 0;
            let coreSimpleScore = s5yrPct + sEslPct + sKitPct; 
            
            let elapsedSecs = window.THPS.Audio && window.THPS.Audio.recordedAudio ? (window.THPS.Audio.lastRecordedDuration || 0) : 0;
            let transcribedDuration = Math.min(240, elapsedSecs);
            
            let mumbleScore = 0; 
            let estimatedPauseTime = 0; 
            let pausePercent = 0; 
            let avgWpm = 0;
            let activeSpeakingSecs = 0;

            if (window.THPS.Audio && window.THPS.Audio.recordedAudio && elapsedSecs > 0) {
                const periods = (text.match(/[.!?]/g) || []).length;
                const commas = (text.match(/[,;:-]/g) || []).length;
                
                estimatedPauseTime = (periods * 1.3) + (commas * 0.5); 
                
                let minAllowedPause = transcribedDuration * 0.10;
                let maxAllowedPause = transcribedDuration * 0.40;
                if (estimatedPauseTime < minAllowedPause) estimatedPauseTime = minAllowedPause;
                if (estimatedPauseTime > maxAllowedPause) estimatedPauseTime = maxAllowedPause;
                
                activeSpeakingSecs = transcribedDuration - estimatedPauseTime;
                pausePercent = (estimatedPauseTime / transcribedDuration) * 100;
                
                avgWpm = Math.round((numWords / transcribedDuration) * 60);
                mumbleScore = totalSyllables / activeSpeakingSecs;
            }

            let avgGrade = 0;
            let readability = null;
            if (typeof window.THPS.NLP.calculateReadabilityMetrics === 'function') {
                 readability = window.THPS.NLP.calculateReadabilityMetrics(numWords, numSentences, totalSyllables, letterCount, complexWordCount);
                 avgGrade = readability.avgGrade;
            } else {
                let flesch = (0.39 * (numWords / numSentences)) + (11.8 * (totalSyllables / numWords)) - 15.59;
                let fog = 0.4 * ((numWords / numSentences) + 100 * (complexWordCount / numWords));
                let smog = 1.0430 * Math.sqrt(complexWordCount * (30 / numSentences)) + 3.1291;
                let coleman = 0.0588 * ((letterCount / numWords) * 100) - 0.296 * ((numSentences / numWords) * 100) - 15.8;
                avgGrade = ((Math.max(0, flesch)) + (Math.max(0, fog)) + (Math.max(0, smog)) + (Math.max(0, coleman))) / 4;
                readability = { flesch: Math.max(0, flesch), fog: Math.max(0, fog), smog: Math.max(0, smog), coleman: Math.max(0, coleman), avgGrade: avgGrade };
            }

            let personalPercent = Math.round((personalCount / numWords) * 100);
            let visualPercent = Math.round((visualCount / numWords) * 100);
            let intangiblePercent = Math.max(0, 100 - personalPercent - visualPercent);

            let avgWpsFloat = numSentences > 0 ? (numWords / numSentences) : 0;
            
            try {
                let totalPoints = 0;
                let overrideGrade = false;

                if (window.THPS.Audio && window.THPS.Audio.recordedAudio && elapsedSecs > 0) {
                    if (elapsedSecs < 30) overrideGrade = true; 
                    else if (elapsedSecs < 60) totalPoints += 0.75; 
                    else if (elapsedSecs <= 90) totalPoints += 1.0; 
                    else overrideGrade = true;

                    if (avgWpm < 100) totalPoints += 0.75; 
                    else if (avgWpm > 150) totalPoints += 0.25; 
                    else totalPoints += 1;

                    if (mumbleScore < 3) totalPoints += 0.75; 
                    else if (mumbleScore > 5) totalPoints += 0.25; 
                    else totalPoints += 1;

                    if (pausePercent < 10) totalPoints += 0.25; 
                    else if (pausePercent > 30) totalPoints += 0.75; 
                    else totalPoints += 1;
                } else {
                    overrideGrade = true;
                }

                if (personalPercent < 30) totalPoints += 0.25; 
                else if (personalPercent > 60) totalPoints += 0.75; 
                else totalPoints += 1;

                if (visualPercent < 20) totalPoints += 0.25; 
                else if (visualPercent > 50) totalPoints += 0.75; 
                else totalPoints += 1;

                if (intangiblePercent > 45) totalPoints += 0.25; 
                else if (intangiblePercent >= 30) totalPoints += 0.75; 
                else totalPoints += 1;

                if (avgWpsFloat < 5) totalPoints += 0.75; 
                else if (avgWpsFloat > 15) totalPoints += 0.25; 
                else totalPoints += 1;

                if (avgGrade < 5) totalPoints += 0.75; 
                else if (avgGrade > 10) totalPoints += 0.25; 
                else totalPoints += 1;

                if (coreSimpleScore < 85) totalPoints += 0.25; 
                else if (coreSimpleScore > 95) totalPoints += 0.75; 
                else totalPoints += 1;

                updateCelebrationPanel(totalPoints, elapsedSecs, overrideGrade, window.THPS.Audio ? window.THPS.Audio.recordedAudio : false, text.length);

                // --- THE TRACKMAN BROADCAST ---
                window.dispatchEvent(new CustomEvent('thps-dashboard-update', { 
                    detail: { 
                        sps: mumbleScore,
                        wpm: avgWpm,
                        grade: avgGrade,
                        time: elapsedSecs,
                        personal: personalPercent,
                        visual: visualPercent,
                        text: text,
                        wordTimestamps: wordTimestamps,
                        volumeData: (window.THPS && window.THPS.Audio && window.THPS.Audio.volumeData) ? window.THPS.Audio.volumeData : [],
                        pause: pausePercent,
                        intangible: intangiblePercent,
                        wps: avgWpsFloat,
                        simple: coreSimpleScore,
                        totalPoints: totalPoints,
                        overrideGrade: overrideGrade,
                        recordedAudio: window.THPS.Audio ? window.THPS.Audio.recordedAudio : false,
                        highlightedHTML: highlightedHTML,
                        reportMarkdownText: reportMarkdownText,
                        numWords: numWords,
                        numSentences: numSentences,
                        totalSyllables: totalSyllables,
                        google10kCount: google10kCount,
                        simpleCounts: simpleCounts,
                        readability: readability
                    } 
                }));

            } catch(e) { console.error("Summary Dashboard Error:", e); }
        };

        window.copyReportToClipboard = function() {
            let cleanMarkdown = reportMarkdownText.trim().replace(/\n/g, '\n\n').replace(/ +/g, ' ');
            const report = `MIC-CHECK CHALLENGE - REPORT\n=========================================\n\n--- TRANSCRIPT (Marked Up) ---\n* Personal text is **bolded**\n* Visual text is _underlined_\n* Overlapping text is _**both**_\n\n${cleanMarkdown}\n`;
            
            const el = document.createElement('textarea');
            el.value = report;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
        };

        window.clearAnalyzer = function() {
            const hiddenEl = document.getElementById('cba-inputText');
            if (hiddenEl) hiddenEl.value = '';
            
            const procPanel = document.getElementById('cba-processing-panel');
            if (procPanel) procPanel.classList.add('hidden');
            
            if (window.THPS && window.THPS.Audio) {
                window.THPS.Audio.recordedAudio = false; 
                window.THPS.Audio.lastRecordedDuration = 0;
                window.THPS.Audio.wordTimestamps = []; 
                window.THPS.Audio.volumeData = [];
            }
            
            window.analyze();
        };

        window.explain = function(term) {
            const titleEl = document.getElementById('cba-explanationTitle');
            const contentEl = document.getElementById('cba-explanationContent');
            if (!titleEl || !contentEl) return;
            
            const panel = titleEl.closest('.glass-panel');
            if (panel) {
                panel.classList.add('ring-2', 'ring-blue-400', 'scale-[1.01]');
                setTimeout(() => panel.classList.remove('ring-2', 'ring-blue-400', 'scale-[1.01]'), 300);
            }

            titleEl.innerText = term;
            contentEl.classList.remove('italic', 'justify-center');
            contentEl.innerHTML = `<span class="animate-pulse">Loading explanation...</span>`;

            setTimeout(() => {
                let text = (explanationsData && explanationsData[term]) 
                           ? explanationsData[term] 
                           : (FALLBACK_EXPLANATIONS[term] || `Detailed explanation for "${term}" will appear here soon.`);
                contentEl.innerHTML = text;
            }, 150);
        };

        document.addEventListener('input', (e) => {
            if (e.target.id === 'cba-inputText-widget') {
                const hiddenEl = document.getElementById('cba-inputText');
                if (hiddenEl) hiddenEl.value = e.target.value;
            }
        });
        
        async function fetchExplanations() {
            try {
                const res = await fetch(EXPLANATIONS_URL + '?nocache=' + new Date().getTime());
                if (res.ok) explanationsData = await res.json();
            } catch (e) {
                console.warn("Using fallback explanations for 'What does this mean' panel.");
            }
        }

        window.onload = () => {
            if (window.THPS && window.THPS.NLP && typeof window.THPS.NLP.loadDictionaries === 'function') {
                window.THPS.NLP.loadDictionaries();
            }
            fetchExplanations();
        };

    </script>
