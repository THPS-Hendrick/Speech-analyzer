    <script>
        lucide.createIcons();
        
        let gameTimerInterval = null;
        let isActive = false;
        
        const inputEl = document.getElementById('cba-inputText');

        // NEW: WIDGET MENU LOGIC
        window.toggleWidgetMenu = function() {
            const drawer = document.getElementById('widget-menu-drawer');
            const overlay = document.getElementById('widget-menu-overlay');

            if (drawer.classList.contains('translate-x-full')) {
                // Open Menu
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    drawer.classList.remove('translate-x-full');
                }, 10);
            } else {
                // Close Menu
                overlay.classList.add('opacity-0');
                drawer.classList.add('translate-x-full');
                setTimeout(() => {
                    overlay.classList.add('hidden');
                }, 300); 
            }
        };

        window.switchWidgetTab = function(size) {
            // Reset all buttons
            ['small', 'medium', 'large'].forEach(s => {
                const btn = document.getElementById(`tab-btn-${s}`);
                const content = document.getElementById(`tab-content-${s}`);
                btn.className = "flex-1 py-3.5 text-xs font-bold uppercase tracking-wider border-b-2 border-transparent text-slate-400 hover:text-slate-700 hover:bg-slate-50 transition-colors";
                content.classList.add('hidden');
                content.classList.remove('block');
            });

            // Activate chosen tab
            const activeBtn = document.getElementById(`tab-btn-${size}`);
            const activeContent = document.getElementById(`tab-content-${size}`);
            activeBtn.className = "flex-1 py-3.5 text-xs font-bold uppercase tracking-wider border-b-2 border-blue-600 text-blue-600 transition-colors";
            activeContent.classList.remove('hidden');
            activeContent.classList.add('block');
        };

        window.toggleRecording = function() {
            const btnText = document.getElementById('toggle-text');
            const btnIcon = document.getElementById('toggle-icon');
            const actionBar = document.getElementById('action-bar');
            const timerProgress = document.getElementById('timer-progress');
            
            if (isActive) {
                // STOP
                clearInterval(gameTimerInterval);
                isActive = false;
                btnText.innerText = 'TAP TO START RECORDING';
                btnIcon.setAttribute('data-lucide', 'play');
                actionBar.classList.replace('bg-rose-600', 'bg-slate-800');
                actionBar.classList.replace('hover:bg-rose-500', 'hover:bg-slate-700');
                if (typeof window.THPS.Audio.stopRecordingProcess === 'function') window.THPS.Audio.stopRecordingProcess();
            } else {
                // START
                isActive = true;
                btnText.innerText = 'TAP TO STOP';
                btnIcon.setAttribute('data-lucide', 'square');
                actionBar.classList.replace('bg-slate-800', 'bg-rose-600');
                actionBar.classList.replace('hover:bg-slate-700', 'hover:bg-rose-500');
                
                timerProgress.style.width = '0%';
                
                const clearBtn = document.getElementById('cba-clearBtn');
                if (clearBtn) clearBtn.click();
                
                if (typeof window.THPS.Audio.startRecordingProcess === 'function') window.THPS.Audio.startRecordingProcess();
                
                if (gameTimerInterval) clearInterval(gameTimerInterval);
