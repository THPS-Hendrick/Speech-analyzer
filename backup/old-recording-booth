                            <div class="flex items-center gap-1 shrink-0"><span class="font-bold text-slate-800 leading-none mt-[1px]" id="stat-pause">-</span> <span id="eval-pause" class="inline-flex items-center justify-center h-[16px] min-w-[34px] px-1 rounded text-[7px] font-bold leading-none bg-slate-100 text-slate-500 tracking-wide">WAIT</span></div>
