    <div id="cba-errorMsg" class="hidden mt-4 max-w-md w-full text-xs font-medium text-rose-500 bg-rose-50 p-3 rounded-lg border border-rose-200 shadow-sm text-center"></div>

    <script>
        lucide.createIcons();

        // -----------------------------------------------------
        // DATE & MOCK DATA INITIALIZATION
        // -----------------------------------------------------
        const GITHUB_JSON_URL = "https://raw.githubusercontent.com/THPS-Hendrick/Speech-analyzer/refs/heads/main/mic-check-daily.json";
        const FALLBACK_TODAY = { challenge: "Entertain us", sponsor: "Umbrellas", script: "Home Away", micCheck: "Use your hands" };
        let cardStates = { challenge: false, sponsor: true, script: false, micCheck: false };

        function getAdelaideDateString() {
            const formatter = new Intl.DateTimeFormat('en-US', { timeZone: 'Australia/Adelaide', year: 'numeric', month: '2-digit', day: '2-digit' });
            const parts = formatter.formatToParts(new Date());
            return `${parts.find(p=>p.type==='year').value}-${parts.find(p=>p.type==='month').value}-${parts.find(p=>p.type==='day').value}`;
        }
        const dateStr = getAdelaideDateString();

        async function fetchDailyCards() {
            document.getElementById('booth-date').innerText = `DATE: ${dateStr}`;
            let todaysCards = FALLBACK_TODAY;
            
            try {
                if(!GITHUB_JSON_URL.includes("YOUR_USERNAME")) {
                    const response = await fetch(GITHUB_JSON_URL + '?nocache=' + new Date().getTime());
                    if (response.ok) {
                        const data = await response.json();
                        if (data[dateStr]) todaysCards = data[dateStr];
                    }
                }
            } catch (error) {}

            document.getElementById('text-challenge').innerText = todaysCards.challenge;
            document.getElementById('text-sponsor').innerText = todaysCards.sponsor;
            document.getElementById('text-script').innerText = todaysCards.script;
            document.getElementById('text-micCheck').innerText = todaysCards.micCheck;
            
            setDifficulty(1);
        }

        function updateDifficulty() {
            let stars = 0;
            if (cardStates.challenge) stars += 1;
            if (cardStates.sponsor) stars += 1;
            if (cardStates.script) stars += 1;
            if (cardStates.micCheck) stars += 2;
            
            stars = Math.max(0, Math.min(5, stars));

            for (let i = 1; i <= 5; i++) {
                const starEl = document.getElementById(`star-${i}`);
                if (starEl) {
                    if (i <= stars) { 
                        starEl.classList.remove('star-empty'); 
                        starEl.classList.add('star-filled'); 
                    } else { 
                        starEl.classList.remove('star-filled'); 
