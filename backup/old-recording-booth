        function renderScoreSummary(scores) {
            // Hide Game Content & Action Bar
            document.getElementById('booth-game-content').classList.add('hidden');
            document.getElementById('action-bar').classList.add('hidden');
            
            // Show Summary Content
            const summaryUI = document.getElementById('booth-summary');
            summaryUI.classList.remove('hidden');
            summaryUI.classList.add('flex');

            if (!scores) {
                document.getElementById('summary-headline').innerText = "Transcript Failed";
                return;
            }

            document.getElementById('summary-headline').innerText = scores.finalGrade !== "-" ? "Wow! Those are some nice scores!" : "Keep Practicing!";
            document.getElementById('summary-grade').innerText = `${scores.finalGrade} / 10`;
            document.getElementById('stat-time').innerText = `${Math.round(scores.durationSecs)}s`;
            
            let evTime = getEval(Math.round(scores.durationSecs), 'time');
            document.getElementById('eval-time').innerText = evTime.text;
            document.getElementById('eval-time').className = `inline-flex items-center justify-center h-[16px] min-w-[34px] px-1 rounded text-[7px] font-bold leading-none tracking-wide ${evTime.colorClass}`;

            const updateMetric = (id, val, type) => {
                document.getElementById(`stat-${id}`).innerText = val;
                let ev = getEval(parseFloat(val), type);
                const el = document.getElementById(`eval-${id}`);
                el.innerText = ev.text;
                el.className = `inline-flex items-center justify-center h-[16px] min-w-[34px] px-1 rounded text-[7px] font-bold leading-none tracking-wide ${ev.colorClass}`;
            };

            updateMetric('personal', scores.personalPct + '%', 'personal');
            updateMetric('visual', scores.visualPct + '%', 'visual');
            updateMetric('intangible', scores.intangiblePct + '%', 'intangible');
            updateMetric('pause', scores.pausePct + '%', 'pause');

            updateMetric('wpm', scores.wpm, 'wpm');
            updateMetric('sps', scores.sps, 'sps');
            updateMetric('wps', scores.wps, 'wps');
            updateMetric('grade', scores.grade, 'grade');
            updateMetric('outside', scores.outsidePct + '%', 'outside');
        }

    </script>
</body>
</html>
