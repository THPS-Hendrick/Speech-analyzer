                case 'grade':
                    if(val >= 5 && val <= 10) return {text: 'GOOD', colorClass: 'bg-green-100 text-green-700'};
                    if(val < 5) return {text: 'LOW', colorClass: 'bg-amber-100 text-amber-700'};
                    return {text: 'HIGH', colorClass: 'bg-rose-100 text-rose-700'};
                case 'outside':
