        async function startGame() {
            gameState = 'PLAYING';
            audioBuffers = [];
            totalSamplesRecorded = 0;
            recordStartTime = Date.now();

            // Setup AudioContext cloned from local stream
            const AudioContextClass = window.AudioContext || window.webkitAudioContext;
            audioCtx = new AudioContextClass({ sampleRate: 16000 });
            sourceNode = audioCtx.createMediaStreamSource(localCamStream); 
            processorNode = audioCtx.createScriptProcessor(4096, 1, 1);

            processorNode.onaudioprocess = function(e) {
                if (gameState !== 'PLAYING') return;
                const channelData = e.inputBuffer.getChannelData(0);
                
                const elapsed = (Date.now() - recordStartTime) / 1000;
                if (elapsed <= 90) { // Limit chunks safely
                    audioBuffers.push(new Float32Array(channelData));
                    totalSamplesRecorded += channelData.length;
                }

                if (elapsed >= 90) {
                    stopGameAndAnalyze();
                }
            };

            sourceNode.connect(processorNode);
            processorNode.connect(audioCtx.destination); 

            // Visuals
            actionText.innerHTML = '<i data-lucide="square" class="w-3 h-3"></i> TAP TO STOP';
            lucide.createIcons();
            
            // Timer Loop
            timerProgress.style.transitionDuration = "1000ms";
            timerInterval = setInterval(() => {
                const elapsedSecs = (Date.now() - recordStartTime) / 1000;
                let displaySecs = Math.ceil(90 - elapsedSecs);
                if (displaySecs < 0) displaySecs = 0;
                
                timerProgress.style.width = `${(elapsedSecs / 90) * 100}%`;
            }, 50);
        }

        async function stopGameAndAnalyze() {
            if (gameState !== 'PLAYING') return;
            
            clearInterval(timerInterval);
            gameState = 'ANALYZING';
            
            actionText.innerHTML = '<i data-lucide="loader-2" class="w-3 h-3 animate-spin"></i> ANALYZING...';
            lucide.createIcons();
            
            if (processorNode) processorNode.disconnect();
            if (sourceNode) sourceNode.disconnect();
            if (audioCtx && audioCtx.state !== 'closed') audioCtx.close();

            const durationSecs = (Date.now() - recordStartTime) / 1000;
            const transcribedDuration = Math.min(90, durationSecs);

            let masterFloatArray = new Float32Array(totalSamplesRecorded);
            let writeOffset = 0;
            for(let i = 0; i < audioBuffers.length; i++) {
                masterFloatArray.set(audioBuffers[i], writeOffset);
                writeOffset += audioBuffers[i].length;
            }

            // Parallel Chunking
            const sampleRate = 16000;
            const chunkSize = sampleRate * 30; // 30-sec slices
            let wavChunks = [];
            
            for(let i = 0; i < totalSamplesRecorded; i += chunkSize) {
                let segment = masterFloatArray.subarray(i, Math.min(i + chunkSize, totalSamplesRecorded));
                wavChunks.push(encodeWAV(segment, sampleRate));
            }

            const uploadPromises = wavChunks.map(async (blob, index) => {
                return new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.readAsDataURL(blob);
                    reader.onloadend = async () => {
                        const base64data = reader.result.split(',')[1];
                        try {
                            const response = await fetch('https://mic-check-backend.vercel.app/api/transcribe', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ audioContent: base64data, mimeType: 'audio/wav' })
                            });
                            if (response.ok) {
                                const data = await response.json();
                                resolve({ index: index, transcript: data.transcript ? data.transcript.trim() : '' });
                            } else {
                                resolve({ index: index, transcript: '', error: `HTTP ${response.status}` });
                            }
                        } catch (e) {
                            resolve({ index: index, transcript: '', error: e.message });
                        }
                    };
                });
            });

            try {
                const resolvedChunks = await Promise.all(uploadPromises);
                resolvedChunks.sort((a, b) => a.index - b.index); 
                const finalStitchedTranscript = resolvedChunks
                    .map(r => r.transcript)
                    .filter(t => t.length > 0)
                    .join(' ');

                const scores = calculateScores(finalStitchedTranscript, transcribedDuration);
                renderScoreSummary(scores);

                gameState = 'SCORED';

            } catch (err) {
                console.error(err);
                renderScoreSummary(null);
                gameState = 'SCORED';
            }
        }

        // ==========================================
        // NLP & SCORING LOGIC
        // ==========================================
        function calculateScores(text, durationSecs) {
            if (!text || durationSecs < 1) return null;

            const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
            const words = text.split(/\s+/).filter(w => w.trim().length > 0);
            
            let totalSyllables = 0; 
            let personalCount = 0; 
            let visualCount = 0;
            let simpleCount = 0;

            const numWords = Math.max(1, words.length);
            const numSentences = Math.max(1, sentences.length);

            const countSyllables = (w) => {
                w = w.toLowerCase().replace(/[^a-z]/g, '');
                if (w.length <= 3) return 1;
                w = w.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
                w = w.replace(/^y/, '');
                const match = w.match(/[aeiouy]{1,2}/g);
                return match ? match.length : 1;
            };

            words.forEach(word => {
                let clean = word.toLowerCase().replace(/[^a-z']/g, '');
                let root = clean.replace(/(?:s|es|ed|ing)$/, '');
                
                totalSyllables += countSyllables(clean);

                let isPersonal = personalPronouns.has(clean);
                let isVisual = !isPersonal && (visualDictPronouns.has(clean) || visualDictWords.has(clean) || visualDictWords.has(root));

                if (isPersonal) personalCount++;
                if (isVisual) visualCount++;
                if (simpleMap.has(clean) || simpleMap.has(root)) simpleCount++;
            });

            const wpm = Math.round((numWords / durationSecs) * 60);
            const personalPct = Math.round((personalCount / numWords) * 100);
            const visualPct = Math.round((visualCount / numWords) * 100);
            const outsidePct = 100 - Math.round((simpleCount / numWords) * 100);
            const wps = (numWords / numSentences).toFixed(1);

            const periods = (text.match(/[.!?]/g) || []).length;
            const commas = (text.match(/[,;:-]/g) || []).length;
            let estimatedPauseTime = (periods * 1.3) + (commas * 0.5);
            estimatedPauseTime = Math.max(durationSecs * 0.1, Math.min(durationSecs * 0.4, estimatedPauseTime));
            const pausePct = Math.round((estimatedPauseTime / durationSecs) * 100);
            
            const activeSecs = durationSecs - estimatedPauseTime;
            const sps = activeSecs > 0 ? (totalSyllables / activeSecs).toFixed(1) : 0;

            const grade = Math.max(0, (0.39 * (numWords / numSentences)) + (11.8 * (totalSyllables / numWords)) - 15.59).toFixed(1);

            let pts = 0;
            
            // 1. Time (durationSecs)
            if (durationSecs >= 60 && durationSecs < 80) pts += 1.0;
            else if (durationSecs >= 40 && durationSecs < 60) pts += 0.75;
            else if (durationSecs >= 20 && durationSecs < 40) pts += 0.25;
            
            // 2. Personal (personalPct)
            if (personalPct >= 30 && personalPct <= 60) pts += 1.0;
            else if (personalPct < 30) pts += 0.25;
            else pts += 0.75;
            
            // 3. Visual (visualPct)
            if (visualPct >= 20 && visualPct <= 50) pts += 1.0;
            else if (visualPct < 20) pts += 0.25;
            else pts += 0.75;

            // 4. Intangible (intangiblePct)
            let intangiblePct = Math.max(0, 100 - personalPct - visualPct);
            if (intangiblePct >= 10 && intangiblePct <= 30) pts += 1.0;
            else if (intangiblePct < 10) pts += 0.75;
            else if (intangiblePct > 45) pts += 0.25;
            else pts += 0.75;

            // 5. WPM (wpm)
            if (wpm >= 100 && wpm <= 150) pts += 1.0;
            else if (wpm < 100) pts += 0.75;
            else pts += 0.25;

            // 6. SPS (sps)
            if (sps >= 3 && sps <= 5) pts += 1.0;
            else if (sps < 3) pts += 0.75;
            else pts += 0.25;

            // 7. Pause (pausePct)
            if (pausePct >= 10 && pausePct <= 30) pts += 1.0;
            else if (pausePct < 10) pts += 0.25;
            else pts += 0.75;

            // 8. WPS (wps)
            if (wps >= 5 && wps <= 15) pts += 1.0;
            else if (wps < 5) pts += 0.75;
            else pts += 0.25;

            // 9. Grade (grade)
            if (grade >= 5 && grade <= 10) pts += 1.0;
            else if (grade < 5) pts += 0.75;
            else pts += 0.25;

            // 10. Outside Non-fluent Eng. (outsidePct)
            if (outsidePct >= 5 && outsidePct <= 15) pts += 1.0;
            else if (outsidePct > 15) pts += 0.25;
            else pts += 0.75;
            
            let finalGrade = (pts % 1 === 0) ? pts.toString() : pts.toFixed(1);
            if (durationSecs < 20 || durationSecs >= 80) finalGrade = "-";

            return {
                wpm, sps, pausePct, personalPct, visualPct, intangiblePct, outsidePct, wps, grade, finalGrade, durationSecs
            };
        }

        // Color/text helpers for compact grid
        function getEval(val, type) {
