                    if(val > 15) return {text: 'HIGH', colorClass: 'bg-rose-100 text-rose-700'};
                    return {text: 'LOW', colorClass: 'bg-amber-100 text-amber-700'};
            }

            return {text: 'WAIT', colorClass: 'bg-slate-100 text-slate-500'};
