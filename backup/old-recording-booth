<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mic-Check Karaoke Booth</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://unpkg.com/compromise@14.14.3/builds/compromise.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Permanent+Marker&display=swap');
        
        body {
            background-color: #0f172a; 
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
        }

        /* 9:16 Scaling container */
        #karaoke-booth {
            width: 100%;
            max-width: 420px; 
            aspect-ratio: 9 / 16;
            background-color: #ffffff;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            border-radius: 12px;
            margin: 0 auto;
        }

        /* 3D Card Flipping */
        .preserve-3d { transform-style: preserve-3d; }
        .backface-hidden { backface-visibility: hidden; }
        .rotate-y-180 { transform: rotateY(180deg) !important; }
        
        .k-card {
            aspect-ratio: 3/4;
            border-radius: 6px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        #user-cam {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1); /* Mirror selfie cam */
        }

        /* Star styling */
        .star-filled { fill: #eab308; color: #eab308; } 
        .star-empty { fill: transparent; color: #e2e8f0; } 
        .star-hover { fill: #fde047 !important; color: #fde047 !important; } 
        
        /* Layout Adjustments */
        #external-controls {
            width: 100%;
            max-width: 420px;
            margin: 1.5rem auto;
            background: rgba(30, 41, 59, 0.8);
            padding: 1.5rem;
            border-radius: 1rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }

    </style>
</head>
<body class="py-8 px-4 flex flex-col">

    <div id="karaoke-booth" class="shrink-0">
        
        <div id="booth-ui-top" class="flex-1 bg-white p-4 flex flex-col relative z-10">
            
            <div id="booth-header" class="flex justify-between items-center mb-2 shrink-0 px-1">
                
                <div class="w-[110px] flex justify-start items-center mt-2">
                    <img src="https://images.squarespace-cdn.com/content/v1/684927e2a3550529e907b25d/5b7659bf-f19f-4af3-8156-7647b5e5cd43/thps-tom-hendrick-public-speaking-skills-diagnostic-coaching-plan.png?format=1500w" alt="THPS Logo" class="h-12 w-auto object-contain drop-shadow-sm">
                </div>
                
                <div class="flex-1 flex flex-col items-center justify-center pb-1">
                    <h1 class="leading-none tracking-wider flex flex-col items-center text-center" style="font-family: 'Permanent Marker', cursive;">
                        <span class="text-[11px] text-slate-900 leading-tight">DAILY</span>
                        <span class="text-[22px] font-black text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-amber-500 drop-shadow-[0_1px_1px_rgba(0,0,0,0.2)] leading-tight uppercase tracking-tighter">MIC-CHECK</span>
                    </h1>
                    <span class="text-[7px] text-slate-400 font-bold uppercase tracking-widest mt-0.5" id="booth-date">Loading...</span>
                </div>
                
                <div class="w-[110px] flex justify-end items-center">
                    <div class="flex flex-col items-center bg-white border border-slate-100 shadow-sm px-2 py-1.5 rounded-xl w-full">
                        <span id="level-text" class="text-[7px] font-bold text-slate-500 uppercase tracking-widest mb-1 text-center whitespace-nowrap">Level: Beginner</span>
                        <div class="flex gap-0.5" id="star-container" onmouseleave="resetStarsHover()">
                            <i data-lucide="star" class="w-3.5 h-3.5 cursor-pointer star-empty" id="star-1" onmouseover="hoverStars(1)" onclick="setDifficulty(1)"></i>
                            <i data-lucide="star" class="w-3.5 h-3.5 cursor-pointer star-empty" id="star-2" onmouseover="hoverStars(2)" onclick="setDifficulty(2)"></i>
                            <i data-lucide="star" class="w-3.5 h-3.5 cursor-pointer star-empty" id="star-3" onmouseover="hoverStars(3)" onclick="setDifficulty(3)"></i>
                            <i data-lucide="star" class="w-3.5 h-3.5 cursor-pointer star-empty" id="star-4" onmouseover="hoverStars(4)" onclick="setDifficulty(4)"></i>
                            <i data-lucide="star" class="w-3.5 h-3.5 cursor-pointer star-empty" id="star-5" onmouseover="hoverStars(5)" onclick="setDifficulty(5)"></i>
                        </div>
