<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YouTube Thumbnail Maker (V24.1 Edition)</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useRef, useEffect, useCallback } = React;

    // --- Inline Icons ---
    const UploadIcon = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" className={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
    );
    const ImageIcon = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" className={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
      </svg>
    );
    const DownloadIcon = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" className={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
    );
    const SettingsIcon = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" className={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
        <path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="7" r="3"/><circle cx="7" cy="17" r="3"/>
      </svg>
    );
    const RefreshIcon = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" className={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>
      </svg>
    );

    // --- Main Application Component ---
    function App() {
      const [sourceImage, setSourceImage] = useState(null);
      const [isProcessing, setIsProcessing] = useState(false);

      const [shortsThumb, setShortsThumb] = useState(null);
      const [standardThumb, setStandardThumb] = useState(null);
      const [shortsSize, setShortsSize] = useState(0);
      const [standardSize, setStandardSize] = useState(0);

      // New Config tailored for the 3-piece layout
      const [config, setConfig] = useState({
        cameraYStart: 950,
        cameraHeight: 900,
        promptsYStart: 50,
        promptsHeight: 700,
        logoYStart: 0,
        logoHeight: 250,
        targetMB: 1.95, 
      });

      const fileInputRef = useRef(null);

      const formatMB = (bytes) => (bytes / (1024 * 1024)).toFixed(2) + ' MB';

      const optimizeImage = async (canvas, targetMB) => {
        const targetBytes = targetMB * 1024 * 1024;
        let quality = 1.0;
        
        let blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', quality));
        if (blob.size <= targetBytes) return blob;

        let minQ = 0.1;
        let maxQ = 1.0;
        let bestBlob = blob;

        for (let i = 0; i < 7; i++) {
          quality = (minQ + maxQ) / 2;
          blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', quality));
          
          if (blob.size > targetBytes) {
            maxQ = quality; 
          } else {
            minQ = quality; 
            bestBlob = blob; 
          }
        }
        return bestBlob;
      };

      const handleImageUpload = (e) => {
        const file = e.target.files?.[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (event) => {
          const img = new Image();
          img.onload = () => {
            setSourceImage(img);
          };
          img.src = event.target.result;
        };
        reader.readAsDataURL(file);
      };

      const generateThumbnails = useCallback(async () => {
        if (!sourceImage) return;
        setIsProcessing(true);

        try {
          // ==========================================
          // 1. SHORTS THUMBNAIL (9:16 Center Crop)
          // ==========================================
          const shortsCanvas = document.createElement('canvas');
          shortsCanvas.width = 1080;
          shortsCanvas.height = 1920;
          const sCtx = shortsCanvas.getContext('2d');

          const sAspectRatio = 1080 / 1920;
          const iAspectRatio = sourceImage.width / sourceImage.height;
          let sx = 0, sy = 0, sw = sourceImage.width, sh = sourceImage.height;

          if (iAspectRatio > sAspectRatio) {
            sw = sourceImage.height * sAspectRatio;
            sx = (sourceImage.width - sw) / 2;
          } else {
            sh = sourceImage.width / sAspectRatio;
            sy = (sourceImage.height - sh) / 2;
          }
          sCtx.drawImage(sourceImage, sx, sy, sw, sh, 0, 0, 1080, 1920);

          const shortsBlob = await optimizeImage(shortsCanvas, config.targetMB);
          setShortsThumb(URL.createObjectURL(shortsBlob));
          setShortsSize(shortsBlob.size);

          // ==========================================
          // 2. STANDARD THUMBNAIL (16:9 Assembly)
          // ==========================================
          const stdCanvas = document.createElement('canvas');
          stdCanvas.width = 1280;
          stdCanvas.height = 720;
          const ctx = stdCanvas.getContext('2d');

          // Dark slate background to make the white panels pop
          ctx.fillStyle = '#1e293b';
          ctx.fillRect(0, 0, 1280, 720);

          // Canonical scale mapping assuming settings are tuned for 1080p width
          const scaleX = sourceImage.width / 1080;
          const scaled1080 = 1080 * scaleX;

          // --- Draw Camera Face Viewport (Right Side - W: 720, H: 720) ---
          const syCam = config.cameraYStart * scaleX;
          const shCam = config.cameraHeight * scaleX;
          ctx.drawImage(sourceImage, 0, syCam, scaled1080, shCam, 560, 0, 720, 720);

          // --- Draw Left Column (Logo + Prompts - W: 480) ---
          const leftColWidth = 480;
          const leftColX = 40; // 40px padding from left edge
          const gap = 30; // 30px gap between the logo and prompts
          
          const destHLogo = (config.logoHeight / 1080) * leftColWidth;
          const destHPrompts = (config.promptsHeight / 1080) * leftColWidth;
          
          // Auto-center vertically based on the snip heights provided
          const totalLeftHeight = destHLogo + gap + destHPrompts;
          const startY = Math.max(20, (720 - totalLeftHeight) / 2);

          // Logo Snip
          const syLogo = config.logoYStart * scaleX;
          const shLogo = config.logoHeight * scaleX;
          ctx.drawImage(sourceImage, 0, syLogo, scaled1080, shLogo, leftColX, startY, leftColWidth, destHLogo);

          // Prompts Snip
          const syPrompts = config.promptsYStart * scaleX;
          const shPrompts = config.promptsHeight * scaleX;
          ctx.drawImage(sourceImage, 0, syPrompts, scaled1080, shPrompts, leftColX, startY + destHLogo + gap, leftColWidth, destHPrompts);

          const stdBlob = await optimizeImage(stdCanvas, config.targetMB);
          setStandardThumb(URL.createObjectURL(stdBlob));
          setStandardSize(stdBlob.size);

        } catch (error) {
          console.error("Error generating thumbnails:", error);
          alert("Something went wrong during generation. Check the console.");
        } finally {
          setIsProcessing(false);
        }
      }, [sourceImage, config]);

      useEffect(() => {
        if (sourceImage) {
          generateThumbnails();
        }
      }, [sourceImage, generateThumbnails]);

      return (
        <div className="min-h-screen bg-slate-50 p-6 font-sans text-slate-800">
          <div className="max-w-6xl mx-auto space-y-8">
            
            <div className="text-center space-y-2">
              <h1 className="text-3xl font-extrabold tracking-tight text-slate-900">
                YouTube Thumbnail Maker <span className="text-indigo-600 text-lg align-top ml-2">V24.1</span>
              </h1>
              <p className="text-slate-500 max-w-xl mx-auto">
                Upload your standard 9:16 format screenshot (approx. 1080x1920) to automatically assemble the Game Board and Camera feed into a 16:9 Thumbnail.
              </p>
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
              
              <div className="space-y-6">
                <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                  <h2 className="text-lg font-semibold flex items-center gap-2 mb-4">
                    <UploadIcon className="w-5 h-5 text-indigo-500" />
                    Upload Image
                  </h2>
                  
                  <div 
                    className="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center cursor-pointer hover:bg-slate-50 transition-colors"
                    onClick={() => fileInputRef.current?.click()}
                  >
                    <input 
                      type="file" 
                      className="hidden" 
                      accept="image/*" 
                      ref={fileInputRef}
                      onChange={handleImageUpload}
                    />
                    <ImageIcon className="w-10 h-10 text-slate-400 mx-auto mb-3" />
                    <p className="text-sm font-medium text-slate-600">Click to browse or drag image here</p>
                    <p className="text-xs text-slate-400 mt-1">Recommended: 1080x1920 px</p>
                  </div>

                  {sourceImage && (
                    <div className="mt-4">
                      <p className="text-xs text-green-600 font-semibold mb-2 flex items-center gap-1">
                        ✓ Image Loaded ({sourceImage.width}x{sourceImage.height})
                      </p>
                      <button 
                        onClick={generateThumbnails}
                        disabled={isProcessing}
                        className="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg flex items-center justify-center gap-2 transition-colors disabled:opacity-70"
                      >
                        {isProcessing ? <RefreshIcon className="w-4 h-4 animate-spin" /> : <RefreshIcon className="w-4 h-4" />}
                        {isProcessing ? 'Processing...' : 'Regenerate'}
                      </button>
                    </div>
                  )}
                </div>

                <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                  <h2 className="text-lg font-semibold flex items-center gap-2 mb-4">
                    <SettingsIcon className="w-5 h-5 text-slate-500" />
                    Coordinate Builder
                  </h2>
                  <p className="text-xs text-slate-500 mb-4 leading-relaxed">
                    Adjust the pixel coordinates if your screenshot layout shifts. Assumes a 1080x1920 native capture scale.
                  </p>
                  
                  <div className="space-y-4">
                    
                    {/* CAMERA */}
                    <div className="bg-slate-50 p-3 rounded-xl border border-slate-200">
                      <h3 className="text-[11px] font-black uppercase text-slate-700 tracking-widest mb-2 border-b border-slate-200 pb-1">Camera Feed Snip</h3>
                      <div className="grid grid-cols-2 gap-3">
                        <div>
                          <label className="block text-[10px] font-bold text-slate-500 uppercase mb-1">Start Pos (Y)</label>
                          <input 
                            type="number" 
                            className="w-full text-sm font-semibold text-slate-700 p-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                            value={config.cameraYStart}
                            onChange={e => setConfig({...config, cameraYStart: parseInt(e.target.value) || 0})}
                          />
                        </div>
                        <div>
                          <label className="block text-[10px] font-bold text-slate-500 uppercase mb-1">Height Area</label>
                          <input 
                            type="number" 
                            className="w-full text-sm font-semibold text-slate-700 p-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                            value={config.cameraHeight}
                            onChange={e => setConfig({...config, cameraHeight: parseInt(e.target.value) || 0})}
                          />
                        </div>
                      </div>
                    </div>

                    {/* PROMPTS */}
                    <div className="bg-slate-50 p-3 rounded-xl border border-slate-200">
                      <h3 className="text-[11px] font-black uppercase text-slate-700 tracking-widest mb-2 border-b border-slate-200 pb-1">Prompts Grid Snip</h3>
                      <div className="grid grid-cols-2 gap-3">
                        <div>
                          <label className="block text-[10px] font-bold text-slate-500 uppercase mb-1">Start Pos (Y)</label>
                          <input 
                            type="number" 
                            className="w-full text-sm font-semibold text-slate-700 p-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                            value={config.promptsYStart}
                            onChange={e => setConfig({...config, promptsYStart: parseInt(e.target.value) || 0})}
                          />
                        </div>
                        <div>
                          <label className="block text-[10px] font-bold text-slate-500 uppercase mb-1">Height Area</label>
                          <input 
                            type="number" 
                            className="w-full text-sm font-semibold text-slate-700 p-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                            value={config.promptsHeight}
                            onChange={e => setConfig({...config, promptsHeight: parseInt(e.target.value) || 0})}
                          />
                        </div>
                      </div>
                    </div>

                    {/* LOGO */}
                    <div className="bg-slate-50 p-3 rounded-xl border border-slate-200">
                      <h3 className="text-[11px] font-black uppercase text-slate-700 tracking-widest mb-2 border-b border-slate-200 pb-1">Date/Logo Snip</h3>
                      <div className="grid grid-cols-2 gap-3">
                        <div>
                          <label className="block text-[10px] font-bold text-slate-500 uppercase mb-1">Start Pos (Y)</label>
                          <input 
                            type="number" 
                            className="w-full text-sm font-semibold text-slate-700 p-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                            value={config.logoYStart}
                            onChange={e => setConfig({...config, logoYStart: parseInt(e.target.value) || 0})}
                          />
                        </div>
                        <div>
                          <label className="block text-[10px] font-bold text-slate-500 uppercase mb-1">Height Area</label>
                          <input 
                            type="number" 
                            className="w-full text-sm font-semibold text-slate-700 p-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                            value={config.logoHeight}
                            onChange={e => setConfig({...config, logoHeight: parseInt(e.target.value) || 0})}
                          />
                        </div>
                      </div>
                    </div>

                  </div>
                </div>
              </div>

              <div className="lg:col-span-2 space-y-6">
                
                <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                  <div className="flex justify-between items-end mb-4">
                    <div>
                      <h2 className="text-lg font-semibold text-slate-900">Standard Thumbnail</h2>
                      <p className="text-sm text-slate-500">1280 x 720 • 16:9 Aspect Ratio</p>
                    </div>
                    {standardThumb && (
                      <div className="text-right">
                        <p className="text-xs font-medium text-slate-500 mb-1">Size: <span className={standardSize > 2 * 1024 * 1024 ? 'text-red-500' : 'text-green-600'}>{formatMB(standardSize)}</span></p>
                        <a 
                          href={standardThumb} 
                          download="mic_check_standard_thumbnail.jpg"
                          className="bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium py-1.5 px-4 rounded-lg inline-flex items-center gap-1.5 transition-colors"
                        >
                          <DownloadIcon className="w-4 h-4" /> Download
                        </a>
                      </div>
                    )}
                  </div>
                  
                  <div className="bg-slate-100 rounded-xl overflow-hidden aspect-video relative flex items-center justify-center border border-slate-200 shadow-inner">
                    {standardThumb ? (
                      <img src={standardThumb} alt="Standard Thumbnail" className="w-full h-full object-contain" />
                    ) : (
                      <p className="text-slate-400 text-sm font-medium">Upload an image to generate</p>
                    )}
                  </div>
                </div>

                <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                  <div className="flex justify-between items-end mb-4">
                    <div>
                      <h2 className="text-lg font-semibold text-slate-900">Shorts Thumbnail</h2>
                      <p className="text-sm text-slate-500">1080 x 1920 • 9:16 Aspect Ratio</p>
                    </div>
                    {shortsThumb && (
                      <div className="text-right">
                        <p className="text-xs font-medium text-slate-500 mb-1">Size: <span className={shortsSize > 2 * 1024 * 1024 ? 'text-red-500' : 'text-green-600'}>{formatMB(shortsSize)}</span></p>
                        <a 
                          href={shortsThumb} 
                          download="mic_check_shorts_thumbnail.jpg"
                          className="bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium py-1.5 px-4 rounded-lg inline-flex items-center gap-1.5 transition-colors"
                        >
                          <DownloadIcon className="w-4 h-4" /> Download
                        </a>
                      </div>
                    )}
                  </div>
                  
                  <div className="bg-slate-100 rounded-xl overflow-hidden aspect-[9/16] w-64 mx-auto relative flex items-center justify-center border border-slate-200 shadow-inner">
                    {shortsThumb ? (
                      <img src={shortsThumb} alt="Shorts Thumbnail" className="w-full h-full object-contain" />
                    ) : (
                      <p className="text-slate-400 text-sm font-medium">Preview area</p>
                    )}
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
