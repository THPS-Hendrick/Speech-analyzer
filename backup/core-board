        let db, auth, currentUser;
        window.userScores = {}; // Global memory cache of scores

        // YOUR OFFICIAL FIREBASE CONFIG KEYS
        const firebaseConfig = {
            apiKey: "AIzaSyBOZBkKXHQvmyhpGPBj_Ca1kaaOcS4CFm0",
