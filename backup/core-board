        }

        function listenToScores() {
            if (!currentUser) return;
            const scoresRef = collection(db, 'users', currentUser.uid, 'micCheckScores');
            onSnapshot(scoresRef, (snapshot) => {
                window.userScores = {};
                snapshot.forEach(doc => {
                    window.userScores[doc.id] = doc.data(); 
                });
                window.renderMenuGrid(); 
            }, (error) => {
                console.error("Firestore error:", error);
            });
        }

        window.dbSaveScore = async function(dateStr, stars, score) {
            if (!currentUser || !db) return; 
            
            const existing = window.userScores[dateStr];
            let shouldSave = true;
            
            if (existing) {
                if (existing.stars > stars) shouldSave = false;
                if (existing.stars === stars && existing.score >= score) shouldSave = false;
            }

            if (shouldSave) {
                const docRef = doc(db, 'users', currentUser.uid, 'micCheckScores', dateStr);
                await setDoc(docRef, { stars: stars, score: score, timestamp: Date.now() });
            }
        };

        function getAdelaideDateObj() {
            const formatter = new Intl.DateTimeFormat('en-US', { 
                timeZone: 'Australia/Adelaide', year: 'numeric', month: '2-digit', day: '2-digit' 
            });
            const parts = formatter.formatToParts(new Date());
            const year = parseInt(parts.find(p => p.type === 'year').value);
            const month = parseInt(parts.find(p => p.type === 'month').value) - 1; // 0-indexed month
            const day = parseInt(parts.find(p => p.type === 'day').value);
            return new Date(year, month, day);
        }

        window.renderMenuGrid = function() {
            const gridEl = document.getElementById('menu-grid');
            const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            
            const startDate = new Date(2026, 0, 1);
            const todayObj = getAdelaideDateObj();
            const tomorrowObj = new Date(todayObj);
            tomorrowObj.setDate(tomorrowObj.getDate() + 1);
            
            let totalStars = 0;
            let goldenCount = 0;
            let htmlContent = '';
            
            let currentDate = new Date(startDate);
            
            while (currentDate <= tomorrowObj) {
                const yyyy = currentDate.getFullYear();
                const mm = String(currentDate.getMonth() + 1).padStart(2, '0');
                const dd = String(currentDate.getDate()).padStart(2, '0');
                const dateKey = `${yyyy}-${mm}-${dd}`;
                
                const isTomorrow = currentDate.getTime() === tomorrowObj.getTime();
                const isToday = currentDate.getTime() === todayObj.getTime();
                
                const displayStr = `${currentDate.getDate()} ${monthNames[currentDate.getMonth()]} '${String(yyyy).substring(2)}`;
                
                if (isTomorrow) {
                    htmlContent += `
                        <div class="flex flex-col items-center justify-center p-3 sm:p-4 bg-slate-100 rounded-xl shadow-inner border border-slate-200 opacity-60">
                            <span class="text-xs sm:text-sm font-bold text-slate-400 mb-3">${displayStr}</span>
                            <i data-lucide="lock" class="w-5 h-5 text-slate-400 mb-2"></i>
                            <span class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest text-center leading-tight">Check-in<br>Tomorrow</span>
                        </div>
                    `;
                } else {
                    const data = window.userScores[dateKey];
                    let stars = 0; 
                    let score = 0.0;
                    let scoreColor = 'text-slate-400';
                    
                    if (data) { 
                        stars = data.stars; 
                        score = data.score; 
                        
                        if (score === 10) {
                            goldenCount++;
                            scoreColor = 'text-yellow-400 drop-shadow-md font-black';
                        } else if (score >= 8.5) {
                            totalStars += stars; 
                            scoreColor = 'text-green-500';
                        } else if (score >= 7) {
                            scoreColor = 'text-orange-500';
                        } else {
                            scoreColor = 'text-yellow-500';
                        }
                    }

                    let starsHtml = '';
                    for (let s = 1; s <= 5; s++) {
                        if (s <= stars) {
                            starsHtml += `<i data-lucide="star" class="w-2 h-2 sm:w-3 sm:h-3 text-amber-500 fill-amber-500"></i>`;
                        } else {
                            starsHtml += `<i data-lucide="star" class="w-2 h-2 sm:w-3 sm:h-3 text-slate-300"></i>`;
                        }
                    }

                    const todayId = isToday ? 'id="btn-today"' : '';
                    const todayRing = isToday ? 'ring-2 ring-blue-400 ring-offset-2' : '';

                    htmlContent += `
                        <div ${todayId} onclick="openGameView('${dateKey}')" class="flex flex-col items-center justify-center p-3 sm:p-4 bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:-translate-y-1 transition-all cursor-pointer group ${todayRing}">
                            <span class="text-xs sm:text-sm font-bold text-slate-700 group-hover:text-blue-600 transition-colors mb-2">${displayStr}</span>
                            <div class="flex gap-0.5 mb-1">
                                ${starsHtml}
                            </div>
                            <span class="${scoreColor} text-lg sm:text-xl font-black">${score.toFixed(1)}</span>
                        </div>
                    `;
                }
                currentDate.setDate(currentDate.getDate() + 1);
            }
            
            gridEl.innerHTML = htmlContent;
            
            document.getElementById('star-count').innerText = totalStars;
            document.getElementById('golden-count').innerText = goldenCount;
            if (window.lucide) window.lucide.createIcons();

            setTimeout(() => {
                const todayBtn = document.getElementById('btn-today');
                const scrollContainer = document.getElementById('grid-scroll-container');
                if (todayBtn && scrollContainer) {
                    const containerRect = scrollContainer.getBoundingClientRect();
                    const btnRect = todayBtn.getBoundingClientRect();
                    const scrollPos = todayBtn.offsetTop - (containerRect.height / 2) + (btnRect.height / 2);
                    scrollContainer.scrollTo({ top: scrollPos, behavior: 'smooth' });
                }
            }, 300);
        };

        initFirebase();
    </script>

