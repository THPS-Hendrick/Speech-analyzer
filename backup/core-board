            activeContent.classList.remove('hidden');
            activeContent.classList.add('block');
        };

        // Listen for the Game Board changing difficulty
        window.addEventListener('thps-game-state', (e) => {
            currentGameStars = e.detail.stars;
        });

        window.openGameView = function(dateStr) {
            currentPlayDate = dateStr;
            document.getElementById('view-menu').classList.add('hidden');
            document.getElementById('view-game').classList.remove('hidden');
            window.scrollTo(0, 0);
            
            if (window.clearAnalyzer) window.clearAnalyzer();
            window.dispatchEvent(new CustomEvent('thps-load-date', { detail: { dateStr: dateStr } }));
        };

        window.closeGameView = function() {
            currentPlayDate = null;
            document.getElementById('view-game').classList.add('hidden');
            document.getElementById('view-menu').classList.remove('hidden');
            if (window.renderMenuGrid) window.renderMenuGrid(); 
            window.scrollTo(0, 0);
        };

        // ==========================================
        // DICTIONARIES
        // ==========================================
        const DICT_URLS = {
            simple: "https://raw.githubusercontent.com/THPS-Hendrick/Speech-analyzer/main/simple.json",
            visual: "https://raw.githubusercontent.com/THPS-Hendrick/Speech-analyzer/main/visualdict.json"
        };

        let personalPronouns = new Set(["i", "i'd", "i'll", "i'm", "i've", "he", "he'd", "he'll", "he's", "she", "she'd", "she'll", "she's"]);
        let visualDictPronouns = new Set();
        let visualDictWords = new Set();
        let simpleMap = new Map();
        let google10kSet = new Set();
        let dictsLoaded = false;

        async function loadDictionaries() {
            try {
                const fetchDict = async (url) => {
                    const res = await fetch(url + "?v=" + Date.now(), { cache: "no-store" });
                    return await res.json();
                };

                const [simpleData, visualData] = await Promise.all([
                    fetchDict(DICT_URLS.simple), fetchDict(DICT_URLS.visual)
                ]).catch(() => [{}, {}]);

                for (const [tier, words] of Object.entries(simpleData)) {
                    let t = tier.toLowerCase();
                    let finalTier = 'outside';
                    if (t.includes('5yr') || t.includes('5 yr')) finalTier = '5yr Old 1000';
                    else if (t.includes('esl')) finalTier = 'ESL 2000';
                    else if (t.includes('kitchen') || t.includes('kit')) finalTier = 'Kitchen 1000';
                    if (finalTier !== 'outside') words.forEach(w => simpleMap.set(w.toLowerCase(), finalTier));
                }

                const getFuzzyKey = (obj, keyword) => {
                    const key = Object.keys(obj).find(k => k.toLowerCase().includes(keyword));
                    return key ? obj[key] : null;
                };
                
                let vPronouns = getFuzzyKey(visualData, "pronoun");
                let vWords = getFuzzyKey(visualData, "visual");
                if (vPronouns) visualDictPronouns = new Set(vPronouns.map(w => w.toLowerCase()));
                if (vWords) visualDictWords = new Set(vWords.map(w => w.toLowerCase()));
                
                try {
                    const gRes = await fetch('https://cdn.jsdelivr.net/gh/first20hours/google-10000-english@master/google-10000-english-no-swears.txt');
                    if(gRes.ok) {
                        const gWords = (await gRes.text()).split('\n').map(w => w.trim().toLowerCase()).filter(w => w.length > 0);
                        google10kSet = new Set(gWords);
                    }
                } catch(e) { }

                dictsLoaded = true;
            } catch (e) { console.error("Dict Load Error", e); }
        }

        // ==========================================
        // PARALLEL CHUNKING ENGINE (RAW PCM/WAV)
        // ==========================================
        
        function floatTo16BitPCM(output, offset, input) {
            for (let i = 0; i < input.length; i++, offset += 2) {
                let s = Math.max(-1, Math.min(1, input[i]));
                output.setInt16(offset, s < 0 ? s * 0x8000 : s * 0x7FFF, true);
            }
        }

        function writeString(view, offset, string) {
            for (let i = 0; i < string.length; i++) view.setUint8(offset + i, string.charCodeAt(i));
        }

        function encodeWAV(samples, sampleRate) {
            let buffer = new ArrayBuffer(44 + samples.length * 2);
            let view = new DataView(buffer);
            writeString(view, 0, 'RIFF');
            view.setUint32(4, 36 + samples.length * 2, true);
            writeString(view, 8, 'WAVE');
            writeString(view, 12, 'fmt ');
            view.setUint32(16, 16, true);
            view.setUint16(20, 1, true); 
            view.setUint16(22, 1, true); 
            view.setUint32(24, sampleRate, true);
            view.setUint32(28, sampleRate * 2, true);
            view.setUint16(32, 2, true);
            view.setUint16(34, 16, true);
            writeString(view, 36, 'data');
            view.setUint32(40, samples.length * 2, true);
            floatTo16BitPCM(view, 44, samples);
            return new Blob([view], { type: 'audio/wav' });
        }

        let audioCtx = null;
        let sourceNode = null;
        let processorNode = null;
        let audioBuffers = [];
        let totalSamplesRecorded = 0;
        
        let isRecording = false;
        let recordStartTime = 0;
        let recordedAudio = false;
        window.lastRecordedDuration = 0; 
        let globalWordTimestamps = [];

        const inputEl = document.getElementById('cba-inputText');

        window.stopRecordingProcess = async function() {
            if (!isRecording) return;
            isRecording = false;
            
            document.getElementById('cba-recordingIndicator').classList.add('hidden');
            
            const procPanel = document.getElementById('cba-processing-panel');
            if (procPanel) {
                procPanel.classList.remove('hidden');
                procPanel.classList.add('flex');
            }
            
            const elapsedSecs = (Date.now() - recordStartTime) / 1000;
            window.lastRecordedDuration = elapsedSecs;
            recordedAudio = true;
            
            if (processorNode) { processorNode.disconnect(); processorNode = null; }
            if (sourceNode) { sourceNode.disconnect(); sourceNode = null; }
            if (window.audioStream) { window.audioStream.getTracks().forEach(t => t.stop()); }
            if (audioCtx && audioCtx.state !== 'closed') { audioCtx.close(); }

            let masterFloatArray = new Float32Array(totalSamplesRecorded);
            let writeOffset = 0;
            for(let i = 0; i < audioBuffers.length; i++) {
                masterFloatArray.set(audioBuffers[i], writeOffset);
                writeOffset += audioBuffers[i].length;
            }

            const sampleRate = 16000;
            const chunkSize = sampleRate * 30;
            let wavChunks = [];
            
            for(let i = 0; i < totalSamplesRecorded; i += chunkSize) {
                let segment = masterFloatArray.subarray(i, Math.min(i + chunkSize, totalSamplesRecorded));
                wavChunks.push(encodeWAV(segment, sampleRate));
            }

            const uploadPromises = wavChunks.map(async (blob, index) => {
                return new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.readAsDataURL(blob);
                    reader.onloadend = async () => {
                        const base64data = reader.result.split(',')[1];
                        try {
                            const response = await fetch('https://mic-check-backend.vercel.app/api/transcribe', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ audioContent: base64data, mimeType: 'audio/wav' })
                            });
                            
                            if (response.ok) {
                                const data = await response.json();
                                resolve({ index: index, transcript: data.transcript ? data.transcript.trim() : '', words: data.words || [] });
                            } else {
                                resolve({ index: index, transcript: '', words: [], error: `HTTP ${response.status}` });
                            }
                        } catch (e) {
                            resolve({ index: index, transcript: '', words: [], error: e.message });
                        }
                    };
                });
            });

            const errorMsgBox = document.getElementById('cba-errorMsg');
            if (errorMsgBox) errorMsgBox.classList.add('hidden');

            try {
                const resolvedChunks = await Promise.all(uploadPromises);
                resolvedChunks.sort((a, b) => a.index - b.index); 
                
                const finalStitchedTranscript = resolvedChunks
                    .map(r => r.transcript)
                    .filter(t => t.length > 0)
                    .join(' ');
                    
                globalWordTimestamps = [];
                resolvedChunks.forEach(chunk => {
                    if (chunk.words && chunk.words.length > 0) {
                        chunk.words.forEach(w => {
                            globalWordTimestamps.push({
                                word: w.word,
                                start: w.start + (chunk.index * 30),
                                end: w.end + (chunk.index * 30)
                            });
                        });
                    }
                });
                
                if (finalStitchedTranscript.length > 0) {
                    inputEl.value = finalStitchedTranscript;
                } else {
                    if (errorMsgBox) {
                        errorMsgBox.innerHTML = `<strong>Google Cloud Error:</strong> Failed to generate transcript from audio chunks.<br><span class="text-xs font-semibold text-red-600">Ensure microphone was clearly recording.</span>`;
                        errorMsgBox.classList.remove('hidden');
                    }
                    inputEl.value = "";
                }
            } catch (globalError) {
                if (errorMsgBox) {
                    errorMsgBox.innerHTML = `<strong>Delivery Pipeline Error:</strong> Vercel chunk processing failed.<br><span class="text-xs font-semibold text-red-600">Details: ${globalError.message}</span>`;
                    errorMsgBox.classList.remove('hidden');
                }
                inputEl.value = "";
            }
            
            if (procPanel) {
                procPanel.classList.remove('flex');
                procPanel.classList.add('hidden');
            }
            
            window.analyze();
            audioBuffers = []; masterFloatArray = null;
        };

        window.startRecordingProcess = async function() {
            isRecording = true;
            recordedAudio = true; 
            audioBuffers = [];
            totalSamplesRecorded = 0;
            recordStartTime = Date.now();
            globalWordTimestamps = [];
            
            document.getElementById('cba-recordingIndicator').classList.remove('hidden');

            try {
                window.audioStream = await navigator.mediaDevices.getUserMedia({ audio: { channelCount: 1 } });
                
                const AudioContextClass = window.AudioContext || window.webkitAudioContext;
                audioCtx = new AudioContextClass({ sampleRate: 16000 });
                
                sourceNode = audioCtx.createMediaStreamSource(window.audioStream);
                processorNode = audioCtx.createScriptProcessor(4096, 1, 1);
                
                processorNode.onaudioprocess = function(e) {
                    if (!isRecording) return;
                    
                    const channelData = e.inputBuffer.getChannelData(0);
                    audioBuffers.push(new Float32Array(channelData));
                    totalSamplesRecorded += channelData.length;
                    
                    if ((Date.now() - recordStartTime) >= 90000) {
                        clearInterval(gameTimerInterval);
                        isActive = false;
                        
                        // Stop the Segmented UI gracefully
                        const actionText = document.getElementById('toggle-text');
                        const btnIcon = document.getElementById('toggle-icon');
                        const actionBar = document.getElementById('action-bar');
                        if(actionText) actionText.innerText = 'TAP TO START GAME';
                        if(btnIcon) btnIcon.setAttribute('data-lucide', 'play');
                        if(actionBar) {
                            actionBar.classList.replace('bg-rose-600', 'bg-slate-800');
                            actionBar.classList.replace('hover:bg-rose-500', 'hover:bg-slate-700');
                        }
                        
                        if (window.lucide) window.lucide.createIcons();
                        window.stopRecordingProcess();
                    }
                };

                sourceNode.connect(processorNode);
                processorNode.connect(audioCtx.destination); 

            } catch (e) {
                console.warn("Microphone access denied or not supported.", e);
                const errorMsgBox = document.getElementById('cba-errorMsg');
                if (errorMsgBox) {
                    errorMsgBox.innerHTML = `<strong>Microphone Access Error:</strong> Please allow microphone access. <br><span class="text-xs font-normal">${e.message}</span>`;
                    errorMsgBox.classList.remove('hidden');
                }
                window.stopRecordingProcess();
                return;
            }
        };

        window.toggleTimerAndMic = function() {
            const actionText = document.getElementById('toggle-text');
            const btnIcon = document.getElementById('toggle-icon');
            const actionBar = document.getElementById('action-bar');
            const timerProgress = document.getElementById('timer-progress');
            
            if (isActive) {
                // STOP RECORDING
                clearInterval(gameTimerInterval);
                isActive = false;
                if(actionText) actionText.innerText = 'TAP TO START GAME';
                if(btnIcon) btnIcon.setAttribute('data-lucide', 'play');
                if(actionBar) {
                    actionBar.classList.replace('bg-rose-600', 'bg-slate-800');
                    actionBar.classList.replace('hover:bg-rose-500', 'hover:bg-slate-700');
                }
                window.stopRecordingProcess();
            } else {
                // START RECORDING
                isActive = true;
                if(actionText) actionText.innerText = 'TAP TO STOP';
                if(btnIcon) btnIcon.setAttribute('data-lucide', 'square');
                if(actionBar) {
                    actionBar.classList.replace('bg-slate-800', 'bg-rose-600');
                    actionBar.classList.replace('hover:bg-slate-700', 'hover:bg-rose-500');
                }
                
                if(timerProgress) timerProgress.style.width = '0%';
                
                if (window.clearAnalyzer) window.clearAnalyzer();
                window.startRecordingProcess();
                
                if (gameTimerInterval) clearInterval(gameTimerInterval);
                gameTimerInterval = setInterval(() => {
                    const elapsedSecs = (Date.now() - recordStartTime) / 1000;
                    if (elapsedSecs >= 90) {
                        clearInterval(gameTimerInterval);
                        isActive = false;
                        if(actionText) actionText.innerText = 'TAP TO START GAME';
                        if(btnIcon) btnIcon.setAttribute('data-lucide', 'play');
                        if(actionBar) {
                            actionBar.classList.replace('bg-rose-600', 'bg-slate-800');
                            actionBar.classList.replace('hover:bg-rose-500', 'hover:bg-slate-700');
                        }
                        window.stopRecordingProcess();
                        if (window.lucide) window.lucide.createIcons();
                    } else {
                        if(timerProgress) timerProgress.style.width = `${(elapsedSecs / 90) * 100}%`;
                    }
                }, 50);
            }
            if (window.lucide) window.lucide.createIcons();
        };

        // ==========================================
        // ANALYZER PROCESSING ENGINE
        // ==========================================
        let reportMarkdownText = "";

        function countSyllables(word) {
            word = word.toLowerCase().replace(/[^a-z]/g, '');
            if (word.length <= 3) return 1;
            word = word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
            word = word.replace(/^y/, '');
            const syllables = word.match(/[aeiouy]{1,2}/g);
            return syllables ? syllables.length : 1;
        }

        function updateCelebrationPanel(totalPoints, totalSecs, overrideGrade, recordedAudio, textLength) {
            const panel = document.getElementById('celebration-panel');
            const comment = document.getElementById('celeb-comment');
            const gradeEl = document.getElementById('celeb-grade');
            const timeEl = document.getElementById('celeb-time');

            if (!recordedAudio && totalSecs === 0 && textLength === 0) {
                panel.classList.add('hidden', 'scale-95', 'opacity-0');
                return;
            }

            panel.classList.remove('hidden');
            setTimeout(() => {
                panel.classList.remove('scale-95', 'opacity-0');
                panel.classList.add('scale-100', 'opacity-100');
            }, 50);

            let finalScore = totalPoints % 1 === 0 ? totalPoints : totalPoints.toFixed(2);
            gradeEl.textContent = overrideGrade ? "- / 10" : `${finalScore} / 10`;
            timeEl.textContent = totalSecs > 0 ? `${totalSecs.toFixed(0)}s` : "-";

            panel.className = "w-full max-w-4xl mx-auto mt-2 mb-10 rounded-3xl shadow-xl p-8 text-center transform transition-all duration-500 scale-100 opacity-100 border border-slate-200";
            
            document.getElementById('celeb-label-grade').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-slate-500";
            document.getElementById('celeb-label-time').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-slate-500";
            document.getElementById('celeb-divider').className = "w-px h-20 bg-slate-300 opacity-50";

            if (totalSecs < 30 && recordedAudio) {
                comment.textContent = "You spoke under 30 seconds";
                panel.classList.add('bg-slate-200', 'text-slate-800');
            } else if (totalSecs > 90 && recordedAudio) {
                comment.textContent = "You spoke over 90 seconds";
                panel.classList.add('bg-slate-200', 'text-slate-800');
            } else {
                panel.classList.remove('border-slate-200');
                panel.classList.add('text-white');
                document.getElementById('celeb-label-grade').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-white/90";
                document.getElementById('celeb-label-time').className = "font-bold uppercase tracking-widest text-xs mb-1 opacity-80 text-white/90";
                document.getElementById('celeb-divider').className = "w-px h-20 bg-white/40";

                if (!overrideGrade) {
                    if (totalPoints >= 8.5) {
                        comment.textContent = "Wow! Those are some nice scores!";
                        panel.classList.add('bg-gradient-to-br', 'from-emerald-600', 'to-teal-800');
                    } else if (totalPoints >= 7) {
                        comment.textContent = "Well said! Check out those scores";
                        panel.classList.add('bg-gradient-to-br', 'from-blue-600', 'to-indigo-800');
                    } else {
                        comment.textContent = "Check your scores and have another go!";
                        panel.classList.add('bg-gradient-to-br', 'from-amber-500', 'to-orange-700');
                    }
                } else {
                    comment.textContent = "Check your scores and have another go!";
                    panel.classList.add('bg-gradient-to-br', 'from-slate-600', 'to-slate-800');
                }
            }
        }

        window.analyze = function() {
            if (!dictsLoaded) return;
            const text = inputEl.value.trim();
            
            if (!text) {
                updateCelebrationPanel(0, 0, true, false, 0); 
                window.dispatchEvent(new CustomEvent('thps-dashboard-update', { detail: { text: "" } }));
                return;
            }

            const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
            const words = text.split(/\s+/).filter(w => w.trim().length > 0);
            const letterCount = text.replace(/[^a-zA-Z]/g, '').length;
            
            let totalSyllables = 0; let complexWordCount = 0;
            let personalCount = 0; let visualCount = 0;
            let simpleCounts = { '5yr Old 1000': 0, 'ESL 2000': 0, 'Kitchen 1000': 0, 'outside': 0 };
            let google10kCount = 0;

            let highlightedHTML = ""; reportMarkdownText = ""; 
            let inQuotes = false;
            
            let useFallback = true;
            if (typeof window.nlp === 'function') {
                try {
                    let doc = window.nlp(text);
                    try { doc.compute('root'); } catch(e) {} 
                    const jsonDoc = doc.json({ terms: true }); 
                    
                    for (let sIdx = 0; sIdx < jsonDoc.length; sIdx++) {
                        const sentence = jsonDoc[sIdx];
                        if (!sentence.terms) continue; 
                        let personalCountdown = 0; let visualCountdown = 0; 

                        for (let tIdx = 0; tIdx < sentence.terms.length; tIdx++) {
                            const term = sentence.terms[tIdx];
                            let rawText = term.text || ""; let rawPre = term.pre || ""; let rawPost = term.post || "";
                            let rawRoot = term.root || term.normal || rawText;

                            let root = String(rawRoot).toLowerCase().replace(/[^a-z]/g, '');
                            let normal = String(term.normal || rawText).toLowerCase().replace(/[^a-z']/g, ''); 
                            
                            if (rawPre.includes('"') || rawPre.includes('“') || rawText.includes('“') || rawText.startsWith('"')) inQuotes = true;
                            if (personalPronouns.has(normal)) personalCountdown = 6;
                            if (!personalPronouns.has(normal)) {
                                if (visualDictPronouns.has(normal) || visualDictWords.has(normal) || visualDictWords.has(root)) {
                                    visualCountdown = Math.max(visualCountdown, 4);
                                }
                            }

                            let isPersonal = (inQuotes || personalCountdown > 0);
                            let isVisual = (visualCountdown > 0); 

                            if (personalCountdown > 0) personalCountdown--;
                            if (visualCountdown > 0) visualCountdown--;
                            if (/[.!?]/.test(rawText) || /[.!?]/.test(rawPost)) { visualCountdown = 0; personalCountdown = 0; }
                            if (rawPost.includes('"') || rawPost.includes('”') || rawText.includes('”') || rawText.endsWith('"')) inQuotes = false;

                            let safePre = rawPre.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                            let safePost = rawPost.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                            let safeText = rawText.replace(/</g, "&lt;").replace(/>/g, "&gt;");

                            if (/[a-zA-Z]/.test(rawText)) {
                                if (isPersonal && isVisual) {
                                    highlightedHTML += `${safePre}<span class="overlap-word">${safeText}</span>${safePost}`;
                                    reportMarkdownText += `${rawPre}_**${rawText}**_${rawPost}`;
                                    personalCount++; visualCount++;
                                } else if (isPersonal) {
                                    highlightedHTML += `${safePre}<span class="personal-word">${safeText}</span>${safePost}`;
                                    reportMarkdownText += `${rawPre}**${rawText}**${rawPost}`;
                                    personalCount++;
                                } else if (isVisual) {
                                    highlightedHTML += `${safePre}<span class="visual-word">${safeText}</span>${safePost}`;
                                    reportMarkdownText += `${rawPre}_${rawText}_${rawPost}`;
                                    visualCount++;
                                } else {
                                    highlightedHTML += `${safePre}${safeText}${safePost}`;
                                    reportMarkdownText += `${rawPre}${rawText}${rawPost}`;
                                }
                            } else {
                                highlightedHTML += `${safePre}${safeText}${safePost}`;
                                reportMarkdownText += `${rawPre}${rawText}${rawPost}`;
                            }
                        }
                    }
                    useFallback = false;
                } catch(e) { useFallback = true; }
            }

            if (useFallback) {
                let tokens = text.split(/([a-zA-Z']+)/);
                let personalCountdown = 0; let visualCountdown = 0;
                tokens.forEach(token => {
                    if (/[.!?]/.test(token)) { visualCountdown = 0; personalCountdown = 0; inQuotes = false; }
                    if (/[a-zA-Z]/.test(token)) {
                        let normal = token.toLowerCase().replace(/[^a-z']/g, '');
                        let root = normal.replace(/(?:s|es|ed|ing)$/, ''); 
                        if (personalPronouns.has(normal)) personalCountdown = 6;
                        if (!personalPronouns.has(normal) && (visualDictPronouns.has(normal) || visualDictWords.has(normal) || visualDictWords.has(root))) {
                            visualCountdown = Math.max(visualCountdown, 4);
                        }
                        let isPersonal = (inQuotes || personalCountdown > 0);
                        let isVisual = (visualCountdown > 0);
                        if (personalCountdown > 0) personalCountdown--;
                        if (visualCountdown > 0) visualCountdown--;

                        let safeText = token.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                        if (isPersonal && isVisual) { highlightedHTML += `<span class="overlap-word">${safeText}</span>`; reportMarkdownText += `_**${token}**_`; personalCount++; visualCount++; } 
                        else if (isPersonal) { highlightedHTML += `<span class="personal-word">${safeText}</span>`; reportMarkdownText += `**${token}**`; personalCount++; } 
                        else if (isVisual) { highlightedHTML += `<span class="visual-word">${safeText}</span>`; reportMarkdownText += `_${token}_`; visualCount++; } 
                        else { highlightedHTML += safeText; reportMarkdownText += token; }
                    } else {
                        let quoteMatches = (token.match(/["“”]/g) || []).length;
                        if (quoteMatches % 2 !== 0) inQuotes = !inQuotes;
                        highlightedHTML += token.replace(/</g, "&lt;").replace(/>/g, "&gt;"); reportMarkdownText += token;
                    }
                });
            }

            words.forEach(word => {
                let cleanWord = word.toLowerCase().replace(/[^a-z']/g, '');
                let syl = countSyllables(cleanWord);
                totalSyllables += syl;
                if (syl >= 3) complexWordCount++;
                if (cleanWord.length > 0) {
                    if (google10kSet.has(cleanWord)) google10kCount++;
                    let sTier = simpleMap.get(cleanWord);
                    if (!sTier && typeof window.nlp === 'function') {
                        try {
                            let doc = window.nlp(cleanWord).compute('root').json();
                            if (doc.length > 0 && doc[0].terms.length > 0) {
                                let rootWord = doc[0].terms[0].root || doc[0].terms[0].normal;
                                if (rootWord) sTier = simpleMap.get(rootWord);
                            }
                        } catch(e) {}
                    }
                    simpleCounts[sTier || 'outside']++;
                }
            });

            const numSentences = Math.max(1, sentences.length);
            const numWords = Math.max(1, words.length);

            let elapsedSecs = recordedAudio ? (window.lastRecordedDuration || 0) : 0;
            let transcribedDuration = Math.min(90, elapsedSecs);
            
            let mumbleScore = 0; 
            let estimatedPauseTime = 0; 
            let pausePercent = 0; 
            let avgWpm = 0;
            let activeSpeakingSecs = 0;

            if (recordedAudio && elapsedSecs > 0) {
                const periods = (text.match(/[.!?]/g) || []).length;
                const commas = (text.match(/[,;:-]/g) || []).length;
                
                estimatedPauseTime = (periods * 1.3) + (commas * 0.5); 
                
                let minAllowedPause = transcribedDuration * 0.10;
                let maxAllowedPause = transcribedDuration * 0.40;
                if (estimatedPauseTime < minAllowedPause) estimatedPauseTime = minAllowedPause;
                if (estimatedPauseTime > maxAllowedPause) estimatedPauseTime = maxAllowedPause;
                
                activeSpeakingSecs = transcribedDuration - estimatedPauseTime;
                pausePercent = (estimatedPauseTime / transcribedDuration) * 100;
                
                avgWpm = Math.round((numWords / transcribedDuration) * 60);
                mumbleScore = totalSyllables / activeSpeakingSecs;
            }

            let flesch = Math.max(0, (0.39 * (numWords / numSentences)) + (11.8 * (totalSyllables / numWords)) - 15.59);
            let fog = Math.max(0, 0.4 * ((numWords / numSentences) + 100 * (complexWordCount / numWords)));
            let smog = Math.max(0, 1.0430 * Math.sqrt(complexWordCount * (30 / numSentences)) + 3.1291);
            let coleman = Math.max(0, 0.0588 * ((letterCount / numWords) * 100) - 0.296 * ((numSentences / numWords) * 100) - 15.8);
            let avgGrade = (flesch + fog + smog + coleman) / 4;

            let personalPercent = Math.round((personalCount / numWords) * 100);
            let visualPercent = Math.round((visualCount / numWords) * 100);
            let intangiblePercent = Math.max(0, 100 - personalPercent - visualPercent);

            let avgWpsFloat = numSentences > 0 ? (numWords / numSentences) : 0;
            
            let s5yrPct = Math.round((simpleCounts['5yr Old 1000'] / numWords) * 100) || 0;
            let sEslPct = Math.round((simpleCounts['ESL 2000'] / numWords) * 100) || 0;
            let sKitPct = Math.round((simpleCounts['Kitchen 1000'] / numWords) * 100) || 0;
            let coreSimpleScore = s5yrPct + sEslPct + sKitPct; 

            try {
                let totalPoints = 0;
                let overrideGrade = false;

                if (recordedAudio && elapsedSecs > 0) {
                    if (elapsedSecs < 30) overrideGrade = true; 
                    else if (elapsedSecs < 60) totalPoints += 0.75; 
                    else if (elapsedSecs <= 90) totalPoints += 1.0; 
                    else overrideGrade = true;

                    if (avgWpm < 100) totalPoints += 0.75; 
                    else if (avgWpm > 150) totalPoints += 0.25; 
                    else totalPoints += 1;

                    if (mumbleScore < 3) totalPoints += 0.75; 
                    else if (mumbleScore > 5) totalPoints += 0.25; 
                    else totalPoints += 1;

                    if (pausePercent < 10) totalPoints += 0.25; 
                    else if (pausePercent > 30) totalPoints += 0.75; 
                    else totalPoints += 1;
                } else {
                    overrideGrade = true;
                }

                if (personalPercent < 30) totalPoints += 0.25; 
                else if (personalPercent > 60) totalPoints += 0.75; 
                else totalPoints += 1;

                if (visualPercent < 20) totalPoints += 0.25; 
                else if (visualPercent > 50) totalPoints += 0.75; 
                else totalPoints += 1;

                if (intangiblePercent > 45) totalPoints += 0.25; 
                else if (intangiblePercent >= 30) totalPoints += 0.75; 
                else totalPoints += 1;

                if (avgWpsFloat < 5) totalPoints += 0.75; 
                else if (avgWpsFloat > 15) totalPoints += 0.25; 
                else totalPoints += 1;

                if (avgGrade < 5) totalPoints += 0.75; 
                else if (avgGrade > 10) totalPoints += 0.25; 
                else totalPoints += 1;

                if (coreSimpleScore < 85) totalPoints += 0.25; 
                else if (coreSimpleScore > 95) totalPoints += 0.75; 
                else totalPoints += 1;

                updateCelebrationPanel(totalPoints, elapsedSecs, overrideGrade, recordedAudio, text.length);

                if (window.dbSaveScore && currentPlayDate && !overrideGrade) {
                    window.dbSaveScore(currentPlayDate, currentGameStars, totalPoints);
                }

                // THE TRACKMAN BROADCAST TO UPDATE ALL WIDGETS
                window.dispatchEvent(new CustomEvent('thps-dashboard-update', { 
                    detail: { 
                        sps: mumbleScore,
                        wpm: avgWpm,
                        grade: avgGrade,
                        time: elapsedSecs,
                        personal: personalPercent,
                        visual: visualPercent,
                        text: text,
                        wordTimestamps: globalWordTimestamps || [],
                        volumeData: [], 
                        pause: pausePercent,
                        intangible: intangiblePercent,
                        wps: avgWpsFloat,
                        simple: coreSimpleScore,
                        totalPoints: totalPoints,
                        overrideGrade: overrideGrade,
                        recordedAudio: recordedAudio,
                        highlightedHTML: highlightedHTML,
                        reportMarkdownText: reportMarkdownText,
                        numWords: numWords,
                        numSentences: numSentences,
                        totalSyllables: totalSyllables,
                        google10kCount: google10kCount,
                        simpleCounts: simpleCounts,
                        readability: { flesch, fog, smog, coleman, avgGrade }
                    } 
                }));

            } catch(e) { console.error("Summary Dashboard Error:", e); }
        };

        window.clearAnalyzer = function() {
            inputEl.value = ''; 
            document.getElementById('celebration-panel').classList.add('hidden', 'scale-95', 'opacity-0');
            
            const procPanel = document.getElementById('cba-processing-panel');
            if (procPanel) {
                procPanel.classList.add('hidden');
                procPanel.classList.remove('flex');
            }
            
            recordedAudio = false; 
            window.analyze(); 
        };

        window.onload = () => {
            loadDictionaries();
            lucide.createIcons();
            if (window.renderMenuGrid) window.renderMenuGrid();
        };

    </script>
