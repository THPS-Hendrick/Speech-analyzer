<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Daily Mic-Check: Flipboard Concept V6 (Height Fix)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background-color: #e2e8f0; 
        }

        /* 3D Flipboard CSS */
        .perspective { perspective: 1200px; }
        
        .flipper {
            position: relative;
            width: 100%;
            height: 100%;
            transform-style: preserve-3d;
            transition: transform 0.7s cubic-bezier(0.4, 0.2, 0.2, 1);
        }

        .flip-active {
            transform: rotateX(180deg);
        }

        .face {
            position: absolute;
            inset: 0;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            border-radius: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }

        .face-front {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .face-back {
            transform: rotateX(180deg);
            background-color: #ffffff;
            border: 1px solid #cbd5e1;
        }

        /* Pulse animation for the timer processing state */
        @keyframes pulse-dark {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }
        .animate-pulse-dark { animation: pulse-dark 1.5s infinite; }
    </style>
</head>
<body class="flex flex-col items-center justify-center min-h-screen p-4">

    <div class="relative w-full max-w-[368px] aspect-[9/16] max-h-[850px] bg-slate-100 rounded-[2rem] shadow-2xl flex flex-col pt-6 pb-2.5 px-2 overflow-hidden">
        
        <div class="w-full grid grid-rows-5 gap-2 shrink-0 mb-3 perspective" style="height: 55%;">
            
            <div class="w-full h-full min-h-[3rem]">
                <div id="bar-1" class="flipper">
                    <div class="face face-front">
                        <span class="text-[13px] font-bold text-slate-600 uppercase tracking-widest"><strong class="text-blue-600">Bore us</strong> about</span>
                    </div>
                    <div class="face face-back bg-blue-50 border-blue-200 px-4 justify-between">
                        <span class="text-[12px] font-bold text-blue-700 tracking-wider">FINAL GRADE</span>
                        <div class="flex items-baseline gap-2">
                            <span class="text-[20px] font-black text-gray-800">8.8</span>
                            <span class="text-[12px] font-bold text-slate-500">/ 41s</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem]">
                <div id="bar-2" class="flipper">
                    <div class="face face-front">
                        <span class="text-[13px] font-bold text-slate-600 uppercase tracking-widest"><strong class="text-purple-600">Cardboard Boxes</strong>, with</span>
                    </div>
                    <div class="face face-back bg-slate-50 border-slate-200 px-4 justify-between">
                        <span class="text-[12px] font-bold text-slate-700 tracking-wider">CONTENT</span>
                        <div class="flex items-baseline gap-2">
                            <span class="text-[16px] font-black text-gray-800">37%</span>
                            <span class="text-[10px] font-bold text-slate-500">PER:9 VIS:37</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem]">
                <div id="bar-3" class="flipper">
                    <div class="face face-front">
                        <span class="text-[13px] font-bold text-slate-600 uppercase tracking-widest"><strong class="text-emerald-600">Cheap + Expensive</strong> examples,</span>
                    </div>
                    <div class="face face-back bg-slate-50 border-slate-200 px-4 justify-between">
                        <span class="text-[12px] font-bold text-slate-700 tracking-wider">DELIVERY</span>
                        <div class="flex items-baseline gap-2">
                            <span class="text-[16px] font-black text-gray-800">103 <span class="text-[10px] font-bold text-slate-500">WPM</span></span>
                            <span class="text-[10px] font-bold text-slate-500">MUM:2.9</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem]">
                <div id="bar-4" class="flipper">
                    <div class="face face-front">
                        <span class="text-[13px] font-bold text-slate-600 uppercase tracking-widest">and <strong class="text-red-600">Close your eyes!</strong></span>
                    </div>
                    <div class="face face-back bg-slate-50 border-slate-200 px-4 justify-between">
                        <span class="text-[12px] font-bold text-slate-700 tracking-wider">SIMPLICITY</span>
                        <div class="flex items-baseline gap-2">
                            <span class="text-[16px] font-black text-gray-800">7.8 <span class="text-[10px] font-bold text-slate-500">WPI</span></span>
                            <span class="text-[10px] font-bold text-slate-500">RDL:3.3</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem] cursor-pointer group" onclick="handleActionClick()">
                <div id="bar-5" class="flipper">
                    
                    <div id="action-btn-front" class="face face-front bg-[#1e293b] border-[#0f172a] text-white transition-colors duration-300 relative overflow-hidden">
                        
                        <div id="timer-progress" class="absolute left-0 top-0 bottom-0 w-0 bg-rose-600 transition-all duration-1000 ease-linear z-0"></div>
                        
                        <div class="relative w-full h-full z-10 pointer-events-none flex items-center justify-center py-2">
                            
                            <div id="star-1" class="absolute top-1/2 text-slate-600 transition-colors duration-300" style="left: 33.33%; transform: translate(-50%, -50%);">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                            </div>

                            <div class="text-white z-20">
                                <svg id="icon-play" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                <svg id="icon-stop" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
                                <svg id="icon-loader" class="hidden animate-spin" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
                            </div>

                            <div id="star-2" class="absolute top-1/2 text-slate-600 transition-colors duration-300" style="left: 66.66%; transform: translate(-50%, -50%);">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                            </div>

                        </div>
                    </div>

                    <div class="face face-back bg-white border-slate-200 px-2 text-center flex flex-col justify-center">
                        <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">Today's Prompt</span>
                        <span class="text-[11px] font-medium leading-tight text-slate-600">
                            Bore us about Cardboard Boxes, with Cheap + Expensive examples, and Close your eyes!
                        </span>
                    </div>
                </div>
            </div>

        </div>

        <div class="w-full flex-grow bg-[#111827] rounded-[1.25rem] relative overflow-hidden flex flex-col items-center justify-center border border-gray-800 shadow-inner">
            <div class="text-gray-600 flex flex-col items-center">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path><circle cx="12" cy="13" r="3"></circle></svg>
                <span id="camera-status" class="text-[12px] font-bold uppercase tracking-widest mt-2">CAMERA OFF</span>
            </div>
        </div>

    </div>

    <button onclick="resetGame()" class="mt-8 px-6 py-2 bg-slate-300 hover:bg-slate-400 text-slate-700 font-bold uppercase tracking-widest text-xs rounded-full shadow transition-all active:scale-95">
        Reset Flipboard
    </button>

    <script>
        let phase = 'START';
        let timerSeconds = 0;
        let timerInterval = null;
        
        // 30s max duration for testing
        const maxDurationSeconds = 30; 

        const btnFront = document.getElementById('action-btn-front');
        const timerProgress = document.getElementById('timer-progress');
        const star1 = document.getElementById('star-1');
        const star2 = document.getElementById('star-2');
        const iconPlay = document.getElementById('icon-play');
        const iconStop = document.getElementById('icon-stop');
        const iconLoader = document.getElementById('icon-loader');
        const cameraStatus = document.getElementById('camera-status');

        function handleActionClick() {
            if (phase === 'START') {
                phase = 'RECORDING';
                timerSeconds = 0;
                
                iconPlay.classList.add('hidden');
                iconStop.classList.remove('hidden');
                
                cameraStatus.innerHTML = '<span class="text-red-500 flex items-center gap-1"><span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span> REC</span>';

                timerInterval = setInterval(() => {
                    timerSeconds++;
                    
                    let progressPercent = Math.min((timerSeconds / maxDurationSeconds) * 100, 100);
                    timerProgress.style.width = progressPercent + '%';

                    if (progressPercent >= 33.33) {
                        star1.classList.replace('text-slate-600', 'text-amber-400');
                    }
                    if (progressPercent >= 66.66) {
                        star2.classList.replace('text-slate-600', 'text-amber-400');
                    }

                }, 1000);
            } 
            else if (phase === 'RECORDING') {
                phase = 'PROCESSING';
                clearInterval(timerInterval);
                
                btnFront.classList.add('animate-pulse-dark');
                iconStop.classList.add('hidden');
                iconLoader.classList.remove('hidden');
                
                cameraStatus.innerHTML = 'CAMERA OFF';

                setTimeout(revealFlipboard, 2000);
            }
        }

        function revealFlipboard() {
            phase = 'RESULTS';
            btnFront.classList.remove('animate-pulse-dark');

            for (let i = 1; i <= 5; i++) {
                setTimeout(() => {
                    document.getElementById(`bar-${i}`).classList.add('flip-active');
                }, i * 150); 
            }
        }

        function resetGame() {
            phase = 'START';
            clearInterval(timerInterval);
            
            for (let i = 1; i <= 5; i++) {
                document.getElementById(`bar-${i}`).classList.remove('flip-active');
            }

            setTimeout(() => {
                btnFront.classList.remove('animate-pulse-dark');
                timerProgress.style.width = '0%';
                
                star1.classList.replace('text-amber-400', 'text-slate-600');
                star2.classList.replace('text-amber-400', 'text-slate-600');
                
                iconLoader.classList.add('hidden');
                iconStop.classList.add('hidden');
                iconPlay.classList.remove('hidden');
                
                cameraStatus.innerHTML = 'CAMERA OFF';
            }, 300); 
        }
    </script>
</body>
</html>
