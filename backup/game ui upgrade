    <!-- Application Logic (Vanilla JS) -->
    <script>
        // State Variables
        let phase = 'START'; // START, RECORDING, PROCESSING, RESULTS
        let timerSeconds = 0;
        let timerInterval = null;

        // DOM Elements
        const btnMain = document.getElementById('main-action-btn');
        const actionBarContainer = document.getElementById('action-bar-container');
        
        const btnStart = document.getElementById('btn-state-start');
        const btnRecording = document.getElementById('btn-state-recording');
        const btnProcessing = document.getElementById('btn-state-processing');
        const btnSubtext = document.getElementById('btn-subtext');
        
        const timerDisplay = document.getElementById('timer-display');
        const cameraStatus = document.getElementById('camera-status');
        
        const statsContainer = document.getElementById('stats-container');
        const setupCards = document.getElementById('setup-cards');
        const setupCardElements = document.querySelectorAll('.setup-card');
        const labelText = document.querySelector('.label-text');
        const resultsCards = document.getElementById('results-cards');

        // Number Animation Function
        function animateValue(elementId, start, end, duration, decimals = 0) {
            const obj = document.getElementById(elementId);
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                // Ease out exponential
                const easeOut = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
                const current = (easeOut * end).toFixed(decimals);
                obj.innerHTML = current;
                if (progress < 1) {
                    window.requestAnimationFrame(step);
                } else {
                    obj.innerHTML = end.toFixed(decimals);
                }
            };
            window.requestAnimationFrame(step);
        }

        function formatTime(seconds) {
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
        }

        function handleActionClick() {
            if (phase === 'START') {
                startRecording();
            } else if (phase === 'RECORDING') {
                stopRecording();
            }
        }

        function startRecording() {
            phase = 'RECORDING';
            timerSeconds = 0;
            timerDisplay.innerText = "00:00";
            
            // UI Updates
            btnMain.classList.remove('bg-[#1e293b]');
            btnMain.classList.add('bg-red-500');
            
            btnStart.classList.add('hidden');
            btnStart.classList.remove('flex');
            
            btnRecording.classList.remove('hidden');
            btnRecording.classList.add('flex');
            
            btnSubtext.classList.add('hidden');
            btnSubtext.classList.remove('flex');

            cameraStatus.innerHTML = '<span class="text-red-500 flex items-center gap-1"><span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span> REC</span>';

            // Start Timer
            timerInterval = setInterval(() => {
                timerSeconds++;
                timerDisplay.innerText = formatTime(timerSeconds);
            }, 1000);
        }

        function stopRecording() {
            phase = 'PROCESSING';
            clearInterval(timerInterval);
            
            // UI Updates
            btnMain.classList.remove('bg-red-500');
            btnMain.classList.add('bg-[#1e293b]', 'cursor-not-allowed');
            btnMain.disabled = true;

            btnRecording.classList.add('hidden');
            btnRecording.classList.remove('flex');
            
            btnProcessing.classList.remove('hidden');
            btnProcessing.classList.add('flex');

            cameraStatus.innerHTML = 'CAMERA OFF';

            // Add dark pulse to setup cards
            setupCardElements.forEach(card => {
                card.classList.add('animate-pulse-dark');
                card.classList.remove('bg-blue-600', 'bg-white', 'bg-emerald-600', 'bg-gradient-to-b');
            });
            labelText.classList.add('opacity-0');

            // Simulate server processing time, then show results
            setTimeout(showResults, 2500);
        }

        function showResults() {
            phase = 'RESULTS';
            
            // Hide Action Bar (reclaims space)
            actionBarContainer.classList.add('hide-smooth');
            
            // Swap setup cards for results cards
            setupCards.classList.add('hidden');
            
            // Expand the stats container height
            statsContainer.classList.remove('h-[110px]');
            statsContainer.classList.add('h-[220px]'); // Expands to fit the 2x2 grid

            // Show results
            resultsCards.classList.remove('hidden');
            resultsCards.classList.add('flex');

            // Trigger Number Animations
            // delay matches the CSS animation delays
            setTimeout(() => animateValue("score-hero", 0, 8.8, 1800, 1), 100);
            setTimeout(() => animateValue("score-content", 0, 37, 1200, 0), 600);
            setTimeout(() => animateValue("score-delivery", 0, 103, 1200, 0), 1000);
            setTimeout(() => animateValue("score-simplify", 0, 7.8, 1200, 1), 1400);
            setTimeout(() => animateValue("score-time", 0, timerSeconds || 41, 1200, 0), 1800); // Use actual recorded time or fallback
        }

        function resetGame() {
            phase = 'START';
            
            // Reset UI
            actionBarContainer.classList.remove('hide-smooth');
            
            btnMain.classList.remove('cursor-not-allowed');
            btnMain.disabled = false;
            
            btnProcessing.classList.add('hidden');
            btnProcessing.classList.remove('flex');
            
            btnStart.classList.remove('hidden');
            btnStart.classList.add('flex');
            
            btnSubtext.classList.remove('hidden');
            btnSubtext.classList.add('flex');

            // Reset Cards Area
            statsContainer.classList.remove('h-[220px]');
            statsContainer.classList.add('h-[110px]');
            
            resultsCards.classList.add('hidden');
            resultsCards.classList.remove('flex');
            
            setupCards.classList.remove('hidden');
            
            // Restore Original Colors
            setupCardElements.forEach(card => card.classList.remove('animate-pulse-dark'));
            setupCardElements[0].classList.add('bg-blue-600');
            setupCardElements[1].classList.add('bg-white');
            setupCardElements[2].classList.add('bg-emerald-600');
            setupCardElements[3].classList.add('bg-gradient-to-b');
            labelText.classList.remove('opacity-0');

            // Reset scores text just in case
            document.getElementById('score-hero').innerText = "0.0";
            document.getElementById('score-content').innerText = "0";
            document.getElementById('score-delivery').innerText = "0";
            document.getElementById('score-simplify').innerText = "0.0";
            document.getElementById('score-time').innerText = "0";
        }
    </script>
</body>
</html>


