<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Daily Mic-Check: Logic Engine (V15)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background-color: #e2e8f0; 
        }

        .perspective { perspective: 1200px; }
        
        .flipper {
            position: relative;
            width: 100%;
            height: 100%;
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.4, 0.2, 0.2, 1);
        }

        .flip-active { transform: rotateX(180deg); }

        .face {
            position: absolute;
            inset: 0;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            border-radius: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }

        .face-front { background-color: #ffffff; border: 1px solid #e2e8f0; }
        .face-back { transform: rotateX(180deg); background-color: #f8fafc; border: 1px solid #cbd5e1; }
    </style>
</head>
<body class="flex flex-col items-center justify-center min-h-screen p-4">

    <div class="relative w-full max-w-[368px] aspect-[9/16] max-h-[850px] bg-slate-100 rounded-[2rem] shadow-2xl flex flex-col pt-6 pb-2.5 px-2 overflow-hidden">
        
        <div class="w-full grid grid-rows-5 gap-2 shrink-0 mb-3 perspective" style="height: 55%;">
            
            <div class="w-full h-full min-h-[3rem] cursor-pointer group" onclick="toggleFlip(1)">
                <div id="bar-1" class="flipper">
                    <div id="p1-front" class="face face-front"></div>
                    <div id="p1-back" class="face face-back"></div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem] cursor-pointer group" onclick="toggleFlip(2)">
                <div id="bar-2" class="flipper">
                    <div id="p2-front" class="face face-front"></div>
                    <div id="p2-back" class="face face-back"></div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem] cursor-pointer group" onclick="toggleFlip(3)">
                <div id="bar-3" class="flipper">
                    <div id="p3-front" class="face face-front"></div>
                    <div id="p3-back" class="face face-back"></div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem] cursor-pointer group" onclick="toggleFlip(4)">
                <div id="bar-4" class="flipper">
                    <div id="p4-front" class="face face-front"></div>
                    <div id="p4-back" class="face face-back"></div>
                </div>
            </div>

            <div class="w-full h-full min-h-[3rem] cursor-pointer group" onclick="toggleFlip(5)">
                <div id="bar-5" class="flipper">
                    <div id="p5-front" class="face face-front bg-[#1e293b] border-[#0f172a] text-white"></div>
                    <div id="p5-back" class="face face-back"></div>
                </div>
            </div>

        </div>

        <div class="w-full flex-grow bg-[#111827] rounded-[1.25rem] relative overflow-hidden flex flex-col items-center justify-center border border-gray-800 shadow-inner">
            <div class="text-gray-600 flex flex-col items-center">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path><circle cx="12" cy="13" r="3"></circle></svg>
                <span id="camera-status" class="text-[12px] font-bold uppercase tracking-widest mt-2">CAMERA OFF</span>
            </div>
        </div>

    </div>

    <button onclick="resetGame()" class="mt-8 px-6 py-2 bg-slate-300 hover:bg-slate-400 text-slate-700 font-bold uppercase tracking-widest text-xs rounded-full shadow transition-all active:scale-95">
        Reset Flow
    </button>

    <script>
        // --- STATE ENGINE ---
        let phase = 'START';
        let timerSeconds = 0;
        let timerInterval = null;
        let achievedStarStatus = 'empty'; 
        const maxDurationSeconds = 30; 
        
        let selections = { 1: 'A', 2: 'A', 3: 'A', 4: 'A' };
        
        // B-Side Drill-Down State Tracking
        let sideBLevel = 0; 
        let p5SoloFlipped = false;
        let currentCategory = ''; 
        let currentSubNum = 0; 

        // --- SVGs ---
        function createStar(type, size = 20, extraClass = "") {
            if (type === 'empty') {
                return `<svg class="${extraClass}" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`;
            } else if (type === 'half') {
                return `<svg class="${extraClass}" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon><polygon fill="currentColor" points="12 2 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`;
            } else {
                return `<svg class="${extraClass}" width="${size}" height="${size}" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`;
            }
        }
        const playSVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>`;
        const stopSVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>`;
        const chevRight = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>`;
        const chevLeft = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>`;

        // --- DATA DICTIONARIES ---
        const matrix = {
            1: { A: "Talk About", B: "Bore us about", colorA: "text-blue-600", colorB: "text-blue-600", finalA: "Final Grade", starA: createStar('empty', 18, 'text-slate-300'), starB: createStar('filled', 18, 'text-amber-400') },
            2: { A: "Cardboard boxes, with", B: "anything, with", colorA: "text-purple-600", colorB: "text-purple-600", finalA: "Content", starA: createStar('filled', 18, 'text-amber-400'), starB: createStar('empty', 18, 'text-slate-300') },
            3: { A: "any examples.", B: "Private + Public examples.", colorA: "text-emerald-600", colorB: "text-emerald-600", finalA: "Delivery", starA: createStar('empty', 18, 'text-slate-300'), starB: createStar('filled', 18, 'text-amber-400') },
            4: { A: "Have fun!", B: "Close eyes for 5 sec!", colorA: "text-red-600", colorB: "text-red-600", finalA: "Clarity", starA: createStar('empty', 18, 'text-slate-300'), starB: createStar('filled', 18, 'text-amber-400') }
        };

        const drillData = {
            Content: {
                score: "2/3",
                2: { name: "Personal", val: "35%", you: "used a good amount of 'I' and 'we'", try: "balancing with more objective facts", why: "connects you to the audience" },
                3: { name: "Visual", val: "10%", you: "didn't use many descriptions", try: "colours, sizes, objects, etc", why: "best speakers use 25%-40% visual words" },
                4: { name: "Abstract", val: "55%", you: "relied heavily on concepts", try: "grounding them in real-world examples", why: "makes ideas easier to grasp" }
            },
            Delivery: {
                score: "1/3",
                2: { name: "Pace", val: "103 WPM", you: "spoke a bit slowly", try: "speeding up to 130-150 WPM", why: "keeps audience attention" },
                3: { name: "Pauses", val: "2.9s", you: "had some long gaps", try: "using shorter, deliberate pauses", why: "creates emphasis without losing flow" },
                4: { name: "Filler", val: "12 words", you: "used 'um' and 'ah' frequently", try: "taking a breath instead of vocalizing", why: "sounds more confident and prepared" }
            },
            Clarity: {
                score: "3/3",
                2: { name: "Reading Lvl", val: "Grade 8", you: "hit the sweet spot for general audiences", try: "maintaining this consistency", why: "Grade 7-9 is globally accessible" },
                3: { name: "WPI", val: "7.8", you: "kept ideas punchy", try: "using short sentences for big impacts", why: "Words-Per-Idea under 10 is very clear" },
                4: { name: "Jargon", val: "Low", you: "avoided confusing industry terms", try: "always explaining acronyms if used", why: "prevents alienating listeners" }
            }
        };

        function getTodayDate() {
            const options = { day: 'numeric', month: 'short', year: 'numeric' };
            return new Date().toLocaleDateString('en-GB', options);
        }

        function buildPromptSentence() {
            const s1 = selections[1] === 'A' ? matrix[1].A : matrix[1].B;
            const s2 = selections[2] === 'A' ? matrix[2].A : matrix[2].B;
            const s3 = selections[3] === 'A' ? matrix[3].A : matrix[3].B;
            const s4 = selections[4] === 'A' ? matrix[4].A : matrix[4].B;
            return `${s1} ${s2} ${s3} ${s4}`;
        }

        // --- DRILL DOWN RENDERER (SIDE B ONLY) ---
        function renderSideB() {
            const p1 = document.getElementById('p1-back');
            const p2 = document.getElementById('p2-back');
            const p3 = document.getElementById('p3-back');
            const p4 = document.getElementById('p4-back');
            const p5 = document.getElementById('p5-back');

            const item = (text, icon) => `
                <div class="w-full h-full flex items-center justify-start pl-5 pr-10">
                    <span class="text-[13px] font-bold uppercase tracking-widest">${text}</span>
                </div>
                <span class="absolute right-3 pointer-events-none">${icon}</span>`;
            
            const feedbackItem = (label, text) => `
                <div class="w-full h-full flex items-center justify-start pl-5 pr-8">
                    <span class="text-[11px] font-medium leading-tight text-slate-600"><strong class="text-blue-600 uppercase text-[10px] tracking-widest">${label}:</strong> ${text}</span>
                </div>`;

            if (sideBLevel === 0) {
                p5.className = 'face face-back bg-slate-50 border-slate-200 text-slate-600';
                p5.innerHTML = `
                    <div class="w-full h-full flex items-center justify-start pl-5 pr-10 text-left">
                        <span class="text-[10px] font-medium leading-tight">${buildPromptSentence()}</span>
                    </div>
                    <span class="absolute right-3 text-slate-300">${chevLeft}</span>`;
            } 
            else if (sideBLevel === 1) {
                p1.className = 'face face-back bg-purple-600 border-purple-700 text-white';
                p1.innerHTML = item("Final Grade = 8.8", chevLeft);
                
                [p2, p3, p4].forEach((el, i) => el.className = 'face face-back bg-slate-50 border-slate-200 text-slate-700 group-hover:bg-slate-100 transition-colors');
                p2.innerHTML = item(`Content = ${drillData.Content.score}`, chevRight);
                p3.innerHTML = item(`Delivery = ${drillData.Delivery.score}`, chevRight);
                p4.innerHTML = item(`Clarity = ${drillData.Clarity.score}`, chevRight);
                
                p5.className = 'face face-back bg-slate-50 border-slate-200 text-slate-500 group-hover:bg-slate-100 transition-colors';
                p5.innerHTML = item(`Time = 41s`, chevLeft);
            } 
            else if (sideBLevel === 2) {
                const data = drillData[currentCategory];
                p1.className = 'face face-back bg-blue-600 border-blue-700 text-white';
                p1.innerHTML = item(`${currentCategory} = ${data.score}`, chevLeft);

                [p2, p3, p4].forEach((el, i) => el.className = 'face face-back bg-slate-50 border-slate-200 text-slate-700 group-hover:bg-slate-100 transition-colors');
                p2.innerHTML = item(`${data[2].name} = ${data[2].val}`, chevRight);
                p3.innerHTML = item(`${data[3].name} = ${data[3].val}`, chevRight);
                p4.innerHTML = item(`${data[4].name} = ${data[4].val}`, chevRight);

                p5.className = 'face face-back bg-slate-50 border-slate-200 text-slate-500 group-hover:bg-slate-100 transition-colors';
                p5.innerHTML = item(`Go back`, chevLeft);
            } 
            else if (sideBLevel === 3) {
                const data = drillData[currentCategory][currentSubNum];
                p1.className = 'face face-back bg-blue-600 border-blue-700 text-white';
                p1.innerHTML = item(`${data.name} = ${data.val}`, chevLeft);

                [p2, p3, p4].forEach(el => el.className = 'face face-back bg-slate-50 border-slate-200 text-slate-700');
                p2.innerHTML = feedbackItem('You', data.you);
                p3.innerHTML = feedbackItem('Try', data.try);
                p4.innerHTML = feedbackItem('Why', data.why);

                p5.className = 'face face-back bg-slate-50 border-slate-200 text-slate-500 group-hover:bg-slate-100 transition-colors';
                p5.innerHTML = item(`Go back`, chevLeft);
            }
        }

        // --- UI RENDERER (SIDE A & INITIAL SETUP) ---
        function renderPhase() {
            for (let i = 1; i <= 5; i++) {
                document.getElementById(`bar-${i}`).classList.remove('flip-active');
            }

            if (phase === 'START') {
                for (let i = 1; i <= 4; i++) {
                    // FIX: Explicitly reset standard classes so leftover colors (blue/purple) are removed on reset
                    document.getElementById(`p${i}-front`).className = 'face face-front bg-white border-slate-200 text-slate-700';
                    document.getElementById(`p${i}-back`).className = 'face face-back bg-slate-50 border-slate-200 text-slate-700';

                    document.getElementById(`p${i}-front`).innerHTML = `
                        <div class="w-full h-full flex items-center justify-start pl-5 pr-10">
                            <span class="text-[13px] font-bold text-slate-600 uppercase tracking-widest"><strong class="${matrix[i].colorA}">${matrix[i].A}</strong></span>
                        </div>
                        <span class="absolute right-3 pointer-events-none transition-transform group-hover:scale-110">${matrix[i].starA}</span>`;
                    
                    document.getElementById(`p${i}-back`).innerHTML = `
                        <div class="w-full h-full flex items-center justify-start pl-5 pr-10">
                            <span class="text-[13px] font-bold text-slate-600 uppercase tracking-widest"><strong class="${matrix[i].colorB}">${matrix[i].B}</strong></span>
                        </div>
                        <span class="absolute right-3 pointer-events-none transition-transform group-hover:scale-110">${matrix[i].starB}</span>`;
                }

                document.getElementById('p5-front').className = 'face face-front bg-[#1e293b] border-[#0f172a] text-white';
                document.getElementById('p5-front').innerHTML = `
                    <div id="timer-progress" class="absolute left-0 top-0 bottom-0 w-0 bg-rose-600 transition-all duration-1000 ease-linear z-0"></div>
                    <div class="relative w-full h-full z-10 pointer-events-none flex items-center justify-center">
                        <div id="star-1" class="absolute top-1/2 text-slate-600 transition-colors duration-300" style="left: 25%; transform: translate(-50%, -50%);">${createStar('half', 20)}</div>
                        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 pointer-events-auto cursor-pointer p-2.5 bg-white/10 hover:bg-white/25 rounded-full backdrop-blur-sm transition-all border border-white/10" onclick="handleActionClick(event)">
                            ${playSVG}
                        </div>
                        <div id="star-2" class="absolute top-1/2 text-slate-600 transition-colors duration-300" style="left: 75%; transform: translate(-50%, -50%);">${createStar('filled', 20)}</div>
                    </div>`;
                document.getElementById('p5-back').className = 'face face-back';
                document.getElementById('p5-back').innerHTML = ''; 
            } 
            
            else if (phase === 'RECORDING') {
                for (let i = 1; i <= 4; i++) {
                    const chosenText = selections[i] === 'A' ? matrix[i].A : matrix[i].B;
                    const chosenColor = selections[i] === 'A' ? matrix[i].colorA : matrix[i].colorB;
                    const chosenStar = selections[i] === 'A' ? matrix[i].starA : matrix[i].starB;
                    
                    document.getElementById(`p${i}-front`).innerHTML = `
                        <div class="w-full h-full flex items-center justify-start pl-5 pr-10">
                            <span class="text-[13px] font-bold text-slate-600 uppercase tracking-widest"><strong class="${chosenColor}">${chosenText}</strong></span>
                        </div>
                        <span class="absolute right-3 pointer-events-none">${chosenStar}</span>`;
                }

                document.getElementById('p5-front').innerHTML = `
                    <div id="timer-progress" class="absolute left-0 top-0 bottom-0 w-0 bg-rose-600 transition-all duration-1000 ease-linear z-0"></div>
                    <div class="relative w-full h-full z-10 pointer-events-none flex items-center justify-center">
                        <div id="star-1" class="absolute top-1/2 text-slate-600 transition-colors duration-300" style="left: 25%; transform: translate(-50%, -50%);">${createStar('half', 20)}</div>
                        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 pointer-events-auto cursor-pointer p-2.5 bg-white/10 hover:bg-white/25 rounded-full backdrop-blur-sm transition-all border border-white/10" onclick="handleActionClick(event)">
                            ${stopSVG}
                        </div>
                        <div id="star-2" class="absolute top-1/2 text-slate-600 transition-colors duration-300" style="left: 75%; transform: translate(-50%, -50%);">${createStar('filled', 20)}</div>
                    </div>`;
            }

            else if (phase === 'PROCESSING') {
                for (let i = 1; i <= 5; i++) {
                    document.getElementById(`p${i}-front`).className = 'face face-front bg-white border-slate-200';
                    document.getElementById(`p${i}-front`).innerHTML = `
                        <div class="w-full h-full flex items-center justify-start pl-5 pr-10 animate-pulse text-slate-500 font-bold uppercase tracking-widest text-[13px]">
                            Checking Scores
                        </div>`;
                }
            }

            else if (phase === 'RESULTS') {
                for (let i = 1; i <= 4; i++) {
                    document.getElementById(`p${i}-front`).className = 'face face-front bg-white border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors';
                    document.getElementById(`p${i}-front`).innerHTML = `
                        <div class="relative w-full h-full flex items-center justify-start pl-5 pr-10">
                            <span class="text-[13px] font-bold uppercase tracking-widest">${matrix[i].finalA}</span>
                            <div class="absolute text-amber-400" style="left: 75%; transform: translateX(-50%);">${createStar('filled', 20)}</div>
                        </div>
                        <span class="absolute right-3 text-slate-300 group-hover:text-slate-500 transition-colors pointer-events-none">${chevRight}</span>`;
                }

                document.getElementById('p5-front').className = 'face face-front bg-white border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors';
                document.getElementById('p5-front').innerHTML = `
                    <div class="relative w-full h-full flex items-center justify-start pl-5 pr-10">
                        <span class="text-[13px] font-bold uppercase tracking-widest">${getTodayDate()}</span>
                        <div class="absolute text-amber-400" style="left: 75%; transform: translateX(-50%);">${createStar(achievedStarStatus, 20)}</div>
                    </div>
                    <span class="absolute right-3 text-slate-300 group-hover:text-slate-500 transition-colors pointer-events-none">${chevRight}</span>`;
                
                sideBLevel = 0;
                renderSideB(); 
            }
        }

        // --- INTERACTION LOGIC ---
        function flipAll(toBack) {
            for (let i = 1; i <= 5; i++) {
                if (toBack) document.getElementById(`bar-${i}`).classList.add('flip-active');
                else document.getElementById(`bar-${i}`).classList.remove('flip-active');
            }
        }

        function toggleFlip(panelNum) {
            if (phase === 'RECORDING' || phase === 'PROCESSING') return;

            if (phase === 'START') {
                if (panelNum === 5) return; 
                document.getElementById(`bar-${panelNum}`).classList.toggle('flip-active');
                selections[panelNum] = document.getElementById(`bar-${panelNum}`).classList.contains('flip-active') ? 'B' : 'A';
            } 
            
            else if (phase === 'RESULTS') {
                if (sideBLevel === 0) {
                    if (panelNum >= 1 && panelNum <= 4) {
                        sideBLevel = 1;
                        renderSideB();
                        flipAll(true);
                        p5SoloFlipped = false;
                    } else if (panelNum === 5) {
                        p5SoloFlipped = !p5SoloFlipped;
                        document.getElementById('bar-5').classList.toggle('flip-active');
                    }
                } 
                else if (sideBLevel === 1) {
                    if (panelNum === 1 || panelNum === 5) {
                        sideBLevel = 0;
                        renderSideB(); 
                        flipAll(false);
                    } else {
                        sideBLevel = 2;
                        currentCategory = panelNum === 2 ? 'Content' : (panelNum === 3 ? 'Delivery' : 'Clarity');
                        renderSideB();
                    }
                } 
                else if (sideBLevel === 2) {
                    if (panelNum === 1 || panelNum === 5) {
                        sideBLevel = 1;
                        renderSideB();
                    } else {
                        sideBLevel = 3;
                        currentSubNum = panelNum;
                        renderSideB();
                    }
                } 
                else if (sideBLevel === 3) {
                    if (panelNum === 1 || panelNum === 5) {
                        sideBLevel = 2;
                        renderSideB();
                    }
                }
            }
        }

        function handleActionClick(event) {
            if (event) event.stopPropagation();

            if (phase === 'START') {
                phase = 'RECORDING';
                achievedStarStatus = 'empty'; 
                renderPhase(); 
                timerSeconds = 0;
                
                document.getElementById('camera-status').innerHTML = '<span class="text-red-500 flex items-center gap-1"><span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span> REC</span>';

                timerInterval = setInterval(() => {
                    timerSeconds++;
                    let progressPercent = Math.min((timerSeconds / maxDurationSeconds) * 100, 100);
                    
                    const tProg = document.getElementById('timer-progress');
                    const s1 = document.getElementById('star-1');
                    const s2 = document.getElementById('star-2');
                    
                    if (tProg) tProg.style.width = progressPercent + '%';
                    
                    if (progressPercent >= 25) {
                        if (s1) s1.classList.replace('text-slate-600', 'text-amber-400');
                        achievedStarStatus = 'half';
                    }
                    if (progressPercent >= 75) {
                        if (s2) s2.classList.replace('text-slate-600', 'text-amber-400');
                        achievedStarStatus = 'filled';
                    }
                }, 1000);
            } 
            else if (phase === 'RECORDING') {
                phase = 'PROCESSING';
                clearInterval(timerInterval);
                renderPhase(); 
                
                document.getElementById('camera-status').innerHTML = 'CAMERA OFF';

                setTimeout(() => {
                    phase = 'RESULTS';
                    renderPhase();
                }, 2000);
            }
        }

        function resetGame() {
            phase = 'START';
            clearInterval(timerInterval);
            selections = { 1: 'A', 2: 'A', 3: 'A', 4: 'A' };
            achievedStarStatus = 'empty';
            sideBLevel = 0;
            p5SoloFlipped = false;
            renderPhase(); 
            document.getElementById('camera-status').innerHTML = 'CAMERA OFF';
        }

        // Init
        renderPhase();
    </script>
</body>
</html>
