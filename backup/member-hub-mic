<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Mic-Check Members Hub</title>
    <!-- Tailwind CSS for Styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- UMD builds guaranteed to work globally on Squarespace -->
    <script src="https://unpkg.com/compromise@14.14.3/builds/compromise.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Permanent+Marker&display=swap');
        
        /* Game CSS */
        .preserve-3d { transform-style: preserve-3d; }
        .backface-hidden { backface-visibility: hidden; }
        .rotate-y-180 { transform: rotateY(180deg) !important; }
        .card-container { perspective: 1000px; }
        
        /* Star styling */
        .star-filled { fill: #eab308; color: #eab308; } 
        .star-empty { fill: transparent; color: #94a3b8; } 
        .star-hover { fill: #fde047 !important; color: #fde047 !important; } 

        /* Timer Pulse */
        @keyframes custom-pulse {
            0%, 100% { background-color: rgb(220 38 38); }
            50% { background-color: rgb(185 28 28); }
        }
        .time-up-bg { animation: custom-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; border-color: rgb(220 38 38) !important; }
        .time-up-text { color: white !important; }

        /* Timer Stage Colors */
        .timer-stage-1 { background-color: #dcfce7; border-color: #86efac; color: #166534; }
        .timer-stage-2 { background-color: #106030; border-color: #106030; color: white; }
        
        /* Analyzer CSS */
        #cba-wrapper { font-family: 'Inter', sans-serif; background-color: transparent; }
        #cba-wrapper .glass-panel { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border: 1px solid rgba(226, 232, 240, 0.8); }
        #cba-wrapper .score-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        @media (min-width: 1024px) { #cba-wrapper .score-card:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); } }

        /* Highlight Colors */
        #cba-wrapper .personal-word { color: #00B700; font-weight: 600; background-color: rgba(0, 183, 0, 0.1); padding: 0 2px; border-radius: 3px; }
        #cba-wrapper .visual-word { color: #ef4444; font-weight: 600; text-decoration: underline; text-decoration-color: #ef4444; text-underline-offset: 2px; background-color: rgba(239, 68, 68, 0.05); padding: 0 2px; border-radius: 3px; }
        #cba-wrapper .overlap-word { color: #ef4444; font-weight: 700; background-color: rgba(0, 183, 0, 0.15); border-bottom: 2px solid #ef4444; padding: 0 2px; border-radius: 3px; }
        
        /* Accordion Animations */
        .cba-accordion-content { transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out; max-height: 0; opacity: 0; overflow: hidden; }
        .cba-accordion-open { max-height: 500px; opacity: 1; margin-top: 1rem; }
        
        /* New Score Summary Alignments */
        .score-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.875rem; line-height: 1.25rem; }
        .score-label { color: #475569; flex: 1; }
        .score-value { font-weight: 700; color: #1e293b; width: 3rem; text-align: right; }
        .score-eval { font-size: 0.625rem; font-weight: 700; padding: 0.125rem 0.5rem; border-radius: 0.25rem; text-transform: uppercase; letter-spacing: 0.025em; width: 5.5rem; text-align: center; margin-left: 0.75rem; }

        /* Custom Scrollbar for Hub Menu */
        .styled-scrollbar::-webkit-scrollbar { width: 6px; }
        .styled-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .styled-scrollbar::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 20px; }

        #body-bg { overflow-x: hidden; width: 100%; box-sizing: border-box; font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="w-full mx-auto bg-slate-50 transition-colors duration-300 min-h-screen p-2 md:p-8 flex flex-col items-center justify-start" id="body-bg">

    <!-- ========================================== -->
    <!-- VIEW 1: MEMBERS HUB (MENU GRID)            -->
    <!-- ========================================== -->
    <div id="view-menu" class="w-full max-w-6xl mx-auto flex flex-col items-center animate-in fade-in duration-500">
        
        <div class="w-full flex flex-col items-center mb-8 px-2">
            <div class="flex flex-col items-center gap-1 text-center mb-6">
                <h1 class="text-4xl md:text-5xl uppercase tracking-wider text-slate-900" style="font-family: 'Permanent Marker', cursive;">
                    Members Hub
                </h1>
                <p class="text-xs md:text-sm text-slate-500 font-medium max-w-md mt-1">
                    Welcome back. Track your Daily Mic-Check progress below.<br>
                    <strong>(Score 8.5 or more to boost your Star Count!)</strong>
                </p>
                <div id="db-status" class="mt-2 text-[10px] font-bold px-3 py-1 bg-amber-100 text-amber-700 rounded-full animate-pulse">Connecting to Save Data...</div>
            </div>

            <!-- Gamification Score Panels -->
            <div class="flex justify-center gap-4 md:gap-12 w-full">
                <!-- Golden Mic Checks -->
                <div class="flex flex-col items-center bg-gradient-to-b from-yellow-50 to-amber-100 border border-amber-200 rounded-2xl p-3 shadow-sm w-36 md:w-44 transition-all hover:scale-105 hover:shadow-md">
                    <span class="text-[10px] md:text-xs font-black uppercase tracking-widest text-amber-700 text-center mb-1 leading-tight">Golden<br>Mic-Checks</span>
                    <span id="golden-count" class="text-3xl md:text-4xl font-black text-amber-600 drop-shadow-sm">0</span>
                </div>

                <!-- Star Count -->
                <div class="flex flex-col items-center bg-gradient-to-b from-slate-50 to-blue-50 border border-blue-200 rounded-2xl p-3 shadow-sm w-36 md:w-44 transition-all hover:scale-105 hover:shadow-md">
                    <span class="text-[10px] md:text-xs font-black uppercase tracking-widest text-blue-700 text-center mb-1 leading-tight">Total<br>Star Count</span>
                    <div class="flex items-center gap-1">
                        <i data-lucide="star" class="w-5 h-5 md:w-6 md:h-6 text-amber-500 fill-amber-500 drop-shadow-sm"></i>
                        <span id="star-count" class="text-3xl md:text-4xl font-black text-blue-800 drop-shadow-sm">0</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Scrollable 7-Column Grid -->
        <div class="w-full relative">
            <!-- Top Fade -->
            <div class="absolute top-0 left-0 w-full h-4 bg-gradient-to-b from-slate-50 to-transparent z-10 pointer-events-none"></div>
            
            <div id="grid-scroll-container" class="w-full max-h-[65vh] overflow-y-auto pb-16 pt-2 px-2 styled-scrollbar">
                <div id="menu-grid" class="w-full grid grid-cols-2 sm:grid-cols-4 md:grid-cols-7 gap-3 md:gap-4">
                    <!-- Grid is generated by JavaScript -->
                </div>
            </div>
            
            <!-- Bottom Fade -->
            <div class="absolute bottom-0 left-0 w-full h-12 bg-gradient-to-t from-slate-50 to-transparent z-10 pointer-events-none"></div>
        </div>
    </div>


    <!-- ========================================== -->
    <!-- VIEW 2: MASTER GAME APP                    -->
    <!-- ========================================== -->
    <div id="view-game" class="hidden w-full max-w-6xl mx-auto flex-col items-center animate-in slide-in-from-bottom-8 duration-500 pb-16">
        
        <!-- Navigation Bar -->
        <div class="w-full flex justify-start mb-6 md:mb-8">
            <button onclick="closeGameView()" class="flex items-center gap-2 text-slate-500 hover:text-blue-600 font-bold uppercase tracking-widest text-xs transition-colors bg-white px-4 py-2 rounded-lg border border-slate-200 shadow-sm hover:shadow-md">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Hub
            </button>
        </div>

        <!-- Header Section -->
        <div class="max-w-6xl mx-auto w-full flex flex-col items-center justify-center gap-6 mb-6 md:mb-10 text-center">
            
            <!-- Top: Title and Date -->
            <div class="flex flex-col items-center gap-2">
                <h1 class="text-4xl md:text-5xl uppercase tracking-wider text-slate-900 transition-colors flex items-center justify-center gap-3" style="font-family: 'Permanent Marker', cursive;">
                    <span class="flex flex-col text-center leading-[0.9]">
                        <span>Daily</span>
                        <span>Mic-Check</span>
                    </span>
                </h1>
                <p class="text-sm md:text-lg text-slate-500 font-medium transition-colors mt-2">
                    Date: <span id="display-date">Loading...</span>
                </p>
            </div>

            <!-- Bottom: Larger Difficulty Stars -->
            <div class="flex flex-col items-center p-4 md:p-6 rounded-2xl md:rounded-3xl shadow-lg bg-white border border-slate-200 gap-2 transition-all duration-300 w-auto">
                <span id="level-text" class="text-sm md:text-base font-bold text-slate-500 uppercase tracking-widest">Level: beginner</span>
                <div id="star-container" class="flex gap-2 md:gap-3 mt-1" onmouseleave="resetStarsHover()">
                    <i data-lucide="star" class="w-8 h-8 md:w-10 md:h-10 transition-colors duration-300 star-empty cursor-pointer" id="star-1" onmouseover="hoverStars(1)" onclick="setDifficulty(1)"></i>
                    <i data-lucide="star" class="w-8 h-8 md:w-10 md:h-10 transition-colors duration-300 star-empty cursor-pointer" id="star-2" onmouseover="hoverStars(2)" onclick="setDifficulty(2)"></i>
                    <i data-lucide="star" class="w-8 h-8 md:w-10 md:h-10 transition-colors duration-300 star-empty cursor-pointer" id="star-3" onmouseover="hoverStars(3)" onclick="setDifficulty(3)"></i>
                    <i data-lucide="star" class="w-8 h-8 md:w-10 md:h-10 transition-colors duration-300 star-empty cursor-pointer" id="star-4" onmouseover="hoverStars(4)" onclick="setDifficulty(4)"></i>
                    <i data-lucide="star" class="w-8 h-8 md:w-10 md:h-10 transition-colors duration-300 star-empty cursor-pointer" id="star-5" onmouseover="hoverStars(5)" onclick="setDifficulty(5)"></i>
                </div>
            </div>
        </div>

        <!-- Info message while loading -->
        <div id="loading-msg" class="max-w-6xl mx-auto text-center text-slate-500 mb-4 text-sm hidden">
            Fetching challenge...
        </div>

        <!-- Card Grid -->
        <div class="max-w-6xl mx-auto w-full grid grid-cols-4 gap-1 md:gap-6 mb-8 md:mb-12">
            <!-- Challenge Card -->
            <div class="card-container h-36 sm:h-56 md:h-80" onclick="toggleCard('challenge')">
                <div id="card-challenge" class="relative w-full h-full transition-all duration-500 transform-gpu preserve-3d">
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-white shadow-md md:shadow-xl flex flex-col items-center justify-center p-1 md:p-6 text-center bg-gradient-to-br from-blue-600 to-blue-800">
                        <i data-lucide="refresh-cw" class="text-white w-4 h-4 md:w-8 md:h-8 mb-1 md:mb-4 opacity-50"></i>
                        <span class="text-white font-bold text-[8px] md:text-lg uppercase tracking-tighter">Challenge</span>
                        <span class="text-white/70 text-[6px] md:text-xs mt-1 block">1 Star</span>
                    </div>
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-white shadow-md md:shadow-xl flex flex-col items-center justify-center p-1 md:p-6 text-center bg-white rotate-y-180">
                        <span class="text-[7px] md:text-xs font-bold uppercase tracking-widest mb-1 md:mb-4 text-blue-700">Challenge</span>
                        <p id="text-challenge" class="text-[9px] sm:text-sm md:text-xl font-serif font-semibold text-gray-800 leading-tight"></p>
                    </div>
                </div>
            </div>

            <!-- Sponsor Card -->
            <div class="card-container h-36 sm:h-56 md:h-80" onclick="toggleCard('sponsor')">
                <div id="card-sponsor" class="relative w-full h-full transition-all duration-500 transform-gpu preserve-3d">
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-white shadow-md md:shadow-xl flex flex-col items-center justify-center p-1 md:p-6 text-center bg-gradient-to-br from-purple-600 to-purple-800">
                        <i data-lucide="refresh-cw" class="text-white w-4 h-4 md:w-8 md:h-8 mb-1 md:mb-4 opacity-50"></i>
                        <span class="text-white font-bold text-[8px] md:text-lg uppercase tracking-tighter">Sponsor</span>
                        <span class="text-white/70 text-[6px] md:text-xs mt-1 block">1 Star</span>
                    </div>
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-white shadow-md md:shadow-xl flex flex-col items-center justify-center p-1 md:p-6 text-center bg-white rotate-y-180">
                        <span class="text-[7px] md:text-xs font-bold uppercase tracking-widest mb-1 md:mb-4 text-purple-700">Sponsor</span>
                        <p id="text-sponsor" class="text-[9px] sm:text-sm md:text-xl font-serif font-semibold text-gray-800 leading-tight"></p>
                    </div>
                </div>
            </div>

            <!-- Script Card -->
            <div class="card-container h-36 sm:h-56 md:h-80" onclick="toggleCard('script')">
                <div id="card-script" class="relative w-full h-full transition-all duration-500 transform-gpu preserve-3d">
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-white shadow-md md:shadow-xl flex flex-col items-center justify-center p-1 md:p-6 text-center bg-gradient-to-br from-emerald-600 to-emerald-800">
                        <i data-lucide="refresh-cw" class="text-white w-4 h-4 md:w-8 md:h-8 mb-1 md:mb-4 opacity-50"></i>
                        <span class="text-white font-bold text-[8px] md:text-lg uppercase tracking-tighter">Script</span>
                        <span class="text-white/70 text-[6px] md:text-xs mt-1 block">1 Star</span>
                    </div>
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-white shadow-md md:shadow-xl flex flex-col items-center justify-center p-1 md:p-6 text-center bg-white rotate-y-180">
                        <span class="text-[7px] md:text-xs font-bold uppercase tracking-widest mb-1 md:mb-4 text-emerald-700">Script</span>
                        <p id="text-script" class="text-[9px] sm:text-sm md:text-xl font-serif font-semibold text-gray-800 leading-tight"></p>
                    </div>
                </div>
            </div>

            <!-- Mic-Check Card -->
            <div class="card-container h-36 sm:h-56 md:h-80" onclick="toggleCard('micCheck')">
                <div id="card-micCheck" class="relative w-full h-full transition-all duration-500 transform-gpu preserve-3d">
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-amber-400 shadow-[0_0_15px_rgba(251,191,36,0.5)] flex flex-col items-center justify-center p-1 md:p-6 text-center bg-gradient-to-br from-red-800 via-red-900 to-black">
                        <i data-lucide="mic" class="text-amber-400 w-5 h-5 md:w-10 md:h-10 mb-1 md:mb-3 animate-pulse drop-shadow-[0_0_8px_rgba(251,191,36,0.8)]"></i>
                        <span class="text-transparent bg-clip-text bg-gradient-to-b from-amber-200 to-amber-500 font-black text-[8px] md:text-lg uppercase tracking-tighter">Mic-Check</span>
                        <span class="bg-gradient-to-r from-amber-400 to-yellow-500 text-red-950 font-bold px-2 py-0.5 rounded-full text-[6px] md:text-xs mt-2 inline-block shadow-sm border border-amber-200">2 STARS</span>
                    </div>
                    <div class="absolute inset-0 w-full h-full backface-hidden rounded-lg md:rounded-xl border-2 md:border-4 border-amber-400 shadow-[0_0_15px_rgba(251,191,36,0.5)] flex flex-col items-center justify-center p-1 md:p-6 text-center bg-white rotate-y-180">
                        <span class="text-[7px] md:text-xs font-bold uppercase tracking-widest mb-1 md:mb-4 text-red-800">Mic-Check</span>
                        <p id="text-micCheck" class="text-[9px] sm:text-sm md:text-xl font-serif font-semibold text-gray-800 leading-tight"></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dynamic Ad-Lib Panel & Timer Controls -->
        <div class="max-w-5xl mx-auto w-full mb-8 md:mb-12 px-4 flex flex-col items-center">
            <div id="madlib-panel" class="w-full bg-white p-6 md:p-10 rounded-2xl md:rounded-3xl shadow-lg border border-slate-200 text-center transition-all duration-500">
                <h2 id="madlib-heading" class="text-xs md:text-sm font-bold text-slate-400 uppercase tracking-widest mb-4 transition-colors">Today's Daily Mic-Check is...</h2>
                <p id="ad-lib-sentence" class="text-lg md:text-3xl font-serif text-slate-700 leading-relaxed md:leading-loose transition-colors">
                    Loading...
                </p>
                
                <div id="cba-errorMsg" class="hidden mt-4 text-sm font-medium text-red-500 bg-red-50 p-3 rounded-lg border border-red-200 shadow-sm text-left w-full"></div>

                <!-- Timer & Action Console -->
                <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6 bg-slate-50 p-4 sm:p-6 rounded-2xl border border-slate-200 w-full max-w-xl mx-auto">
                    
                    <!-- Timer Display -->
                    <div id="timer-container" class="relative flex items-center justify-center bg-white border border-slate-200 px-6 py-3 rounded-xl shadow-inner min-w-[140px] transition-colors duration-300">
                        <div id="cba-recordingIndicator" class="hidden absolute -top-1 -right-1 flex h-4 w-4">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-4 w-4 bg-rose-600"></span>
                        </div>
                        <div id="timer-display" class="text-4xl md:text-5xl font-mono font-bold tracking-widest text-slate-800 transition-colors">
                            1:30
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex gap-3 w-full sm:w-auto">
                        <button onclick="toggleTimerAndMic()" id="timer-toggle" class="flex-1 sm:flex-none bg-[#106030] hover:bg-green-800 text-white font-bold text-sm md:text-base uppercase tracking-widest py-3 px-6 md:px-8 rounded-xl shadow-md transition-transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
                            <i id="toggle-icon" data-lucide="mic" class="w-5 h-5"></i>
                            <span id="toggle-text">Start Mic & Timer</span>
                        </button>
                        <button onclick="resetTimer()" class="flex-1 sm:flex-none bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold text-sm md:text-base uppercase tracking-widest py-3 px-6 rounded-xl shadow-sm transition-transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
                            <i data-lucide="rotate-ccw" class="w-5 h-5"></i>
                            <span class="hidden md:inline">Reset</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Celebration Panel -->
        <div id="celebration-panel" class="hidden w-full max-w-4xl mx-auto mt-2 mb-10 rounded-3xl shadow-xl p-8 text-center border transition-all duration-500 scale-95 opacity-0">
            <h2 id="celeb-comment" class="text-xl md:text-3xl font-black uppercase tracking-widest mb-6 drop-shadow-sm">Waiting...</h2>
            <div class="flex flex-row justify-center items-center gap-8 md:gap-16">
                <div class="flex flex-col items-center">
                    <span id="celeb-label-grade" class="font-bold uppercase tracking-widest text-xs mb-1 opacity-80">Final Grade</span>
                    <span id="celeb-grade" class="text-5xl md:text-7xl font-black drop-shadow-sm">- / 10</span>
                </div>
                <div id="celeb-divider" class="w-px h-20 bg-slate-300 opacity-50"></div>
                <div class="flex flex-col items-center">
                    <span id="celeb-label-time" class="font-bold uppercase tracking-widest text-xs mb-1 opacity-80">Time</span>
                    <span id="celeb-time" class="text-5xl md:text-7xl font-black drop-shadow-sm">-</span>
                </div>
            </div>
        </div>

        <!-- Content Balance Analyzer Integrations -->
        <div id="cba-wrapper" class="w-full max-w-6xl mx-auto mb-16">
            <div class="flex flex-col space-y-6 sm:space-y-8">
                
                <!-- ALL RESULTS CONTAINER -->
                <div id="cba-resultsContainer" class="flex flex-col space-y-6 sm:space-y-8 mt-4">
                    
                    <!-- LOADING / PROCESSING PANEL -->
                    <div id="cba-processing-panel" class="hidden score-card glass-panel p-8 rounded-2xl border-t-4 border-blue-500 shadow-md bg-gradient-to-b from-blue-50 to-white flex flex-col items-center justify-center transition-all duration-300">
                        <div class="relative flex items-center justify-center mb-4 w-16 h-16 bg-blue-100 rounded-full shadow-inner">
                            <i data-lucide="refresh-cw" class="w-8 h-8 text-blue-600 animate-spin"></i>
                            <i data-lucide="mic" class="w-4 h-4 text-blue-800 absolute"></i>
                        </div>
                        <h2 class="text-xl md:text-2xl font-black uppercase tracking-widest text-slate-800 drop-shadow-sm text-center">We're checkin' on your Mic-Check...</h2>
                        <p class="text-sm text-slate-500 font-medium mt-2 text-center animate-pulse">Running advanced parallel transcription and analysis. Please hold tight!</p>
                    </div>

                    <!-- 2. SCORE SUMMARY DASHBOARD -->
                    <div id="cba-summaryCard" class="score-card glass-panel p-5 sm:p-6 rounded-2xl border-t-4 border-slate-800 shadow-sm transition-colors duration-300">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-4 border-b pb-4 border-slate-100 gap-4">
                            <h2 class="text-lg font-bold text-slate-800 cursor-pointer hover:text-blue-600 transition-colors" onclick="explain('Score Summary')">Score Summary</h2>
                            <div class="flex items-center gap-4 w-full md:w-auto justify-between md:justify-end">
                                <div class="flex items-center gap-2 bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-200 cursor-pointer hover:bg-blue-50 hover:border-blue-200 transition-colors" onclick="explain('Time')">
                                    <span class="text-xs font-bold text-slate-500 uppercase pointer-events-none">Time:</span>
                                    <span id="sum-time" class="font-bold text-slate-800 text-sm pointer-events-none">-</span>
                                    <span id="sum-time-eval" class="score-eval bg-slate-100 text-slate-500 ml-1 pointer-events-none">Waiting</span>
                                </div>
                                <div class="text-base font-black text-slate-700 bg-slate-100 px-3 py-1.5 rounded-lg shadow-inner cursor-pointer hover:bg-blue-100 transition-colors" onclick="explain('Grade')">
                                    Grade: <span id="cba-overallGrade" class="text-blue-600 pointer-events-none">- / 10</span>
                                </div>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                            <!-- Content -->
                            <div class="space-y-3">
                                <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider border-b border-slate-100 pb-1 cursor-pointer hover:text-blue-600 transition-colors inline-block" onclick="explain('Content')">Content</h3>
