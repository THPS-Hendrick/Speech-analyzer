        window.analyze = function() {
            if (!dictsLoaded) return;
            const text = inputEl.value.trim();
            
            if (!text) {
                document.getElementById('cba-highlightContainer').classList.add('hidden');
                document.getElementById('cba-copyBtn').classList.add('hidden');
                updateCelebrationPanel(0, 0, true, false, 0); 
                return;
            }

            const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
            const words = text.split(/\s+/).filter(w => w.trim().length > 0);
            const letterCount = text.replace(/[^a-zA-Z]/g, '').length;
            
            let totalSyllables = 0; let complexWordCount = 0;
            let personalCount = 0; let visualCount = 0;
            let simpleCounts = { '5yr Old 1000': 0, 'ESL 2000': 0, 'Kitchen 1000': 0, 'outside': 0 };
            let google10kCount = 0;

            let highlightedHTML = ""; reportMarkdownText = ""; 
            let inQuotes = false;
            
            let useFallback = true;
            if (typeof window.nlp === 'function') {
                try {
                    let doc = window.nlp(text);
                    try { doc.compute('root'); } catch(e) {} 
                    const jsonDoc = doc.json({ terms: true }); 
                    
                    for (let sIdx = 0; sIdx < jsonDoc.length; sIdx++) {
                        const sentence = jsonDoc[sIdx];
                        if (!sentence.terms) continue; 
                        let personalCountdown = 0; let visualCountdown = 0; 

                        for (let tIdx = 0; tIdx < sentence.terms.length; tIdx++) {
                            const term = sentence.terms[tIdx];
                            let rawText = term.text || ""; let rawPre = term.pre || ""; let rawPost = term.post || "";
                            let rawRoot = term.root || term.normal || rawText;

                            let root = String(rawRoot).toLowerCase().replace(/[^a-z]/g, '');
                            let normal = String(term.normal || rawText).toLowerCase().replace(/[^a-z']/g, ''); 
                            
                            if (rawPre.includes('"') || rawPre.includes('“') || rawText.includes('“') || rawText.startsWith('"')) inQuotes = true;
                            if (personalPronouns.has(normal)) personalCountdown = 6;
                            if (!personalPronouns.has(normal)) {
                                if (visualDictPronouns.has(normal) || visualDictWords.has(normal) || visualDictWords.has(root)) {
                                    visualCountdown = Math.max(visualCountdown, 4);
                                }
                            }

                            let isPersonal = (inQuotes || personalCountdown > 0);
                            let isVisual = (visualCountdown > 0); 

                            if (personalCountdown > 0) personalCountdown--;
                            if (visualCountdown > 0) visualCountdown--;
                            if (/[.!?]/.test(rawText) || /[.!?]/.test(rawPost)) { visualCountdown = 0; personalCountdown = 0; }
                            if (rawPost.includes('"') || rawPost.includes('”') || rawText.includes('”') || rawText.endsWith('"')) inQuotes = false;

                            let safePre = rawPre.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                            let safePost = rawPost.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                            let safeText = rawText.replace(/</g, "&lt;").replace(/>/g, "&gt;");

                            if (/[a-zA-Z]/.test(rawText)) {
                                if (isPersonal && isVisual) {
                                    highlightedHTML += `${safePre}<span class="overlap-word">${safeText}</span>${safePost}`;
                                    reportMarkdownText += `${rawPre}_**${rawText}**_${rawPost}`;
                                    personalCount++; visualCount++;
                                } else if (isPersonal) {
                                    highlightedHTML += `${safePre}<span class="personal-word">${safeText}</span>${safePost}`;
                                    reportMarkdownText += `${rawPre}**${rawText}**${rawPost}`;
                                    personalCount++;
                                } else if (isVisual) {
                                    highlightedHTML += `${safePre}<span class="visual-word">${safeText}</span>${safePost}`;
                                    reportMarkdownText += `${rawPre}_${rawText}_${rawPost}`;
                                    visualCount++;
                                } else {
                                    highlightedHTML += `${safePre}${safeText}${safePost}`;
                                    reportMarkdownText += `${rawPre}${rawText}${rawPost}`;
                                }
                            } else {
                                highlightedHTML += `${safePre}${safeText}${safePost}`;
                                reportMarkdownText += `${rawPre}${rawText}${rawPost}`;
                            }
                        }
                    }
                    useFallback = false;
                } catch(e) { useFallback = true; }
            }

            if (useFallback) {
                let tokens = text.split(/([a-zA-Z']+)/);
                let personalCountdown = 0; let visualCountdown = 0;
                tokens.forEach(token => {
                    if (/[.!?]/.test(token)) { visualCountdown = 0; personalCountdown = 0; inQuotes = false; }
                    if (/[a-zA-Z]/.test(token)) {
                        let normal = token.toLowerCase().replace(/[^a-z']/g, '');
                        let root = normal.replace(/(?:s|es|ed|ing)$/, ''); 
                        if (personalPronouns.has(normal)) personalCountdown = 6;
                        if (!personalPronouns.has(normal) && (visualDictPronouns.has(normal) || visualDictWords.has(normal) || visualDictWords.has(root))) {
                            visualCountdown = Math.max(visualCountdown, 4);
                        }
                        let isPersonal = (inQuotes || personalCountdown > 0);
                        let isVisual = (visualCountdown > 0);
                        if (personalCountdown > 0) personalCountdown--;
                        if (visualCountdown > 0) visualCountdown--;

                        let safeText = token.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                        if (isPersonal && isVisual) { highlightedHTML += `<span class="overlap-word">${safeText}</span>`; reportMarkdownText += `_**${token}**_`; personalCount++; visualCount++; } 
                        else if (isPersonal) { highlightedHTML += `<span class="personal-word">${safeText}</span>`; reportMarkdownText += `**${token}**`; personalCount++; } 
                        else if (isVisual) { highlightedHTML += `<span class="visual-word">${safeText}</span>`; reportMarkdownText += `_${token}_`; visualCount++; } 
                        else { highlightedHTML += safeText; reportMarkdownText += token; }
                    } else {
                        let quoteMatches = (token.match(/["“”]/g) || []).length;
                        if (quoteMatches % 2 !== 0) inQuotes = !inQuotes;
                        highlightedHTML += token.replace(/</g, "&lt;").replace(/>/g, "&gt;"); reportMarkdownText += token;
                    }
                });
            }

            words.forEach(word => {
                let cleanWord = word.toLowerCase().replace(/[^a-z']/g, '');
                let syl = countSyllables(cleanWord);
                totalSyllables += syl;
                if (syl >= 3) complexWordCount++;
                if (cleanWord.length > 0) {
                    if (google10kSet.has(cleanWord)) google10kCount++;
                    let sTier = simpleMap.get(cleanWord);
                    if (!sTier && typeof window.nlp === 'function') {
                        try {
                            let doc = window.nlp(cleanWord).compute('root').json();
                            if (doc.length > 0 && doc[0].terms.length > 0) {
                                let rootWord = doc[0].terms[0].root || doc[0].terms[0].normal;
                                if (rootWord) sTier = simpleMap.get(rootWord);
                            }
                        } catch(e) {}
                    }
                    simpleCounts[sTier || 'outside']++;
                }
            });

            const numSentences = Math.max(1, sentences.length);
            const numWords = Math.max(1, words.length);

            document.getElementById('cba-highlightContainer').classList.remove('hidden'); 
            document.getElementById('cba-copyBtn').classList.remove('hidden'); 
            document.getElementById('cba-highlightedText').innerHTML = highlightedHTML.replace(/\n/g, '<br>');

            let gPct = Math.round((google10kCount / numWords) * 100);
            if (google10kSet.size > 0 && numWords > 0) {
                document.getElementById('cba-googleScore').textContent = `${gPct}%`;
                document.getElementById('cba-googleProgress').style.width = `${Math.min(100, Math.max(0, gPct))}%`;
                document.getElementById('cba-googleCount').textContent = `${google10kCount} out of ${numWords} words`;
                let gColor = gPct > 80 ? "#10b981" : gPct > 60 ? "#f59e0b" : "#ef4444";
                document.getElementById('cba-googleInterpret').textContent = gPct > 80 ? "Highly Common" : gPct > 60 ? "Moderately Common" : "Highly Unique/Niche";
                document.getElementById('cba-googleCard').style.borderLeftColor = gColor;
                document.getElementById('cba-googleProgress').style.backgroundColor = gColor;
                document.getElementById('cba-googleScore').style.color = gColor;
            }

            let s5yrPct = Math.round((simpleCounts['5yr Old 1000'] / numWords) * 100) || 0;
            let sEslPct = Math.round((simpleCounts['ESL 2000'] / numWords) * 100) || 0;
            let sKitPct = Math.round((simpleCounts['Kitchen 1000'] / numWords) * 100) || 0;
            let coreSimpleScore = s5yrPct + sEslPct + sKitPct; 
            document.getElementById('cba-simpleScore').textContent = `${coreSimpleScore}%`;
            document.getElementById('cba-simpleBar5yr').style.width = `${s5yrPct}%`;
            document.getElementById('cba-simpleBarEsl').style.width = `${sEslPct}%`;
            document.getElementById('cba-simpleBarKit').style.width = `${sKitPct}%`;
            document.getElementById('cba-s5yr').textContent = `${s5yrPct}%`;
            document.getElementById('cba-sEsl').textContent = `${sEslPct}%`;
            document.getElementById('cba-sKit').textContent = `${sKitPct}%`;
            document.getElementById('cba-sOut').textContent = `${Math.round((simpleCounts['outside'] / numWords) * 100) || 0}%`;
            document.getElementById('cba-simpleInterpret').textContent = coreSimpleScore > 85 ? "Extremely Accessible" : coreSimpleScore > 70 ? "Good Accessibility" : "Highly advanced vocabulary";

            let elapsedSecs = recordedAudio ? (window.lastRecordedDuration || 0) : 0;
            let transcribedDuration = Math.min(90, elapsedSecs);
            
            let mumbleScore = 0; 
            let estimatedPauseTime = 0; 
            let pausePercent = 0; 
            let avgWpm = 0;
            let activeSpeakingSecs = 0;

            const mmCard = document.getElementById('cba-mumbleCard');
            const wCard = document.getElementById('cba-wpmCard');

            if (recordedAudio && elapsedSecs > 0) {
                mmCard.classList.remove('opacity-50');
                wCard.classList.remove('opacity-50');

                const periods = (text.match(/[.!?]/g) || []).length;
                const commas = (text.match(/[,;:-]/g) || []).length;
                
                estimatedPauseTime = (periods * 1.3) + (commas * 0.5); 
                
                let minAllowedPause = transcribedDuration * 0.10;
                let maxAllowedPause = transcribedDuration * 0.40;
                if (estimatedPauseTime < minAllowedPause) estimatedPauseTime = minAllowedPause;
                if (estimatedPauseTime > maxAllowedPause) estimatedPauseTime = maxAllowedPause;
                
                activeSpeakingSecs = transcribedDuration - estimatedPauseTime;
                pausePercent = (estimatedPauseTime / transcribedDuration) * 100;
                
                avgWpm = Math.round((numWords / transcribedDuration) * 60);
                mumbleScore = totalSyllables / activeSpeakingSecs;

                let mColor, mText;
                if (mumbleScore < 2.5) { mColor = "#3b82f6"; mText = "Slightly too slow"; } 
                else if (mumbleScore < 4.0) { mColor = "#10b981"; mText = "Very clear, no mumble"; } 
                else if (mumbleScore <= 5.5) { mColor = "#f97316"; mText = "Slight mumble"; } 
                else { mColor = "#ef4444"; mText = "High Mumbling Risk"; } 

                document.getElementById('cba-mumbleScore').textContent = mumbleScore.toFixed(1);
                document.getElementById('cba-mumbleInterpret').textContent = mText;
                document.getElementById('cba-mumbleInterpret').style.color = mColor;
                document.getElementById('cba-mumbleScore').style.color = mColor;
                mmCard.style.borderLeftColor = mColor;
                document.getElementById('cba-mumbleMarker').style.left = Math.min(100, Math.max(0, (mumbleScore / 8) * 100)) + "%";
                document.getElementById('cba-mumbleStats').textContent = `${activeSpeakingSecs.toFixed(1)}s active / ${estimatedPauseTime.toFixed(1)}s pause / ${transcribedDuration.toFixed(1)}s analyzed`;

                document.getElementById('cba-wpmScore').textContent = avgWpm;
                document.getElementById('cba-wpmScore').classList.replace('text-slate-400', 'text-amber-500');

                let wpmData = [];
                let numIntervals = Math.ceil(transcribedDuration / 20);
                for (let i = 0; i < numIntervals; i++) {
                    let intervalDuration = (i === numIntervals - 1) ? (transcribedDuration % 20 || 20) : 20;
                    let share = intervalDuration / transcribedDuration;
                    let baseWords = numWords * share;
                    let variation = 1 + (Math.sin(i * 1.5) * 0.12); 
                    let intervalWords = Math.round(baseWords * variation);
                    let intervalWpm = Math.round((intervalWords / intervalDuration) * 60);
                    wpmData.push(intervalWpm);
                }

                if (wpmChartInstance) wpmChartInstance.destroy();
                wpmChartInstance = new window.Chart(document.getElementById('cba-wpmChart'), {
                    type: 'bar',
                    data: { 
                        labels: wpmData.map((_, i) => `${(i+1)*20}s`), 
                        datasets: [{ 
                            label: 'WPM', 
                            data: wpmData, 
                            backgroundColor: 'rgba(245, 158, 11, 0.5)', 
                            borderColor: 'rgba(245, 158, 11, 1)', 
                            borderWidth: 1, 
                            borderRadius: 4 
                        }] 
                    },
                    options: { responsive: true, scales: { y: { beginAtZero: true, suggestedMax: 180 } }, plugins: { legend: { display: false } } }
                });

            } else {
                mmCard.classList.add('opacity-50');
                wCard.classList.add('opacity-50');
                document.getElementById('cba-mumbleInterpret').textContent = "Waiting for Audio...";
                document.getElementById('cba-wpmScore').classList.replace('text-amber-500', 'text-slate-400');
            }

            let avgGrade = ((Math.max(0, (0.39 * (numWords / numSentences)) + (11.8 * (totalSyllables / numWords)) - 15.59)) + (Math.max(0, 0.4 * ((numWords / numSentences) + 100 * (complexWordCount / numWords)))) + (Math.max(0, 1.0430 * Math.sqrt(complexWordCount * (30 / numSentences)) + 3.1291)) + (Math.max(0, 0.0588 * ((letterCount / numWords) * 100) - 0.296 * ((numSentences / numWords) * 100) - 15.8))) / 4;
            document.getElementById('cba-gradeLevel').textContent = avgGrade.toFixed(1);
            let gradeColor = avgGrade <= 4.4 ? "#f97316" : avgGrade <= 8.4 ? "#10b981" : avgGrade <= 9.5 ? "#00B700" : gradeColor = avgGrade <= 12.5 ? "#f59e0b" : "#ef4444";
            document.getElementById('cba-gradeInterpret').textContent = avgGrade <= 4.4 ? "Pitched to 5-10 yr old" : avgGrade <= 8.4 ? "Short & Simple" : avgGrade <= 9.5 ? "Perfect Plain English" : avgGrade <= 12.5 ? "Audience Strain" : "Too Complex";
            document.getElementById('cba-gradeInterpret').style.color = gradeColor;
            document.getElementById('cba-simpleComplexCard').style.borderLeftColor = gradeColor;
            document.getElementById('cba-gradeProgress').style.backgroundColor = gradeColor;
            document.getElementById('cba-gradeProgress').style.width = `${Math.min(100, Math.max(0, (avgGrade / 18) * 100))}%`;

            let personalPercent = Math.round((personalCount / numWords) * 100);
            document.getElementById('cba-personalScore').textContent = `${personalPercent}%`;
            let pColor = personalPercent <= 29 ? "#94a3b8" : personalPercent <= 44 ? "#10b981" : personalPercent <= 60 ? "#00B700" : "#a855f7";
            document.getElementById('cba-personalInterpret').textContent = personalPercent <= 29 ? "Highly Detached" : personalPercent <= 44 ? "Good Balance" : personalPercent <= 60 ? "Highly Personal" : "Overly Conversational?";
            document.getElementById('cba-personalCard').style.borderLeftColor = pColor;
            document.getElementById('cba-personalProgress').style.backgroundColor = pColor;
            document.getElementById('cba-personalScore').style.color = pColor;
            document.getElementById('cba-personalProgress').style.width = `${Math.min(100, Math.max(0, personalPercent))}%`;

            let visualPercent = Math.round((visualCount / numWords) * 100);
            document.getElementById('cba-visualScore').textContent = `${visualPercent}%`;
            let vColor = visualPercent <= 29 ? "#94a3b8" : visualPercent <= 44 ? "#10b981" : visualPercent <= 60 ? "#00B700" : "#a855f7";
            document.getElementById('cba-visualInterpret').textContent = visualPercent <= 29 ? "Very Intangible" : visualPercent <= 44 ? "Good" : visualPercent <= 60 ? "Very Vivid" : "Reaching poetic levels";
            document.getElementById('cba-visualCard').style.borderLeftColor = vColor;
            document.getElementById('cba-visualProgress').style.backgroundColor = vColor;
            document.getElementById('cba-visualScore').style.color = vColor;
            document.getElementById('cba-visualProgress').style.width = `${Math.min(100, Math.max(0, visualPercent))}%`;

            let avgWpsFloat = numSentences > 0 ? (numWords / numSentences) : 0;
            const avgWps = Math.round(avgWpsFloat);
            document.getElementById('cba-snScore').textContent = avgWpsFloat.toFixed(1);
            let snColor = avgWps <= 9 ? "#00B700" : avgWps <= 16 ? "#6366f1" : avgWps <= 25 ? "#f59e0b" : "#ef4444";
            document.getElementById('cba-snInterpret').textContent = avgWps <= 9 ? "Very high signal, low noise" : avgWps <= 16 ? "High signal; moderate noise" : avgWps <= 25 ? "Moderate signal; high noise" : "Low signal; very high noise";
            document.getElementById('cba-snInterpret').style.color = snColor;
            document.getElementById('cba-snCard').style.borderLeftColor = snColor;
            document.getElementById('cba-snScore').style.color = snColor;
            document.getElementById('cba-snProgress').style.backgroundColor = snColor;
            document.getElementById('cba-snProgress').style.width = `${Math.min(100, Math.max(0, (avgWps / 40) * 100))}%`;

            try {
                let totalPoints = 0;
                let overrideGrade = false;

                const setEval = (id, text, points, isTime = false) => {
                    const el = document.getElementById(id);
                    if(el) { 
                        el.textContent = text; 
                        el.className = `score-eval ${getPillColorClass(points, isTime)}`; 
                    }
                };

                let timeStatus = 'Waiting';
                let timePts = 0;
                if (recordedAudio && elapsedSecs > 0) {
                    document.getElementById('sum-time').textContent = `${elapsedSecs.toFixed(0)}s`;
                    if (elapsedSecs < 30) {
                        timeStatus = 'not enough';
                        timePts = 0;
                        overrideGrade = true;
                    } else if (elapsedSecs < 60) {
                        timeStatus = 'pretty good!';
                        timePts = 0.75;
                        totalPoints += 0.75;
                    } else if (elapsedSecs <= 90) {
                        timeStatus = 'just right';
                        timePts = 1.0;
                        totalPoints += 1.0;
                    } else {
                        timeStatus = 'too much';
                        timePts = 0;
                        overrideGrade = true;
                    }
                } else {
                    document.getElementById('sum-time').textContent = "-";
                    timeStatus = 'Text Only';
                    overrideGrade = true;
                }
                setEval('sum-time-eval', timeStatus, timePts, true);

                document.getElementById('sum-personal').textContent = `${personalPercent}%`;
                let pStatus = 'just right'; let pPts = 1;
                if (personalPercent < 30) { pStatus = 'not enough'; pPts = 0.25; totalPoints += 0.25; }
                else if (personalPercent > 60) { pStatus = 'too much'; pPts = 0.75; totalPoints += 0.75; }
                else { totalPoints += 1; }
                setEval('sum-personal-eval', pStatus, pPts);

                document.getElementById('sum-visual').textContent = `${visualPercent}%`;
                let vStatus = 'just right'; let vPts = 1;
                if (visualPercent < 20) { vStatus = 'not enough'; vPts = 0.25; totalPoints += 0.25; }
                else if (visualPercent > 50) { vStatus = 'too much'; vPts = 0.75; totalPoints += 0.75; }
                else { totalPoints += 1; }
                setEval('sum-visual-eval', vStatus, vPts);

                let intangiblePercent = Math.max(0, 100 - personalPercent - visualPercent);
                document.getElementById('sum-intangible').textContent = `${intangiblePercent}%`;
                let iStatus = 'just right'; let iPts = 1;
                if (intangiblePercent > 45) { iStatus = 'too much'; iPts = 0.25; totalPoints += 0.25; }
                else if (intangiblePercent >= 30) { iStatus = 'bit much'; iPts = 0.75; totalPoints += 0.75; }
                else { totalPoints += 1; }
                setEval('sum-intangible-eval', iStatus, iPts);

                if (recordedAudio && elapsedSecs > 0) {
                    document.getElementById('sum-wpm').textContent = avgWpm;
                    let wpmStatus = 'just right'; let wpmPts = 1;
                    if (avgWpm < 100) { wpmStatus = 'speed up'; wpmPts = 0.75; totalPoints += 0.75; }
                    else if (avgWpm > 150) { wpmStatus = 'strain'; wpmPts = 0.25; totalPoints += 0.25; }
                    else { totalPoints += 1; }
                    setEval('sum-wpm-eval', wpmStatus, wpmPts);

                    document.getElementById('sum-sps').textContent = mumbleScore.toFixed(1);
                    let spsStatus = 'just right'; let spsPts = 1;
                    if (mumbleScore < 3) { spsStatus = 'speed up'; spsPts = 0.75; totalPoints += 0.75; }
                    else if (mumbleScore > 5) { spsStatus = 'strain'; spsPts = 0.25; totalPoints += 0.25; }
                    else { totalPoints += 1; }
                    setEval('sum-sps-eval', spsStatus, spsPts);

                    document.getElementById('sum-pause').textContent = `${pausePercent.toFixed(0)}%`;
                    let pzStatus = 'just right'; let pzPts = 1;
                    if (pausePercent < 10) { pzStatus = 'too little'; pzPts = 0.25; totalPoints += 0.25; }
                    else if (pausePercent > 30) { pzStatus = 'too much'; pzPts = 0.75; totalPoints += 0.75; }
                    else { totalPoints += 1; }
                    setEval('sum-pause-eval', pzStatus, pzPts);
                } else {
                    document.getElementById('sum-wpm').textContent = "-";
                    document.getElementById('sum-sps').textContent = "-";
                    document.getElementById('sum-pause').textContent = "-";
                    const fallbackEl = (id) => { const el = document.getElementById(id); if(el) { el.textContent = 'Text Only'; el.className = 'score-eval bg-slate-100 text-slate-500'; }};
                    fallbackEl('sum-wpm-eval'); fallbackEl('sum-sps-eval'); fallbackEl('sum-pause-eval');
                }

                document.getElementById('sum-wps').textContent = avgWpsFloat.toFixed(1);
                let wpsStatus = 'just right'; let wpsPts = 1;
                if (avgWpsFloat < 5) { wpsStatus = 'too simple'; wpsPts = 0.75; totalPoints += 0.75; }
                else if (avgWpsFloat > 15) { wpsStatus = 'too complex'; wpsPts = 0.25; totalPoints += 0.25; }
                else { totalPoints += 1; }
                setEval('sum-wps-eval', wpsStatus, wpsPts);

                document.getElementById('sum-grade').textContent = avgGrade.toFixed(1);
                let gradeStatus = 'just right'; let gradePts = 1;
                if (avgGrade < 5) { gradeStatus = 'too simple'; gradePts = 0.75; totalPoints += 0.75; }
                else if (avgGrade > 10) { gradeStatus = 'too complex'; gradePts = 0.25; totalPoints += 0.25; }
                else { totalPoints += 1; }
                setEval('sum-grade-eval', gradeStatus, gradePts);

                document.getElementById('sum-simple').textContent = `${coreSimpleScore}%`;
                let simpleStatus = 'just right'; let simplePts = 1;
                if (coreSimpleScore < 85) { simpleStatus = 'too complex'; simplePts = 0.25; totalPoints += 0.25; }
                else if (coreSimpleScore > 95) { simpleStatus = 'too simple'; simplePts = 0.75; totalPoints += 0.75; }
                else { totalPoints += 1; }
                setEval('sum-simple-eval', simpleStatus, simplePts);
                
                if (overrideGrade) {
                    document.getElementById('cba-overallGrade').textContent = "- / 10";
                } else {
                    let formattedScore = totalPoints % 1 === 0 ? totalPoints : totalPoints.toFixed(2);
                    document.getElementById('cba-overallGrade').textContent = `${formattedScore} / 10`;
                }

                updateCelebrationPanel(totalPoints, elapsedSecs, overrideGrade, recordedAudio, text.length);

                let playedStars = 0;
                if (cardStates.challenge) playedStars += 1;
                if (cardStates.sponsor) playedStars += 1;
                if (cardStates.script) playedStars += 1;
                if (cardStates.micCheck) playedStars += 2;
                
                if (window.dbSaveScore && currentPlayDate && !overrideGrade) {
                    window.dbSaveScore(currentPlayDate, playedStars, totalPoints);
                }

            } catch(e) { console.error("Summary Dashboard Error:", e); }
        };

        document.getElementById('cba-copyBtn').addEventListener('click', () => {
            let cleanMarkdown = reportMarkdownText.trim().replace(/\n/g, '\n\n').replace(/ +/g, ' ');
            const report = `MIC-CHECK CHALLENGE - REPORT\n=========================================\n\n--- EXECUTIVE SUMMARY ---\n[Grade] ${document.getElementById('cba-overallGrade').textContent}\n[Content] Personal: ${document.getElementById('sum-personal').textContent} | Visual: ${document.getElementById('sum-visual').textContent} | Intangible: ${document.getElementById('sum-intangible').textContent}\n[Delivery] WPM: ${document.getElementById('sum-wpm').textContent} | Syllables/sec: ${document.getElementById('sum-sps').textContent} | Pause Time: ${document.getElementById('sum-pause').textContent}\n[Simplicity] Words/Sent: ${document.getElementById('sum-wps').textContent} | Grade: ${document.getElementById('sum-grade').textContent} | Simple %: ${document.getElementById('sum-simple').textContent}\n\n--- TRANSCRIPT (Marked Up) ---\n* Personal text is **bolded**\n* Visual text is _underlined_\n* Overlapping text is _**both**_\n\n${cleanMarkdown}\n`;
            
            const el = document.createElement('textarea');
            el.value = report;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            const btnText = document.getElementById('cba-copyBtnText');
            btnText.textContent = "Copied to Clipboard!";
            setTimeout(() => { btnText.textContent = "Copy Report"; }, 2500);
        });

        document.getElementById('cba-analyzeBtn').addEventListener('click', window.analyze);
        
        document.getElementById('cba-clearBtn').addEventListener('click', () => { 
            inputEl.value = ''; 
            document.getElementById('cba-highlightContainer').classList.add('hidden'); 
            document.getElementById('cba-copyBtn').classList.add('hidden'); 
            document.getElementById('celebration-panel').classList.add('hidden', 'scale-95', 'opacity-0');
            
            const procPanel = document.getElementById('cba-processing-panel');
            if (procPanel) procPanel.classList.add('hidden');
            
            recordedAudio = false; 

            const summaryIds = ['sum-personal', 'sum-visual', 'sum-intangible', 'sum-time', 'sum-wpm', 'sum-sps', 'sum-pause', 'sum-wps', 'sum-grade', 'sum-simple'];
            summaryIds.forEach(id => {
                const el = document.getElementById(id);
                if (el) el.textContent = id === 'sum-time' || id.includes('wpm') || id.includes('sps') || id.includes('pause') ? "-" : "0";
                const evalEl = document.getElementById(id + '-eval');
                if (evalEl) {
                    evalEl.textContent = "Waiting";
                    evalEl.className = "score-eval bg-slate-100 text-slate-500";
                }
            });
            document.getElementById('cba-overallGrade').textContent = "- / 10";
            document.getElementById('cba-explanationTitle').textContent = "What does this mean?";
            document.getElementById('cba-explanationContent').innerHTML = "Click on any term to learn more...";
            document.getElementById('cba-explanationContent').classList.add('italic', 'justify-center');
            window.analyze(); 
        });

        inputEl.addEventListener('input', () => { 
            recordedAudio = false; 
            if (inputEl.value.length === 0) { window.analyze(); document.getElementById('cba-copyBtn').classList.add('hidden'); }
        });

        window.onload = () => {
            loadDictionaries();
            fetchExplanations();
            if (window.lucide) window.lucide.createIcons();
            
            if (window.renderMenuGrid) window.renderMenuGrid();
        };

        // ==========================================
        // EXPLANATION PANEL LOGIC
        // ==========================================
        const EXPLANATIONS_URL = "https://raw.githubusercontent.com/THPS-Hendrick/Speech-analyzer/main/explanations.json"; 
        let explanationsData = null;

        const FALLBACK_EXPLANATIONS = {
            "Score Summary": "This panel breaks down your speech into 9 core metrics across Content, Delivery, and Simplicity. Every metric in the green ('just right') awards you 1 point toward your final Grade.",
            "Time": "Your total speaking time. Speaking for 60-90 seconds is 1p, 30-60 is 0.75p, and going under 30s or over 90s cancels your Grade entirely.",
            "Grade": "Your final score out of 10. Metrics in the green give 1 point, yellow gives 0.75, and red gives 0.25 points. Speaking over 90s or under 30s cancels your Grade entirely",
            "Content": "Measures the substance of your speech. Aim for 30%+ Personal examples and 30%+ Visual descriptions. Keep your ideas (Intangibles) conscise & meaningful.",
            "Delivery": "Measures how you sound. Aim for 100-150 Words Per Minute, 3 to 5 Syllables/sec (to avoid mumbling), and pause for at least 400 milliseconds often.",
            "Simplicity": "Measures how easy your speech is to understand. Keep your average sentence between 5 to 15 words, and see what academic grade or english fluency is needed to understand you",
            "Personal": "Measures storytelling and personal examples. Best speakers talk about a specific person doing specific things about 30-60% of the time. Too little is detached; too much is self-centred.",
            "Visual": "Measures words that paint a picture (objects, colors, sizes). Aim for 20-50%. Good visual balance makes your speech memorable.",
            "Intangible": "Content that is not Personal or Visual (abstract concepts and filler). Aim for under 30%. If this goes over 45%, your speech may sound like an academic paper instead of an engaging talk.",
            "Words/min": "Your speaking pace. 100-150 words per minute is 'just right'. Slower sounds hesitant, while faster can strain the audience.",
            "Syllable/sec": "Our 'Mumble Meter'. It measures how densely packed your syllables are during active speech. 3 to 5 syllables per second is ideal.",
            "Pause %": "The percentage of time you spend silent. Aim for 10-30%. Pause is about 400 milliseconds or more and gives the audience time to process your ideas.",
            "Words/Sent": "The average length of your sentences. Aim for 5-15 words. If each sentence has 1 point, then avoid diluting your ideas with excess words.",
            "Comp. Grade": "The reading grade level of your speech (based on academic reading studies, sentence length & syllable length). A grade of 5-10 is 'just right' and plain english. Anything higher is too complex for spoken word.",
            "Simple %": "The percentage of your words within the 10,000 words used by people learning english. The best communicators use 85-95% simple words to explain complex ideas."
        };

        async function fetchExplanations() {
            try {
                const res = await fetch(EXPLANATIONS_URL + '?nocache=' + new Date().getTime());
                if (res.ok) explanationsData = await res.json();
            } catch (e) {
                console.warn("Using fallback explanations for 'What does this mean' panel.");
            }
        }

        window.explain = function(term) {
            const panel = document.getElementById('cba-explanationPanel');
            const titleEl = document.getElementById('cba-explanationTitle');
            const contentEl = document.getElementById('cba-explanationContent');
            
            panel.classList.add('ring-2', 'ring-blue-400', 'scale-[1.01]');
            setTimeout(() => panel.classList.remove('ring-2', 'ring-blue-400', 'scale-[1.01]'), 300);

            titleEl.innerText = term;
            contentEl.classList.remove('italic', 'justify-center');
            contentEl.innerHTML = `<span class="animate-pulse">Loading explanation...</span>`;

            setTimeout(() => {
                let text = (explanationsData && explanationsData[term]) 
                           ? explanationsData[term] 
                           : (FALLBACK_EXPLANATIONS[term] || `Detailed explanation for "${term}" will appear here soon.`);
                contentEl.innerHTML = text;
            }, 150);
        };

        window.toggleExtendedStats = function() {
            const statsContainer = document.getElementById('cba-extendedStats');
            const btnText = document.getElementById('toggle-stats-text');
            const btnIcon = document.getElementById('toggle-stats-icon');

            if (statsContainer.classList.contains('hidden')) {
                statsContainer.classList.remove('hidden');
                statsContainer.classList.add('flex');
                btnText.innerText = 'Hide Your Stats';
                btnIcon.classList.add('rotate-180');
                btnIcon.classList.remove('group-hover:translate-y-0.5');
                btnIcon.classList.add('group-hover:-translate-y-0.5');
            } else {
                statsContainer.classList.add('hidden');
                statsContainer.classList.remove('flex');
                btnText.innerText = 'See Your Stats';
                btnIcon.classList.remove('rotate-180');
                btnIcon.classList.add('group-hover:translate-y-0.5');
                btnIcon.classList.remove('group-hover:-translate-y-0.5');
            }
        };
    </script>
</body>
</html>
