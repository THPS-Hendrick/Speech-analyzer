{
    "title": "Pitching Level 1",
    "totalSteps": 2,
    "modules": [
        {
            "step": 1,
            "title": "1. The Baseline Pitch",
            "type": "recording",
            "instructions": "Pitch your idea in under 60 seconds. You must speak slowly and clearly.",
            "targets": {
                "time": { "min": 20, "max": 60, "label": "Time (Seconds)" },
                "wpm": { "min": 100, "max": 150, "label": "Pace (WPM)" },
                "sps": { "min": 3.0, "max": 5.0, "label": "Clarity (Syllables/Sec)" }
            }
        },
        {
            "step": 2,
            "title": "2. Painting a Picture",
            "type": "recording",
            "instructions": "Describe a $10 million house. You must use highly visual language.",
            "targets": {
                "visual": { "min": 40, "max": 100, "label": "Visual Words (%)" },
                "time": { "min": 30, "max": 90, "label": "Time (Seconds)" }
            }
        }
    ]
}
